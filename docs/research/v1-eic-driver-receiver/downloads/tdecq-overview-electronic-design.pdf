scription" property="og:description" item-prop="description" content="When decisions were made to change from historical NRZ or simple on-off modulation to PAM4 in the development of advanced comms systems, methods to quantify transmitter performance..."><meta property="og:title" item-prop="name" content="TDECQ: Understanding the Theory Behind the Key Metric for PAM4 Optical Transmitters"><meta name="og:url" content="https://www.electronicdesign.com/technologies/test-measurement/article/21283812/keysight-technologies-tdecq-understanding-the-theory-behind-the-key-metric-for-pam4-optical-transmitters"><meta name="og:site_name" content="Electronic Design"><meta name="og:locale" content="en"><meta name="twitter:card" content="summary_large_image"><meta name="twitter:title" content="TDECQ: Understanding the Theory Behind the Key Metric for PAM4 Optical Transmitters"><meta name="twitter:description" content="When decisions were made to change from historical NRZ or simple on-off modulation to PAM4 in the development of advanced comms systems, methods to quantify transmitter performance..."><meta hid="og-type" name="og:type" content="article"><meta hid="type" name="type" content="article"><meta name="image" property="og:image" item-prop="image" content="https://img.electronicdesign.com/files/base/ebm/electronicdesign/image/2024/03/65e1fbaf709a66001eb9fdd7-dreamstime_agsandrew_32581249promo.png?auto=format,compress&fit=fill&fill=blur&w=1200&h=630"><meta name="twitter:image:src" content="https://img.electronicdesign.com/files/base/ebm/electronicdesign/image/2024/03/65e1fbaf709a66001eb9fdd7-dreamstime_agsandrew_32581249promo.png?auto=format,compress&fit=fill&fill=blur&w=1200&h=630"><meta name="robots" content="max-image-preview:large"><meta name="contentId" content="21283812"><meta name="pterm" content="test & measurement"><meta name="tag" content="optical modulation amplitude,extinction ratio,symbol error ratio,transmitter dispersion and eye closure quaternary,bit error rate