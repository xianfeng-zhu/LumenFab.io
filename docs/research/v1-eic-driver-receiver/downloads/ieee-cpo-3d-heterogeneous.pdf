<h2 class="text-primary" style="margin-top: 10px; margin-bottom: 10px;">Co-Packaged Optics – 3D Heterogeneous Integration of Photonic IC and Electronic IC</h2>

<div>
    <span class="label ieee_primary_blue_bg"
          style="display: inline-block; font-size: 1.25em; margin-bottom: 5px;">#electronics-packaging</span>
    <span class="label ieee_primary_blue_bg"
          style="display: inline-block; font-size: 1.25em; margin-bottom: 5px;">#photonics</span>
    <span class="label ieee_primary_blue_bg"
          style="display: inline-block; font-size: 1.25em; margin-bottom: 5px;">#circuits</span>
    <span class="label ieee_primary_blue_bg"
          style="display: inline-block; font-size: 1.25em; margin-bottom: 5px;">#seminar</span>
    <span class="label ieee_primary_blue_bg"
          style="display: inline-block; font-size: 1.25em; margin-bottom: 5px;">#technical</span>

  <div style="display: block; float: right; margin-left: 6px;">
  <script src="https://platform.linkedin.com/in.js" type="text/javascript"> lang: en_US</script>
  <script type="IN/Share" data-url="https://events.vtools.ieee.org/m/505983"></script>
</div>
