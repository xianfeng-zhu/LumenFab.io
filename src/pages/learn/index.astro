---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sitePath } from "../../lib/paths";
---

<BaseLayout title="内部索引">
  <section class="hero-panel">
    <p class="page-kicker">Internal index</p>
    <h1>内部索引</h1>
    <p class="lede">
      主页是主要入口。这个页面只保留给本地整理和后续迁移使用：组件页负责“看见结构”，
      底层页面负责“解释原因”。
    </p>
  </section>

  <section>
    <div class="section-heading">
      <p class="page-kicker">Product view</p>
      <h2>CPO / 光引擎模块</h2>
    </div>
    <div class="module-grid">
      <article class="module-card">
        <h3>Laser source / laser chip</h3>
        <ul>
          <li><a href={sitePath("/learn/inp-substrate/")}>InP substrate</a></li>
          <li><a href={sitePath("/learn/optical-gain-and-threshold-current/")}>Optical gain and threshold current</a></li>
          <li><a href={sitePath("/learn/distributed-feedback-and-wavelength-selection/")}>Distributed feedback and wavelength selection</a></li>
          <li><a href={sitePath("/learn/why-semiconductor-lasers-are-temperature-sensitive/")}>Why semiconductor lasers are temperature-sensitive</a></li>
        </ul>
      </article>

      <article class="module-card">
        <h3>PIC</h3>
        <ul>
          <li><a href={sitePath("/learn/silicon-electronics-and-photonic-integration/")}>Silicon: electronics and photonic integration</a></li>
          <li><a href={sitePath("/learn/soi-and-photonics-soi/")}>SOI and Photonics-SOI</a></li>
          <li><a href={sitePath("/learn/silicon-nitride-low-loss-passive-platform/")}>SiN as a low-loss passive platform</a></li>
          <li><a href={sitePath("/learn/lnoi-and-tfln/")}>LNOI and TFLN</a></li>
        </ul>
      </article>

      <article class="module-card">
        <h3>EIC / electrical side</h3>
        <ul>
          <li><a href={sitePath("/learn/electrical-signal-to-optical-signal/")}>Electrical signal to optical signal</a></li>
          <li><a href={sitePath("/learn/tx-rx-path/")}>Tx path and Rx path</a></li>
          <li><a href={sitePath("/learn/inside-a-transceiver/")}>Inside a transceiver</a></li>
        </ul>
      </article>

      <article class="module-card">
        <h3>Packaging</h3>
        <ul>
          <li><a href={sitePath("/learn/why-photonic-packaging-is-hard/")}>Why photonic packaging is hard</a></li>
          <li><a href={sitePath("/learn/soi-wafer/")}>SOI wafer</a></li>
          <li><a href={sitePath("/learn/lnoi-wafer/")}>LNOI wafer</a></li>
        </ul>
      </article>

      <article class="module-card">
        <h3>Test</h3>
        <ul>
          <li><a href={sitePath("/learn/epi-ready-substrates/")}>Epi-ready substrates</a></li>
          <li><a href={sitePath("/learn/wafer-slicing-lapping-polishing-and-cmp/")}>Wafer slicing, lapping, polishing, and CMP</a></li>
          <li><a href={sitePath("/learn/why-photonic-packaging-is-hard/")}>Packaging and test boundary</a></li>
        </ul>
      </article>
    </div>
  </section>

  <section>
    <div class="section-heading">
      <p class="page-kicker">Foundation</p>
      <h2>底层知识域</h2>
    </div>
    <div class="topic-columns">
      <div>
        <h3>材料平台</h3>
        <ul>
          <li><a href={sitePath("/learn/silicon-electronics-and-photonic-integration/")}>Silicon integration</a></li>
          <li><a href={sitePath("/learn/gaas-850-nm-and-vcsel/")}>GaAs and VCSEL</a></li>
          <li><a href={sitePath("/learn/inp-1310-1550-nm-and-high-speed-communication/")}>InP communication platform</a></li>
          <li><a href={sitePath("/learn/why-no-single-material-wins-everything/")}>Why no single material wins everything</a></li>
        </ul>
      </div>

      <div>
        <h3>原料与晶圆</h3>
        <ul>
          <li><a href={sitePath("/learn/in-p-ga-as-si-ge-and-linbo3/")}>In, P, Ga, As, Si, Ge, and LiNbO3</a></li>
          <li><a href={sitePath("/learn/raw-material-ingot-wafer-substrate-and-epi-ready-wafer/")}>Raw material to epi-ready wafer</a></li>
          <li><a href={sitePath("/learn/inp-substrate/")}>InP substrate</a></li>
          <li><a href={sitePath("/learn/gaas-substrate/")}>GaAs substrate</a></li>
          <li><a href={sitePath("/learn/soi-wafer/")}>SOI wafer</a></li>
          <li><a href={sitePath("/learn/lnoi-wafer/")}>LNOI wafer</a></li>
        </ul>
      </div>

      <div>
        <h3>物理基础</h3>
        <ul>
          <li><a href={sitePath("/learn/direct-vs-indirect-bandgap/")}>Direct vs indirect bandgap</a></li>
          <li><a href={sitePath("/learn/pn-junction-and-carrier-injection/")}>PN junction and carrier injection</a></li>
          <li><a href={sitePath("/learn/waveguides-and-optical-modes/")}>Waveguides and optical modes</a></li>
          <li><a href={sitePath("/learn/interference-resonance-and-loss/")}>Interference, resonance, and loss</a></li>
        </ul>
      </div>

      <div>
        <h3>激光器原理</h3>
        <ul>
          <li><a href={sitePath("/learn/spontaneous-vs-stimulated-emission/")}>Spontaneous vs stimulated emission</a></li>
          <li><a href={sitePath("/learn/optical-gain-and-threshold-current/")}>Optical gain and threshold current</a></li>
          <li><a href={sitePath("/learn/fabry-perot-cavity/")}>Fabry-Perot cavity</a></li>
          <li><a href={sitePath("/learn/distributed-feedback-and-wavelength-selection/")}>DFB and wavelength selection</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
