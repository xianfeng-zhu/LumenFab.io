        <rect class="pic-map__device-outline pic-map__device-outline--violet" x="382" y="198" width="230" height="148" rx="8"></rect>
        <path class="pic-map__wg pic-map__wg--violet" d="M 382 236 C 408 236, 414 216, 440 216 H 554 C 580 216, 586 236, 612 236"></path>
        <path class="pic-map__wg pic-map__wg--violet" d="M 382 236 C 408 236, 414 256, 440 256 H 554 C 580 256, 586 236, 612 236"></path>
        <path class="pic-map__wg pic-map__wg--violet" d="M 382 280 C 408 280, 414 260, 440 260 H 554 C 580 260, 586 280, 612 280"></path>
        <path class="pic-map__wg pic-map__wg--violet" d="M 382 280 C 408 280, 414 300, 440 300 H 554 C 580 300, 586 280, 612 280"></path>
