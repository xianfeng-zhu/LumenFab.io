---
interface Props {
  title?: string;
  caption?: string;
}

const {
  title = "硅光光子集成芯片（PIC）俯视器件地图",
  caption = "示意图按芯片裸片的俯视关系组织常见器件。波导长度、版图比例、通道数量和金属层级经过简化，重点呈现光接口、片上光路、有源器件、无源器件、探测器和电热控制结构之间的空间关系。"
} = Astro.props;

const parts = [
  ["lightIn", "#2563eb", "连续光输入"],
  ["coupler", "#f97316", "光输入输出耦合"],
  ["splitter", "#0d9488", "分光与监测抽头"],
  ["modulator", "#7c3aed", "调制器区"],
  ["wavelength", "#db2777", "波长选择区"],
  ["detector", "#16a34a", "锗探测器"],
  ["heater", "#d97706", "热调谐结构"],
  ["metal", "#475569", "金属互连与焊盘"]
];

const partInfo = {
  lightIn: {
    title: "连续光输入",
    body: "连续光通常由外置激光器、磷化铟（InP）光源、异质集成光源或同封装集成激光器微模块（Laser Tile）提供。PIC 在物理边界上接收这束光，并把输入功率、波长、偏振和噪声约束传递给片上光路。"
  },
  splitter: {
    title: "分光与监测抽头",
    body: "多模干涉耦合器（MMI）、方向耦合器和抽头耦合器把输入光分配到多条信道，并抽取少量光功率供监测探测器使用。分光比、插入损耗和通道均匀性会决定后级调制器可用的光功率余量。"
  },
  modulator: {
    title: "调制器区",
    body: "马赫-曾德尔调制器（MZM）利用两臂相位差控制干涉输出，微环调制器（MRM）利用共振波长移动改变透过光强。两类结构在版图面积、驱动电压、带宽、插入损耗和温度敏感性之间形成不同取舍。"
  },
  wavelength: {
    title: "波长选择区",
    body: "阵列波导光栅（AWG）、微环滤波器和阶梯光栅可完成波分复用（WDM）中的合波、分波或通道选择。它们提高单根光纤的带宽密度，同时把波长漂移、滤波损耗和热稳定性纳入系统预算。"
  },
  coupler: {
    title: "光输入输出耦合",
    body: "边缘（端面）耦合器通过芯片侧壁与光纤阵列对接，光栅耦合器从芯片表面完成测试或封装耦合。耦合效率、偏振相关损耗、回波反射和对准容差会直接进入链路预算与封装设计。"
  },
  detector: {
    title: "锗探测器",
    body: "锗光电探测器（Ge PD）吸收近红外光并产生光电流，既可用于接收端，也可作为监测探测器追踪片上光功率。探测器电容、暗电流、响应度和饱和功率会影响跨阻放大器（TIA）与控制环路设计。"
  },
  heater: {
    title: "热调谐结构",
    body: "微加热器利用硅材料的热光效应调节相位或共振波长，用于补偿制造误差和环境温漂。微环、AWG、MZM 偏置点和开关矩阵常需要热调谐，调谐功耗与热串扰会影响芯片工作点稳定性。"
  },
  metal: {
    title: "金属互连与焊盘",
    body: "金属层把高速地-信号-地（GSG）电极、微加热器供电、探测器读出、静电防护结构、焊盘和微凸点连接到电芯片与测试设备。金属布局会影响射频损耗、寄生参数、热分布和测试通路。"
  }
} satisfies Record<string, { title: string; body: string }>;
