          <ellipse cx="292" cy="130" rx="44" ry="18"></ellipse>
          <path d="M 260 130 h 64 M 266 122 h 52 M 266 138 h 52"></path>
        </g>
        <rect class="pic-map__facet" x="908" y="228" width="42" height="64" rx="5"></rect>
        <path class="pic-map__taper" d="M 908 260 L 866 244 L 866 276 Z"></path>
        <path class="pic-map__fiber" d="M 950 260 H 1066"></path>
        <text class="pic-map__label" x="118" y="334" text-anchor="middle">输入端面耦合 / SSC</text>
        <text class="pic-map__sub" x="244" y="104" text-anchor="middle">晶圆级光栅测试口</text>
