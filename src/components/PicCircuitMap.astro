---
interface Props {
  title?: string;
  caption?: string;
}

const {
  title = "PIC 光路功能图",
  caption = "示意图显示一颗光引擎 PIC 内常见的光路功能关系。波导长度、器件尺寸、通道数量和位置均经过示意化处理，表示功能边界而非真实版图。"
} = Astro.props;

const parts = [
  ["lightIn", "#2563eb", "CW 光输入"],
  ["splitter", "#0d9488", "分光 / tap"],
  ["modulator", "#7c3aed", "调制器阵列"],
  ["wavelength", "#db2777", "WDM / MUX"],
  ["coupler", "#f97316", "光 I/O 耦合"],
  ["detector", "#16a34a", "PD / monitor"],
  ["heater", "#eab308", "heater / tuning"],
  ["metal", "#475569", "金属与 pad"]
];

const partInfo = {
  lightIn: {
    title: "CW 光输入",
    body: "PIC 通常接收来自激光源的连续光。光可以来自外置激光器、封装内 laser tile、InP 芯片或异质集成光源；PIC 的主要任务是把这束光组织成可承载数据的多条光路。"
  },
  splitter: {
    title: "分光 / tap",
    body: "splitter 把输入光分到多条 lane，tap 抽取少量光用于监控。分光比、插入损耗和均匀性会直接影响每条 lane 能得到多少光功率。"
  },
  modulator: {
    title: "调制器阵列",
    body: "modulator 把 EIC 送来的高速电信号写到光上。MZM 通过两臂相位差转换成强度变化，MRM 通过谐振位置改变透过光强；不同结构在长度、驱动电压、带宽、热敏感性和插损上取舍不同。"
  },
  wavelength: {
    title: "WDM / MUX",
    body: "WDM 光路把不同波长合到同一根输出光纤，常需要 AWG、环形滤波器、Echelle grating 或其他 wavelength-selective 结构。它提高单纤带宽密度，同时引入波长控制、滤波损耗和热稳定要求。"
  },
  coupler: {
    title: "光 I/O 耦合",
    body: "edge coupler 或 grating coupler 把片上波导模式转换到光纤、FAU 或封装光路。耦合效率、偏振、反射、对准窗口和装配漂移会进入封装与 optical I/O 设计。"
  },
  detector: {
    title: "PD / monitor",
    body: "photodetector 把接收端光信号变成电流，也可作为 monitor photodiode 追踪片上光功率。硅光平台常用 Ge photodetector；InP 平台也能原生集成探测器。"
  },
  heater: {
    title: "heater / tuning",
    body: "heater 和温度传感器用于补偿工艺偏差、温漂和谐振器失配。微环、AWG 和相位敏感光路常依赖热调谐，但调谐功耗会进入 CPO 的热预算。"
  },
  metal: {
    title: "金属与 pad",
    body: "PIC 不只是波导。高速电极、heater 走线、monitor 读出、ESD、pad、microbump 和 metal stack 决定它怎样靠近 EIC、怎样测试，以及怎样进入封装。"
  }
} satisfies Record<string, { title: string; body: string }>;
---

<figure class="pic-map">
  <div class="pic-map__frame" data-pic-map>
    <svg class="pic-map__svg" viewBox="0 0 980 520" role="img" aria-labelledby="pic-map-title">
      <title id="pic-map-title">{title}</title>

      <defs>
        <marker id="pic-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
          <path d="M 0 0 L 10 5 L 0 10 z" fill="#334155"></path>
        </marker>
        <filter id="pic-soft-shadow" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="8" stdDeviation="10" flood-color="#0f4f49" flood-opacity="0.12"></feDropShadow>
        </filter>
      </defs>

      <rect class="pic-map__die" x="78" y="72" width="824" height="348" rx="22"></rect>
      <rect class="pic-map__keepout" x="112" y="104" width="756" height="284" rx="16"></rect>

      <g data-pic-node="lightIn">
        <path class="pic-map__fiber" d="M 14 194 C 48 194, 54 194, 82 194"></path>
        <path class="pic-map__waveguide pic-map__waveguide--blue" d="M 82 194 H 178"></path>
        <rect class="pic-map__block pic-map__block--blue" x="124" y="156" width="84" height="76" rx="10"></rect>
        <text class="pic-map__label" x="166" y="188" text-anchor="middle">CW</text>
        <text class="pic-map__sub" x="166" y="211" text-anchor="middle">light in</text>
      </g>

      <g data-pic-node="splitter">
        <path class="pic-map__waveguide pic-map__waveguide--teal" d="M 208 194 H 292"></path>
        <circle class="pic-map__node pic-map__node--teal" cx="292" cy="194" r="25"></circle>
        <path class="pic-map__waveguide pic-map__waveguide--teal" d="M 292 194 C 330 134, 352 130, 390 130"></path>
        <path class="pic-map__waveguide pic-map__waveguide--teal" d="M 292 194 C 330 174, 352 172, 390 172"></path>
        <path class="pic-map__waveguide pic-map__waveguide--teal" d="M 292 194 C 330 216, 352 218, 390 218"></path>
        <path class="pic-map__waveguide pic-map__waveguide--teal" d="M 292 194 C 330 276, 352 278, 390 278"></path>
        <path class="pic-map__tap" d="M 250 194 C 250 276, 238 318, 202 346"></path>
        <circle class="pic-map__small-node" cx="250" cy="194" r="6"></circle>
        <text class="pic-map__label" x="292" y="199" text-anchor="middle">split</text>
      </g>

      <g data-pic-node="modulator">
        <path class="pic-map__waveguide pic-map__waveguide--violet" d="M 390 130 H 558"></path>
        <path class="pic-map__waveguide pic-map__waveguide--violet" d="M 390 172 H 558"></path>
        <path class="pic-map__waveguide pic-map__waveguide--violet" d="M 390 218 H 558"></path>
        <path class="pic-map__waveguide pic-map__waveguide--violet" d="M 390 278 H 558"></path>
        <rect class="pic-map__lane" x="420" y="106" width="104" height="48" rx="9"></rect>
        <rect class="pic-map__lane" x="420" y="148" width="104" height="48" rx="9"></rect>
        <rect class="pic-map__lane" x="420" y="194" width="104" height="48" rx="9"></rect>
        <rect class="pic-map__lane" x="420" y="254" width="104" height="48" rx="9"></rect>
        <text class="pic-map__label" x="472" y="134" text-anchor="middle">MZM</text>
        <text class="pic-map__label" x="472" y="176" text-anchor="middle">MRM</text>
        <text class="pic-map__label" x="472" y="222" text-anchor="middle">MZM</text>
        <text class="pic-map__label" x="472" y="282" text-anchor="middle">MRM</text>
      </g>

      <g data-pic-node="wavelength">
        <path class="pic-map__waveguide pic-map__waveguide--pink" d="M 558 130 C 600 130, 612 162, 650 190"></path>
        <path class="pic-map__waveguide pic-map__waveguide--pink" d="M 558 172 C 598 172, 612 178, 650 194"></path>
        <path class="pic-map__waveguide pic-map__waveguide--pink" d="M 558 218 C 598 218, 612 210, 650 198"></path>
        <path class="pic-map__waveguide pic-map__waveguide--pink" d="M 558 278 C 600 278, 612 226, 650 202"></path>
        <path class="pic-map__awg" d="M 650 128 C 724 152, 724 240, 650 264 C 616 230, 616 162, 650 128 Z"></path>
        <path class="pic-map__awg-lines" d="M 646 142 C 700 164, 700 228, 646 250 M 662 136 C 718 162, 718 230, 662 258 M 678 138 C 736 168, 736 224, 678 254"></path>
        <text class="pic-map__label" x="668" y="196" text-anchor="middle">MUX</text>
      </g>

      <g data-pic-node="coupler">
        <path class="pic-map__waveguide pic-map__waveguide--orange" d="M 724 196 H 804"></path>
        <rect class="pic-map__block pic-map__block--orange" x="792" y="158" width="84" height="76" rx="10"></rect>
        <path class="pic-map__fiber" d="M 876 196 C 918 196, 938 196, 966 196"></path>
        <text class="pic-map__label" x="834" y="188" text-anchor="middle">edge</text>
        <text class="pic-map__sub" x="834" y="211" text-anchor="middle">coupler</text>
      </g>

      <g data-pic-node="detector">
        <path class="pic-map__waveguide pic-map__waveguide--green" d="M 202 346 C 236 330, 270 330, 304 346"></path>
        <rect class="pic-map__block pic-map__block--green" x="304" y="316" width="100" height="60" rx="10"></rect>
        <path class="pic-map__rx" d="M 598 338 H 706"></path>
        <rect class="pic-map__block pic-map__block--green" x="706" y="308" width="110" height="60" rx="10"></rect>
        <text class="pic-map__label" x="354" y="352" text-anchor="middle">monitor PD</text>
        <text class="pic-map__label" x="761" y="344" text-anchor="middle">Rx PD</text>
      </g>

      <g data-pic-node="heater">
        <path class="pic-map__heater" d="M 408 88 h 130 M 412 88 c 12 -16, 28 -16, 40 0 c 12 16, 28 16, 40 0 c 12 -16, 28 -16, 40 0"></path>
        <path class="pic-map__heater" d="M 606 284 h 130 M 610 284 c 12 -16, 28 -16, 40 0 c 12 16, 28 16, 40 0 c 12 -16, 28 -16, 40 0"></path>
        <text class="pic-map__sub pic-map__sub--dark" x="474" y="77" text-anchor="middle">thermal tuning</text>
        <text class="pic-map__sub pic-map__sub--dark" x="672" y="302" text-anchor="middle">wavelength trim</text>
      </g>

      <g data-pic-node="metal">
        <path class="pic-map__metal" d="M 472 106 V 40 H 578"></path>
        <path class="pic-map__metal" d="M 472 148 V 40"></path>
        <path class="pic-map__metal" d="M 472 194 V 420 H 586"></path>
        <path class="pic-map__metal" d="M 472 254 V 420"></path>
        <path class="pic-map__metal" d="M 354 316 V 420 H 586"></path>
        <path class="pic-map__metal" d="M 761 308 V 420"></path>
        <rect class="pic-map__pad" x="578" y="24" width="96" height="32" rx="6"></rect>
        <rect class="pic-map__pad" x="586" y="404" width="184" height="32" rx="6"></rect>
        <text class="pic-map__sub pic-map__sub--dark" x="626" y="45" text-anchor="middle">EIC driver pads</text>
        <text class="pic-map__sub pic-map__sub--dark" x="678" y="425" text-anchor="middle">TIA / monitor / heater pads</text>
      </g>

      <path class="pic-map__direction" d="M 116 462 H 864" marker-end="url(#pic-arrow)"></path>
      <text class="pic-map__sub pic-map__sub--dark" x="490" y="488" text-anchor="middle">Tx 光路主线：连续光进入 PIC 后被分配、调制、合波并耦合出芯片</text>
    </svg>
  </div>

  <div class="pic-map__index" aria-label="PIC 功能索引">
    {parts.map(([key, color, label]) => (
      <button type="button" data-pic-part={key} style={`--part-color: ${color}`}>{label}</button>
    ))}
  </div>

  <div class="pic-map__info" data-pic-info aria-live="polite">
    <strong data-pic-title>结构说明</strong>
    <span data-pic-body>PIC 把片上光路、调制器、耦合器、探测器和电热控制组织成可制造、可测试的光学电路。</span>
  </div>

  <figcaption>
    <strong>{title}</strong>
    <span>{caption}</span>
  </figcaption>
</figure>

<script define:vars={{ partInfo }}>
  const maps = document.querySelectorAll("[data-pic-map]");

  for (const map of maps) {
    const figure = map.closest(".pic-map");
    const buttons = figure?.querySelectorAll("[data-pic-part]") || [];
    const nodes = map.querySelectorAll("[data-pic-node]");
    const title = figure?.querySelector("[data-pic-title]");
    const body = figure?.querySelector("[data-pic-body]");
    let active = "";

    const clear = () => {
      active = "";
      title.textContent = "结构说明";
      title.style.removeProperty("--part-title-color");
      body.textContent = "PIC 把片上光路、调制器、耦合器、探测器和电热控制组织成可制造、可测试的光学电路。";
      for (const node of nodes) {
        node.removeAttribute("data-active");
        node.removeAttribute("data-muted");
      }
      for (const button of buttons) {
        button.setAttribute("aria-pressed", "false");
      }
    };

    const select = (key) => {
      if (!key || !partInfo[key]) return;
      if (active === key) {
        clear();
        return;
      }
      active = key;
      title.textContent = partInfo[key].title;
      title.style.setProperty("--part-title-color", getComputedStyle(figure).getPropertyValue(`--pic-${key}`));
      body.textContent = partInfo[key].body;

      for (const node of nodes) {
        const match = node.getAttribute("data-pic-node") === key;
        node.toggleAttribute("data-active", match);
        node.toggleAttribute("data-muted", !match);
      }

      for (const button of buttons) {
        button.setAttribute("aria-pressed", String(button.getAttribute("data-pic-part") === key));
      }
    };

    for (const button of buttons) {
      button.addEventListener("click", () => select(button.getAttribute("data-pic-part")));
    }

    for (const node of nodes) {
      node.addEventListener("click", () => select(node.getAttribute("data-pic-node")));
      node.setAttribute("tabindex", "0");
      node.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          select(node.getAttribute("data-pic-node"));
        }
      });
    }
  }
</script>

<style>
  .pic-map {
    --pic-lightIn: #2563eb;
    --pic-splitter: #0d9488;
    --pic-modulator: #7c3aed;
    --pic-wavelength: #db2777;
    --pic-coupler: #f97316;
    --pic-detector: #16a34a;
    --pic-heater: #eab308;
    --pic-metal: #475569;
    margin: 2rem 0 2.5rem;
  }

  .pic-map__frame {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 8px;
    background:
      linear-gradient(135deg, rgb(255 255 255 / 92%), rgb(238 245 241 / 82%)),
      radial-gradient(circle at 12% 18%, rgb(37 99 235 / 12%), transparent 28%),
      radial-gradient(circle at 82% 24%, rgb(249 115 22 / 10%), transparent 24%);
  }

  .pic-map__svg {
    display: block;
    width: 100%;
    min-height: 300px;
  }

  .pic-map__die {
    fill: #ffffff;
    filter: url("#pic-soft-shadow");
    stroke: #cbd5e1;
    stroke-width: 2;
  }

  .pic-map__keepout {
    fill: #f8fafc;
    stroke: #e2e8f0;
    stroke-dasharray: 8 7;
  }

  .pic-map__fiber,
  .pic-map__direction {
    fill: none;
    stroke: #334155;
    stroke-linecap: round;
    stroke-width: 8;
  }

  .pic-map__direction {
    stroke-width: 2;
  }

  .pic-map__waveguide,
  .pic-map__tap,
  .pic-map__rx {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 8;
  }

  .pic-map__waveguide--blue {
    stroke: var(--pic-lightIn);
  }

  .pic-map__waveguide--teal,
  .pic-map__tap {
    stroke: var(--pic-splitter);
  }

  .pic-map__waveguide--violet {
    stroke: var(--pic-modulator);
  }

  .pic-map__waveguide--pink {
    stroke: var(--pic-wavelength);
  }

  .pic-map__waveguide--orange {
    stroke: var(--pic-coupler);
  }

  .pic-map__waveguide--green,
  .pic-map__rx {
    stroke: var(--pic-detector);
  }

  .pic-map__block,
  .pic-map__node,
  .pic-map__lane,
  .pic-map__awg,
  .pic-map__pad {
    stroke-width: 2;
  }

  .pic-map__block--blue {
    fill: #dbeafe;
    stroke: var(--pic-lightIn);
  }

  .pic-map__block--orange {
    fill: #ffedd5;
    stroke: var(--pic-coupler);
  }

  .pic-map__block--green {
    fill: #dcfce7;
    stroke: var(--pic-detector);
  }

  .pic-map__node--teal {
    fill: #ccfbf1;
    stroke: var(--pic-splitter);
  }

  .pic-map__small-node {
    fill: #ffffff;
    stroke: var(--pic-splitter);
    stroke-width: 3;
  }

  .pic-map__lane {
    fill: #ede9fe;
    stroke: var(--pic-modulator);
  }

  .pic-map__awg {
    fill: #fce7f3;
    stroke: var(--pic-wavelength);
  }

  .pic-map__awg-lines {
    fill: none;
    stroke: var(--pic-wavelength);
    stroke-linecap: round;
    stroke-width: 3;
  }

  .pic-map__heater {
    fill: none;
    stroke: var(--pic-heater);
    stroke-linecap: round;
    stroke-width: 5;
  }

  .pic-map__metal {
    fill: none;
    stroke: var(--pic-metal);
    stroke-linecap: round;
    stroke-width: 3;
  }

  .pic-map__pad {
    fill: #e2e8f0;
    stroke: var(--pic-metal);
  }

  .pic-map__label,
  .pic-map__sub {
    fill: #172033;
    font-family: Inter, ui-sans-serif, system-ui, "Noto Sans SC", sans-serif;
    letter-spacing: 0;
    pointer-events: none;
  }

  .pic-map__label {
    font-size: 18px;
    font-weight: 750;
  }

  .pic-map__sub {
    fill: #475569;
    font-size: 14px;
    font-weight: 650;
  }

  .pic-map__sub--dark {
    fill: #334155;
  }

  [data-pic-node] {
    cursor: pointer;
    outline: none;
    transition: opacity 140ms ease;
  }

  [data-pic-node][data-muted] {
    opacity: 0.18;
  }

  [data-pic-node][data-active] {
    opacity: 1;
  }

  [data-pic-node][data-active] .pic-map__block,
  [data-pic-node][data-active] .pic-map__node,
  [data-pic-node][data-active] .pic-map__lane,
  [data-pic-node][data-active] .pic-map__awg,
  [data-pic-node][data-active] .pic-map__pad {
    stroke-width: 4;
  }

  .pic-map__index {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.85rem;
  }

  .pic-map__index button {
    min-height: 2.25rem;
    padding: 0.42rem 0.72rem;
    border: 1px solid color-mix(in srgb, var(--part-color), var(--border) 45%);
    border-radius: 8px;
    background: color-mix(in srgb, var(--part-color), #ffffff 88%);
    color: #16201b;
    cursor: pointer;
    font: inherit;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .pic-map__index button[aria-pressed="true"] {
    background: var(--part-color);
    color: #ffffff;
  }

  .pic-map__index button:focus-visible {
    outline: 3px solid rgb(29 122 107 / 25%);
    outline-offset: 3px;
  }

  .pic-map__info {
    display: grid;
    gap: 0.25rem;
    margin-top: 0.9rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border);
    border-left: 4px solid var(--part-title-color, var(--accent));
    border-radius: 8px;
    background: var(--surface);
  }

  .pic-map__info strong {
    color: var(--part-title-color, var(--text));
  }

  .pic-map__info span {
    color: var(--muted);
  }

  .pic-map figcaption {
    display: grid;
    gap: 0.2rem;
  }

  @media (max-width: 720px) {
    .pic-map__frame {
      overflow-x: auto;
    }

    .pic-map__svg {
      width: 860px;
      max-width: none;
    }

    .pic-map__index button {
      flex: 1 1 9.5rem;
    }
  }
</style>
