      </g>

      <g data-pic-node="metal">
        <g class="pic-map__pad-row">
          <rect x="396" y="88" width="34" height="24" rx="4"></rect>
          <rect x="444" y="88" width="34" height="24" rx="4"></rect>
          <rect x="492" y="88" width="34" height="24" rx="4"></rect>
          <rect x="540" y="88" width="34" height="24" rx="4"></rect>
        </g>
        <path class="pic-map__metal" d="M 414 198 V 112 M 462 198 V 112 M 510 198 V 112 M 558 198 V 112"></path>
        <path class="pic-map__metal" d="M 302 418 V 430"></path>
        <text class="pic-map__label" x="510" y="68" text-anchor="middle">射频 GSG 与控制焊盘</text>
        <text class="pic-map__sub pic-map__sub--dark" x="620" y="458" text-anchor="middle">短距离读出与控制线</text>
      </g>

      <g class="pic-map__legend">
        <line x1="116" y1="582" x2="166" y2="582"></line>
        <text x="178" y="587">主光路</text>
        <rect x="346" y="566" width="42" height="28" rx="5"></rect>
        <text x="398" y="587">功能器件区</text>
        <path d="M 550 580 h 72"></path>
        <text x="636" y="587">金属互连</text>
      </g>
    </svg>
  </div>

  <div class="pic-map__index" aria-label="PIC 功能索引">
    {parts.map(([key, color, label]) => (
      <button type="button" data-pic-part={key} style={`--part-color: ${color}`}>{label}</button>
    ))}
  </div>

  <div class="pic-map__info" data-pic-info aria-live="polite">
    <strong data-pic-title>结构说明</strong>
    <span data-pic-body>光子集成芯片（PIC）把片上光路、调制器、耦合器、探测器和金属互连组织成可制造、可测试的光学电路。</span>
  </div>

  <figcaption>
    <strong>{title}</strong>
    <span>{caption}</span>
  </figcaption>
</figure>

<script define:vars={{ partInfo }}>
  const maps = document.querySelectorAll("[data-pic-map]");

  for (const map of maps) {
    const figure = map.closest(".pic-map");
    const buttons = figure?.querySelectorAll("[data-pic-part]") || [];
    const nodes = map.querySelectorAll("[data-pic-node]");
    const title = figure?.querySelector("[data-pic-title]");
    const body = figure?.querySelector("[data-pic-body]");
    let active = "";
    let manualSelection = false;

    const clear = () => {
      active = "";
      title.textContent = "结构说明";
      title.style.removeProperty("--part-title-color");
      body.textContent = "光子集成芯片（PIC）把片上光路、调制器、耦合器、探测器和金属互连组织成可制造、可测试的光学电路。";
      for (const node of nodes) {
        node.removeAttribute("data-active");
        node.removeAttribute("data-muted");
      }
      for (const button of buttons) {
        button.setAttribute("aria-pressed", "false");
      }
    };

    const select = (key, options = {}) => {
      if (!key || !partInfo[key]) return;
      const { toggle = true, manual = false } = options;
      if (manual) {
        manualSelection = true;
      }
      if (active === key && toggle) {
        clear();
        return;
      }
      active = key;
      title.textContent = partInfo[key].title;
      title.style.setProperty("--part-title-color", getComputedStyle(figure).getPropertyValue(`--pic-${key}`));
      body.textContent = partInfo[key].body;

      for (const node of nodes) {
        const match = node.getAttribute("data-pic-node") === key;
        node.toggleAttribute("data-active", match);
        node.toggleAttribute("data-muted", !match);
      }

      for (const button of buttons) {
        button.setAttribute("aria-pressed", String(button.getAttribute("data-pic-part") === key));
      }
    };

    for (const button of buttons) {
      button.addEventListener("click", () => select(button.getAttribute("data-pic-part"), { manual: true }));
    }

    for (const node of nodes) {
      node.addEventListener("click", () => select(node.getAttribute("data-pic-node"), { manual: true }));
      node.setAttribute("tabindex", "0");
      node.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          select(node.getAttribute("data-pic-node"), { manual: true });
        }
      });
    }

    const sectionRules = [
      [/什么是硅光|总结：一束光/, "lightIn"],
      [/一颗硅光 PIC|波导与模式/, "splitter"],
      [/材料栈|设计与制造/, "metal"],
      [/光输入输出|封装与系统/, "coupler"],
      [/被动光路器件/, "wavelength"],
      [/主动光器件/, "modulator"],
      [/从光到电|测试指标/, "detector"],
      [/应用场景/, "lightIn"]
    ];

    const sectionKey = (heading) => {
      const text = heading.textContent || "";
      for (const [pattern, key] of sectionRules) {
        if (pattern.test(text)) return key;
      }
      return "";
    };

    const setupSectionObserver = () => {
      const headings = Array.from(document.querySelectorAll(".concept-page h2")).filter(sectionKey);
      if (headings.length === 0) return;

      let raf = 0;
      const updateFromScroll = () => {
        raf = 0;
        if (manualSelection) return;

        const readingLine = window.innerHeight * 0.32;
        const mapBox = map.getBoundingClientRect();
        if (mapBox.bottom > readingLine) {
          clear();
          return;
        }

        let current = headings[0];
        for (const heading of headings) {
          if (heading.getBoundingClientRect().top <= readingLine) {
            current = heading;
          }
        }

        const key = sectionKey(current);
        if (key) {
          select(key, { toggle: false });
        }
      };

      const requestUpdate = () => {
        if (!raf) {
          raf = window.requestAnimationFrame(updateFromScroll);
        }
      };

      window.addEventListener(
        "scroll",
        () => {
          if (manualSelection) {
            window.clearTimeout(map._picManualTimer);
            map._picManualTimer = window.setTimeout(() => {
              manualSelection = false;
            }, 900);
          }
          requestUpdate();
        },
        { passive: true }
      );
      window.addEventListener("resize", requestUpdate, { passive: true });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupSectionObserver, { once: true });
    } else {
      window.requestAnimationFrame(setupSectionObserver);
    }
  }
</script>

<style>
  .pic-map {
    --pic-lightIn: #2563eb;
    --pic-splitter: #0d9488;
    --pic-modulator: #7c3aed;
    --pic-wavelength: #db2777;
    --pic-coupler: #f97316;
    --pic-detector: #16a34a;
    --pic-metal: #475569;
    margin: 2rem 0 2.5rem;
  }

  .pic-map__frame {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 8px;
    background:
      linear-gradient(135deg, rgb(255 255 255 / 92%), rgb(238 245 241 / 82%)),
      radial-gradient(circle at 12% 18%, rgb(37 99 235 / 12%), transparent 28%),
      radial-gradient(circle at 82% 24%, rgb(249 115 22 / 10%), transparent 24%);
  }

  .pic-map__svg {
    display: block;
    width: 100%;
    min-height: 360px;
  }

  .pic-map__die {
    fill: #ffffff;
    filter: url("#pic-soft-shadow");
    stroke: #cbd5e1;
    stroke-width: 2;
  }

  .pic-map__grid {
    fill: url("#pic-grid");
    opacity: 0.65;
  }

  .pic-map__keepout {
    fill: rgb(248 250 252 / 78%);
    stroke: #e2e8f0;
    stroke-dasharray: 8 7;
  }

  .pic-map__fiber {
    fill: none;
    stroke: #334155;
    stroke-linecap: round;
    stroke-width: 5;
  }

  .pic-map__fiber-array {
    fill: #f1f5f9;
    stroke: #64748b;
    stroke-width: 1.5;
  }

  .pic-map__wg {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 5;
  }

  .pic-map__wg--thin {
    stroke-width: 3.2;
  }

  .pic-map__wg--blue {
    stroke: var(--pic-lightIn);
  }

  .pic-map__wg--teal {
    stroke: var(--pic-splitter);
  }

  .pic-map__wg--violet {
    stroke: var(--pic-modulator);
  }

  .pic-map__wg--pink {
    stroke: var(--pic-wavelength);
  }

  .pic-map__wg--green {
    stroke: var(--pic-detector);
  }

  .pic-map__facet,
  .pic-map__mmi,
  .pic-map__device-outline,
  .pic-map__pd,
  .pic-map__awg-body,
  .pic-map__ring {
    stroke-width: 2;
  }

  .pic-map__facet {
    fill: #ffedd5;
    stroke: var(--pic-coupler);
  }

  .pic-map__taper {
    fill: #ffedd5;
    stroke: var(--pic-coupler);
    stroke-width: 1.5;
  }

  .pic-map__gratings ellipse {
    fill: #fff7ed;
    stroke: var(--pic-coupler);
    stroke-width: 2;
  }

  .pic-map__gratings path {
    fill: none;
    stroke: var(--pic-coupler);
    stroke-linecap: round;
    stroke-width: 2;
  }

  .pic-map__test-link {
    stroke-dasharray: 6 6;
    opacity: 0.65;
  }

  .pic-map__mmi {
    fill: #ccfbf1;
    stroke: var(--pic-splitter);
  }

  .pic-map__tap-dot {
    fill: #ffffff;
    stroke: var(--pic-splitter);
    stroke-width: 2.5;
  }

  .pic-map__device-outline--violet {
    fill: rgb(237 233 254 / 72%);
    stroke: var(--pic-modulator);
  }

  .pic-map__ring {
    fill: none;
  }

  .pic-map__ring--violet {
    stroke: var(--pic-modulator);
  }

  .pic-map__ring--pink {
    stroke: var(--pic-wavelength);
  }

  .pic-map__awg-body {
    fill: #fce7f3;
    stroke: var(--pic-wavelength);
  }

  .pic-map__awg-lines {
    fill: none;
    stroke: var(--pic-wavelength);
    stroke-linecap: round;
    stroke-width: 2.4;
  }

  .pic-map__pd {
    fill: #dcfce7;
    stroke: var(--pic-detector);
  }

  .pic-map__metal {
    fill: none;
    stroke: var(--pic-metal);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.6;
  }

  .pic-map__metal--wide {
    stroke-width: 6;
  }

  .pic-map__wg--optional,
  .pic-map__optional-device {
    opacity: 0.62;
  }

  .pic-map__pad-row rect {
    fill: url("#pic-die-metal");
    stroke: var(--pic-metal);
    stroke-width: 1.5;
  }

  .pic-map__label,
  .pic-map__sub,
  .pic-map__corner {
    fill: #172033;
    font-family: Inter, ui-sans-serif, system-ui, "Noto Sans SC", sans-serif;
    letter-spacing: 0;
    pointer-events: none;
  }

  .pic-map__label {
    font-size: 18px;
    font-weight: 750;
  }

  .pic-map__sub {
    fill: #475569;
    font-size: 14px;
    font-weight: 650;
  }

  .pic-map__sub--dark {
    fill: #334155;
  }

  .pic-map__corner {
    fill: #64748b;
    font-size: 13px;
    font-weight: 650;
  }

  .pic-map__legend line,
  .pic-map__legend path {
    fill: none;
    stroke: #0d9488;
    stroke-linecap: round;
    stroke-width: 5;
  }

  .pic-map__legend path {
    stroke: var(--pic-metal);
    stroke-width: 3;
  }

  .pic-map__legend rect {
    fill: #ede9fe;
    stroke: var(--pic-modulator);
    stroke-width: 2;
  }

  .pic-map__legend text {
    fill: #334155;
    font-family: Inter, ui-sans-serif, system-ui, "Noto Sans SC", sans-serif;
    font-size: 15px;
    font-weight: 700;
  }

  [data-pic-node] {
    cursor: pointer;
    outline: none;
