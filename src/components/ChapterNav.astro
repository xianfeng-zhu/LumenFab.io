---
import { chapters } from "../data/chapters";
import { sitePath } from "../lib/paths";
---

<nav class="chapter-nav" aria-label="学习路径">
  {chapters.map((chapter) => (
    <a class="chapter-link" href={sitePath(chapter.path)}>
      <span>{chapter.title}</span>
      <small>{chapter.purpose}</small>
    </a>
  ))}
</nav>

<style>
  .chapter-nav {
    display: grid;
    gap: 0.75rem;
  }

  .chapter-link {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    color: inherit;
    text-decoration: none;
  }

  .chapter-link:hover {
    border-color: var(--accent);
  }

  .chapter-link span {
    font-weight: 700;
  }

  .chapter-link small {
    color: var(--muted);
    line-height: 1.6;
  }
</style>
