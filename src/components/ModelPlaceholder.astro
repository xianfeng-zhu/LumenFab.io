---
interface Props {
  title?: string;
  caption?: string;
}

const { title = "3D 模型占位", caption = "模型资产尚未生成。此处预留交互式结构展示。" } =
  Astro.props;
---

<div class="model-placeholder" role="img" aria-label={title}>
  <div class="model-placeholder__grid"></div>
  <div class="model-placeholder__body">
    <strong>{title}</strong>
    <p>{caption}</p>
  </div>
</div>

<style>
  .model-placeholder {
    position: relative;
    min-height: 320px;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: #101820;
  }

  .model-placeholder__grid {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    transform: perspective(600px) rotateX(58deg) translateY(44px) scale(1.4);
    transform-origin: center bottom;
  }

  .model-placeholder__body {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    left: 1rem;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 8px;
    background: rgba(10, 16, 20, 0.82);
    color: #f7fbff;
  }

  .model-placeholder__body p {
    margin: 0.35rem 0 0;
    color: #cbd6df;
  }
</style>
