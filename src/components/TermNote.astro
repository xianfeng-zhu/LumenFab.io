---
interface Props {
  label: string;
  note: string;
}

const { label, note } = Astro.props;
---

<span class="term-note">
  <button class="term-note__trigger" type="button" aria-label={`${label}: ${note}`}>
    <span class="term-note__label">{label}</span>
  </button>
  <span class="term-note__tip" role="tooltip">{note}</span>
</span>

<style>
  .term-note {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }

  .term-note__trigger {
    display: inline;
    padding: 0;
    border: 0;
    border-bottom: 1px dotted currentColor;
    background: transparent;
    color: inherit;
    cursor: help;
    font: inherit;
    text-align: inherit;
    text-decoration: none;
    white-space: nowrap;
  }

  .term-note__trigger:focus-visible {
    border-radius: 3px;
    outline: 2px solid currentColor;
    outline-offset: 0.16em;
  }

  .term-note__tip {
    position: absolute;
    bottom: calc(100% + 0.45rem);
    left: 0;
    z-index: 20;
    display: none;
    width: max-content;
    max-width: min(24rem, 78vw);
    padding: 0.55rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    box-shadow: 0 12px 34px rgb(15 79 73 / 14%);
    color: var(--text);
    font-size: 0.88rem;
    line-height: 1.55;
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.2rem);
    transition:
      opacity 140ms ease,
      transform 140ms ease;
    visibility: hidden;
    white-space: normal;
  }

  .term-note:hover .term-note__tip,
  .term-note:focus-within .term-note__tip {
    display: block;
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
  }

  @media (max-width: 720px) {
    .term-note__tip {
      position: fixed;
      top: 1rem;
      right: 1rem;
      bottom: auto;
      left: 1rem;
      width: auto;
      max-width: none;
    }
  }
</style>
