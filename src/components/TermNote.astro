---
interface Props {
  label: string;
  note: string;
}

const { label, note } = Astro.props;
---

<span class="term-note">
  <button class="term-note__trigger" type="button" aria-label={`${label}: ${note}`}>
    <span class="term-note__label">{label}</span>
  </button>
  <span class="term-note__tip" role="tooltip">{note}</span>
</span>

<script>
  const edgeGap = 12;
  const verticalGap = 8;
  const notes = document.querySelectorAll(".term-note");

  function positionTermNote(note) {
    const tip = note.querySelector(".term-note__tip");
    if (!(tip instanceof HTMLElement) || !(note instanceof HTMLElement)) {
      return;
    }

    requestAnimationFrame(() => {
      const noteRect = note.getBoundingClientRect();
      const tipRect = tip.getBoundingClientRect();
      const viewportWidth = document.documentElement.clientWidth;
      const viewportHeight = window.innerHeight;

      const maxLeft = Math.max(edgeGap, viewportWidth - edgeGap - tipRect.width);
      const left = Math.min(
        Math.max(noteRect.left + noteRect.width / 2 - tipRect.width / 2, edgeGap),
        maxLeft,
      );
      let top = noteRect.top - tipRect.height - verticalGap;

      if (top < edgeGap && noteRect.bottom + tipRect.height + verticalGap < viewportHeight - edgeGap) {
        note.setAttribute("data-term-note-placement", "below");
        top = noteRect.bottom + verticalGap;
      } else {
        note.removeAttribute("data-term-note-placement");
        const maxTop = Math.max(edgeGap, viewportHeight - edgeGap - tipRect.height);
        top = Math.min(Math.max(top, edgeGap), maxTop);
      }

      note.style.setProperty("--term-note-fixed-left", `${Math.round(left)}px`);
      note.style.setProperty("--term-note-fixed-top", `${Math.round(top)}px`);
    });
  }

  for (const note of notes) {
    note.addEventListener("pointerenter", () => positionTermNote(note));
    note.addEventListener("focusin", () => positionTermNote(note));
    note.addEventListener("click", () => positionTermNote(note));
  }

  window.addEventListener("resize", () => {
    for (const note of notes) {
      if (note.matches(":hover, :focus-within")) {
        positionTermNote(note);
      }
    }
  });
</script>

<style>
  .term-note {
    display: inline-block;
    --term-note-fixed-left: 12px;
    --term-note-fixed-top: 12px;
  }

  .term-note__trigger {
    display: inline;
    padding: 0;
    border: 0;
    border-bottom: 1px dotted currentColor;
    background: transparent;
    color: inherit;
    cursor: help;
    font: inherit;
    text-align: inherit;
    text-decoration: none;
  }

  .term-note__trigger:focus-visible {
    border-radius: 3px;
    outline: 2px solid currentColor;
    outline-offset: 0.16em;
  }

  .term-note__tip {
    position: fixed;
    top: var(--term-note-fixed-top);
    left: var(--term-note-fixed-left);
    z-index: 20;
    display: none;
    width: max-content;
    max-width: min(24rem, calc(100vw - 2rem));
    padding: 0.55rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    box-shadow: 0 12px 34px rgb(15 79 73 / 14%);
    color: var(--text);
    font-size: 0.88rem;
    line-height: 1.55;
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.2rem);
    transition:
      opacity 140ms ease,
      transform 140ms ease;
    visibility: hidden;
    white-space: normal;
  }

  .term-note:hover .term-note__tip,
  .term-note:focus-within .term-note__tip {
    display: block;
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
  }

  @media (max-width: 720px) {
    .term-note__tip {
      width: min(20rem, calc(100vw - 2rem));
      max-width: calc(100vw - 2rem);
    }
  }
</style>
