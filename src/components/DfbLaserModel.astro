---
interface Props {
  title?: string;
  caption?: string;
}

const {
  title = "InP DFB 激光器结构模型",
  caption = "可旋转模型显示边发射 ridge DFB 激光器的主要芯片级结构。为便于观察，垂直层厚、MQW、DFB 光栅、端面镀膜和电流窗口均经过示意化放大，属于 not to scale 教学模型。"
} = Astro.props;

const legendItems = [
  ["substrate", "#2563eb", "InP 衬底"],
  ["nCladding", "#16a34a", "n-InP 包层"],
  ["sch", "#eab308", "SCH"],
  ["mqw", "#db2777", "MQW 有源区 (MQW active region)"],
  ["pCladding", "#7c3aed", "p-InP 包层"],
  ["contactCap", "#ef4444", "p+ 接触层"],
  ["grating", "#0d9488", "DFB 光栅 (DFB grating)"],
  ["ridge", "#0891b2", "ridge 横向约束"],
  ["dielectric", "#64748b", "绝缘 / 钝化"],
  ["pMetal", "#f97316", "p-contact"],
  ["nContact", "#475569", "n-contact"],
  ["facet", "#334155", "端面 / 镀膜"],
  ["photonPool", "#f472b6", "有源区光子 / 波长选择"],
  ["braggSelection", "#38bdf8", "Bragg 波长选择"]
];

const indexItems = [
  ["nContact", "#475569", "背面 n-contact"],
  ["substrate", "#2563eb", "InP 衬底"],
  ["nCladding", "#16a34a", "n-InP 包层"],
  ["sch", "#eab308", "SCH 限制层"],
  ["mqw", "#db2777", "MQW 有源区"],
  ["mode", "#0891b2", "腔内光场分布"],
  ["photonPool", "#f472b6", "有源区光子 / 波长选择"],
  ["braggSelection", "#38bdf8", "Bragg 波长选择"],
  ["output", "#60a5fa", "边发射输出光"],
  ["grating", "#0d9488", "DFB 光栅"],
  ["phase", "#1e293b", "相移区"],
  ["pCladding", "#7c3aed", "p-InP 包层"],
  ["ridge", "#0891b2", "Ridge 侧向波导结构"],
  ["contactCap", "#ef4444", "p+ 接触层"],
  ["dielectric", "#64748b", "绝缘钝化"],
  ["currentWindow", "#22c55e", "电流窗口"],
  ["pMetal", "#f97316", "顶部 p-contact"],
  ["facet", "#334155", "解理端面"],
  ["coating", "#a855f7", "AR / HR coating"],
  ["current", "#22c55e", "电流路径"]
];
---

<figure class="dfb-model">
  <div class="dfb-model__viewport" data-dfb-laser-model>
    <canvas aria-label={title}></canvas>
    <div class="dfb-model__controls">
      <div class="dfb-model__controls-row">
        <button type="button" class="dfb-model__control-btn" data-dfb-explode-toggle aria-pressed="false">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 5.5L7 1.5L11 5.5"/>
            <path d="M3 8.5L7 12.5L11 8.5"/>
          </svg>
          <span>分层展开</span>
        </button>
      </div>
    </div>
    <div class="dfb-model__legend" aria-hidden="true">
      {legendItems.map(([key, color, label]) => (
        <span data-key={key}><i style={`--swatch: ${color}`}></i>{label}</span>
      ))}
    </div>
  </div>
  <div class="dfb-model__index" aria-label="3D 模型结构索引">
    {indexItems.map(([key, color, label]) => (
      <button type="button" data-dfb-part-index={key} style={`--part-color: ${color}`}>{label}</button>
    ))}
  </div>
  <div class="dfb-model__info" data-dfb-part-info aria-live="polite">
    <strong data-dfb-part-title>结构说明</strong>
    <span data-dfb-part-body>选择模型中的结构，或点击下方结构索引，这里会显示它在激光器中的作用。</span>
  </div>
  <figcaption>
    <strong>{title}</strong>
    <span>{caption}</span>
  </figcaption>
</figure>

<script>
  import * as THREE from "three";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";

  const roots = document.querySelectorAll("[data-dfb-laser-model]");

  const partInfo = {
    substrate: {
      color: "#2563eb",
      title: "InP 衬底",
      body: "InP 衬底提供晶格模板、机械支撑和下侧导电路径。通信波段 InGaAsP / InAlGaAs 有源区需要在接近 InP 晶格常数的模板上外延生长，衬底缺陷、翘曲和表面质量会继续影响外延、解理和长期可靠性。"
    },
    nCladding: {
      color: "#16a34a",
      title: "n-InP 包层 / 缓冲层",
      body: "n-InP 层位于衬底和有源区之间，既是外延过渡层，也承担下侧电流注入路径。它的折射率低于波导核心区域，帮助把光场限制在有源区附近。"
    },
    sch: {
      color: "#eab308",
      title: "SCH 光限制层",
      body: "SCH 是 separate confinement heterostructure。它夹住 MQW 有源区，使光学模式与增益区有足够重叠，同时缓和包层和量子阱之间的折射率与能带变化。"
    },
    mqw: {
      color: "#db2777",
      title: "MQW 有源区",
      body: "MQW 由多层量子阱和 barrier 组成，是电子空穴复合并提供光增益的核心区域。模型把纳米级量子阱放大成可见条纹，用来显示多阱堆叠和光学模式重叠关系。"
    },
    pCladding: {
      color: "#7c3aed",
      title: "p-InP 包层",
      body: "p-InP 包层位于有源区上方，提供上侧光场限制和 p 侧电流路径。真实 ridge 器件会刻蚀 p-side 外延层，保留中间脊形区域来形成横向波导。"
    },
    contactCap: {
      color: "#ef4444",
      title: "p+ 接触层",
      body: "p+ contact cap 是高掺杂接触层，用来降低金属和半导体之间的接触电阻。它属于接触层，和负责光场限制的包层分工不同；接触电阻会影响电压损耗、发热和效率。"
    },
    ridge: {
      color: "#0891b2",
      title: "Ridge 侧向波导结构",
      body: "ridge 是刻蚀后保留下来的 p-side 脊形结构，位于有源区上方。它不是光从外部进入的通道；激光模式主要位于 MQW / SCH 附近，并沿芯片长度方向传播。ridge 通过横向等效折射率差和电流窗口，把光学模式和注入电流限制在脊下方的有源区附近。"
    },
    dielectric: {
      color: "#64748b",
      title: "绝缘 / 钝化层",
      body: "SiN、SiO2 等介质层覆盖 ridge 两侧和刻蚀侧壁，降低漏电和表面复合。它还定义金属只能通过开窗区域把电流注入脊顶部。"
    },
    currentWindow: {
      color: "#22c55e",
      title: "电流窗口",
      body: "电流窗口是绝缘层中的开口，决定电流从哪里进入 p+ 接触层。窗口宽度和 ridge 中心对准会影响电流扩散、局部热点、阈值和可靠性。"
    },
    pMetal: {
      color: "#f97316",
      title: "顶部 p-contact / 金属电极",
      body: "顶部金属与 p+ 接触层形成低阻 p-contact，把驱动电流送入 ridge 区域。金属宽度、厚度和接触质量会影响串联电阻和热分布。"
    },
    nContact: {
      color: "#475569",
      title: "backside n-contact / cathode",
      body: "背面 n-contact 是电流回路的下侧电极。典型 p-up InP 边发射激光器中，电流从顶部 p-contact 垂直穿过外延层和有源区，最终到达背面 n-contact。"
    },
    grating: {
      color: "#0d9488",
      title: "DFB 光栅",
      body: "DFB 光栅沿腔长方向周期性扰动有效折射率。接近 Bragg 条件的光场会把前向传播波和后向传播波强耦合起来，许多微弱反射沿腔长相干相加，形成分布式反馈。模型为了可视化把光栅外露；实际光栅可能位于有源区上方、下方、埋入再生长层或侧向耦合区域。"
    },
    phase: {
      color: "#1e293b",
      title: "四分之一波相移区",
      body: "相移区是在 DFB 光栅中引入受控相位变化的区域，常用于让目标纵模获得最低阈值优势。它是常见设计选项，具体位置和实现方式会随器件路线变化。"
    },
    facet: {
      color: "#334155",
      title: "解理端面",
      body: "边发射激光器沿晶体解理面形成端面。端面质量、解理位置和反射边界会影响输出功率、残余 Fabry-Perot 效应、SMSR 和长期可靠性。"
    },
    coating: {
      color: "#a855f7",
      title: "AR / HR coating",
      body: "端面镀膜调节端面反射率。AR coating 降低残余反射和外部反馈敏感性；HR coating 提高一侧反射，让更多光从另一端输出。模型用薄膜示意这种端面工程。"
    },
    mode: {
      color: "#0891b2",
      title: "腔内光场分布",
      body: "腔内光场分布表示激光在芯片内部的空间强度分布。这个示意体沿腔长方向延伸，垂直方向被压得很薄，用来表达光主要位于 MQW / SCH 附近。它表示光场，不对应独立材料层；SCH / 包层提供垂直限制，ridge 提供横向限制。"
    },
    current: {
      color: "#22c55e",
      title: "电流注入路径",
      body: "电流从顶部 p-contact 进入，通过电流窗口、p-InP 包层和 MQW 有源区，到达 n-InP 层和背面 n-contact。电流路径与光学模式越匹配，无效复合和局部发热越少。"
    },
    photonPool: {
      color: "#f472b6",
      title: "有源区光子与波长选择",
      body: "有源区内不同颜色的小球表示不同波长的自发辐射光子。DFB 光栅不会像筛网一样逐个拦截光子，而是通过周期性折射率扰动选择能形成前向 / 后向耦合模式的 Bragg 波长；非目标波长因反馈不足和增益竞争逐渐衰减，目标波长形成稳定输出。"
    },
    braggSelection: {
      color: "#38bdf8",
      title: "Bragg 波长选择",
      body: "多色波纹表示不同波长在有源区内尝试形成纵向光场。接近 Bragg 条件的波纹会逐渐相干增强，并与前向 / 后向反馈耦合；偏离 Bragg 条件的波纹相位关系不能沿光栅周期稳定累加，因此在增益竞争中变淡。"
    },
    output: {
      color: "#60a5fa",
      title: "边发射输出光",
      body: "激光沿芯片长度方向传播并从解理端面射出。后续封装会围绕发散角、偏振、端面反馈、准直和耦合效率设计光路。"
    }
  };

  const partOrder = Object.keys(partInfo);
  const partColor = (key) => Number.parseInt(partInfo[key].color.slice(1), 16);

  const material = (color, options = {}) =>
    new THREE.MeshStandardMaterial({
      color,
      roughness: 0.68,
      metalness: 0,
      ...options
    });

  const transparent = (color, opacity) =>
    material(color, {
      transparent: true,
      opacity,
      depthWrite: false
    });

  function createBox({ size, position, color, opacity = 1, metalness = 0, roughness = 0.68 }) {
    const mat = material(color, {
      transparent: opacity < 1,
      opacity,
      metalness,
      roughness
    });
    const mesh = new THREE.Mesh(new THREE.BoxGeometry(...size), mat);
    mesh.position.set(...position);
    return mesh;
  }

  function createCylinder({ radiusTop, radiusBottom, height, position, color, opacity = 1 }) {
    const mesh = new THREE.Mesh(
      new THREE.CylinderGeometry(radiusTop, radiusBottom, height, 32, 1, true),
      transparent(color, opacity)
    );
    mesh.position.set(...position);
    return mesh;
  }

  function createArrow(start, end, color, headLength = 0.18, headWidth = 0.09) {
    const from = new THREE.Vector3(...start);
    const to = new THREE.Vector3(...end);
    const direction = to.clone().sub(from);
    const length = direction.length();
    return new THREE.ArrowHelper(direction.normalize(), from, length, color, headLength, headWidth);
  }

  function createHitBox({ size, position, key, priority = 2 }) {
    const mesh = new THREE.Mesh(
      new THREE.BoxGeometry(...size),
      new THREE.MeshBasicMaterial({
        transparent: true,
        opacity: 0,
        depthWrite: false
      })
    );
    mesh.position.set(...position);
    return tagPart(mesh, key, true, priority);
  }

  function tagPart(object, key, isHitProxy = false, priority = 0) {
    object.userData.partKey = key;
    object.userData.hitProxy = isHitProxy;
    object.userData.selectionPriority = priority;
    object.traverse((child) => {
      child.userData.partKey = key;
      child.userData.hitProxy = isHitProxy;
      child.userData.selectionPriority = priority;
    });
    return object;
  }

  const smoothstep = (edge0, edge1, value) => {
    const t = THREE.MathUtils.clamp((value - edge0) / (edge1 - edge0), 0, 1);
    return t * t * (3 - 2 * t);
  };

  const createSegmentedPathCurve = (points) => {
    const curve = new THREE.CurvePath();
    for (let i = 1; i < points.length; i += 1) {
      curve.add(new THREE.LineCurve3(points[i - 1], points[i]));
    }
    return curve;
  };

  const createGlowSpheres = ({ count, radius, color, opacity = 0.72 }) =>
    Array.from({ length: count }, (_, i) => ({
      mesh: new THREE.Mesh(
        new THREE.SphereGeometry(radius, 14, 8),
        new THREE.MeshBasicMaterial({
          color,
          transparent: true,
          opacity,
          depthTest: false,
          depthWrite: false
        })
      ),
      offset: i / count
    }));

  const braggWaveSegments = 72;
  const braggWaveLength = 5.25;
  const braggRibbonWidth = 0.035;

  const createBraggWaveLine = ({ color, baseY, baseZ, phaseOffset, waveNumber, isTargetBragg }) => {
    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute("position", new THREE.BufferAttribute(new Float32Array((braggWaveSegments + 1) * 2 * 3), 3));
    const indices = [];
    for (let i = 0; i < braggWaveSegments; i += 1) {
      const a = i * 2;
      const b = a + 1;
      const c = a + 2;
      const d = a + 3;
      indices.push(a, c, b, b, c, d);
    }
    geometry.setIndex(indices);
    const line = new THREE.Mesh(
      geometry,
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: isTargetBragg ? 0.72 : 0.36,
        depthTest: false,
        depthWrite: false,
        side: THREE.DoubleSide
      })
    );
    line.userData.baseY = baseY;
    line.userData.baseZ = baseZ;
    line.userData.phaseOffset = phaseOffset;
    line.userData.waveNumber = waveNumber;
    line.userData.isTargetBragg = isTargetBragg;
    line.renderOrder = 4;
    return line;
  };

  const updateBraggWaveLine = (line, time) => {
    const position = line.geometry.getAttribute("position");
    const cycle = (time * 0.13 + line.userData.phaseOffset) % 1;
    const suppression = line.userData.isTargetBragg ? 0 : smoothstep(0.42, 0.92, cycle);
    const coherence = line.userData.isTargetBragg
      ? 0.62 + 0.38 * (0.5 + 0.5 * Math.sin(time * 1.4))
      : 1 - suppression;

    for (let i = 0; i <= braggWaveSegments; i += 1) {
      const u = i / braggWaveSegments;
      const x = (u - 0.5) * braggWaveLength;
      const longitudinalEnvelope = Math.sin(u * Math.PI);
      const phase = x * line.userData.waveNumber + time * (line.userData.isTargetBragg ? 1.15 : 2.05) + line.userData.phaseOffset * Math.PI * 2;
      const wave = Math.sin(phase) * longitudinalEnvelope * coherence;
      const y = line.userData.baseY + 0.14 + wave * 0.018;
      const z = line.userData.baseZ + wave * (line.userData.isTargetBragg ? 0.13 : 0.09);
      position.setXYZ(i * 2, x, y - braggRibbonWidth, z);
      position.setXYZ(i * 2 + 1, x, y + braggRibbonWidth, z);
    }

    position.needsUpdate = true;
    line.geometry.computeBoundingSphere();
    line.material.opacity = line.userData.isTargetBragg
      ? 0.42 + 0.34 * coherence
      : 0.05 + 0.28 * coherence;
  };

  function buildModel(scene) {
    const chip = new THREE.Group();
    scene.add(chip);

    const layerGroups = [];
    const layerGroupMap = new Map();
    function addLayer(key) {
      const group = new THREE.Group();
      group.userData.layerKey = key;
      group.userData.layerIndex = layerGroups.length;
      layerGroups.push(group);
      layerGroupMap.set(key, group);
      chip.add(group);
      return group;
    }

    addLayer("nContact");
    addLayer("substrate");
    addLayer("nCladding");
    addLayer("activeRegion");
    addLayer("grating");
    addLayer("pCladding");
    addLayer("ridge");
    addLayer("topContact");
    const annotationGroup = new THREE.Group();
    annotationGroup.userData.layerKey = "annotations";
    chip.add(annotationGroup);

    const layerKeyByPart = {
      nContact: "nContact",
      substrate: "substrate",
      nCladding: "nCladding",
      sch: "activeRegion",
      mqw: "activeRegion",
      mode: "activeRegion",
      photonPool: "activeRegion",
      braggSelection: "activeRegion",
      output: "activeRegion",
      grating: "grating",
      phase: "grating",
      pCladding: "pCladding",
      ridge: "ridge",
      contactCap: "ridge",
      dielectric: "topContact",
      currentWindow: "topContact",
      pMetal: "topContact"
    };

    const findObjectPartKey = (object) => {
      if (object.userData.partKey) return object.userData.partKey;
      let partKey = "";
      object.traverse((child) => {
        if (!partKey && child.userData.partKey) partKey = child.userData.partKey;
      });
      return partKey;
    };

    const assignChildrenToLayers = () => {
      const directChildren = [...chip.children].filter((child) => (
        child !== annotationGroup && !layerGroups.includes(child)
      ));
      for (const child of directChildren) {
        const partKey = findObjectPartKey(child);
        const targetLayer = layerGroupMap.get(layerKeyByPart[partKey]);
        (targetLayer || annotationGroup).add(child);
      }
    };

    const length = 6.25;
    const fullWidth = 2.04;
    const cutawayWidth = 1.36;
    const ridgeWidth = 0.58;
    const cutawayOffset = 0.18;
    let y = 0;

    const layers = [
      { name: "InP substrate", key: "substrate", h: 0.44, color: 0x2563eb, width: fullWidth },
      { name: "n-InP buffer / cladding", key: "nCladding", h: 0.22, color: 0x16a34a, width: fullWidth },
      { name: "lower SCH", key: "sch", h: 0.105, color: 0xeab308, width: cutawayWidth },
      { name: "upper SCH", key: "sch", h: 0.105, color: 0xeab308, width: cutawayWidth },
      { name: "p-InP cladding", key: "pCladding", h: 0.3, color: 0x7c3aed, width: cutawayWidth },
      { name: "p+ contact cap", key: "contactCap", h: 0.1, color: 0xef4444, width: ridgeWidth }
    ];

    const layerCenters = {};

    for (const layer of layers.slice(0, 3)) {
      const centerY = y + layer.h / 2;
      const mesh = createBox({
        size: [length, layer.h, layer.width],
        position: [0, centerY, layer.width === fullWidth ? 0 : cutawayOffset],
        color: layer.color,
        opacity: layer.key === "sch" ? 0.9 : 1
      });
      chip.add(tagPart(mesh, layer.key));
      layerCenters[layer.name] = centerY;
      y += layer.h;
    }

    const mqwCenter = y + 0.055;
    const quantumWellCount = 5;
    const barrierCount = quantumWellCount + 1;
    const barrierH = 0.012;
    const wellH = 0.01;
    for (let i = 0; i < barrierCount + quantumWellCount; i += 1) {
      const isWell = i % 2 === 1;
      const h = isWell ? wellH : barrierH;
      const centerY = y + h / 2;
      const mesh = createBox({
        size: [length, h, 0.92],
        position: [0, centerY, cutawayOffset],
        color: isWell ? 0xdb2777 : 0xf9a8d4,
        opacity: isWell ? 1 : 0.75
      });
      chip.add(tagPart(mesh, "mqw", false, isWell ? 2 : 1));
      y += h;
    }
    layerCenters["MQW active region"] = mqwCenter;

    for (const layer of layers.slice(3, 5)) {
      const centerY = y + layer.h / 2;
      const mesh = createBox({
        size: [length, layer.h, layer.width],
        position: [0, centerY, cutawayOffset],
        color: layer.color,
        opacity: layer.key === "pCladding" ? 0.86 : 0.9
      });
      chip.add(tagPart(mesh, layer.key));
      layerCenters[layer.name] = centerY;
      y += layer.h;
    }

    const ridgeBaseY = y;
    const ridge = createBox({
      size: [5.35, 0.24, ridgeWidth],
      position: [0, ridgeBaseY + 0.12, cutawayOffset],
      color: 0x0891b2,
      opacity: 0.9
    });
    chip.add(tagPart(ridge, "ridge"));

    const contactCap = createBox({
      size: [5.2, 0.1, 0.42],
      position: [0, ridgeBaseY + 0.29, cutawayOffset],
      color: 0xef4444,
      opacity: 0.96
    });
    chip.add(tagPart(contactCap, "contactCap"));

    const topY = ridgeBaseY + 0.34;

    const dielectricLeft = createBox({
      size: [5.55, 0.09, 0.42],
      position: [0, topY + 0.045, cutawayOffset - 0.54],
      color: 0x94a3b8,
      opacity: 0.86
    });
    const dielectricRight = dielectricLeft.clone();
    dielectricRight.position.z = cutawayOffset + 0.54;
    chip.add(tagPart(dielectricLeft, "dielectric"), tagPart(dielectricRight, "dielectric"));

    const currentWindow = createBox({
      size: [5.1, 0.06, 0.31],
      position: [0, topY + 0.08, cutawayOffset],
      color: 0x22c55e,
      opacity: 0.72
    });
    chip.add(tagPart(currentWindow, "currentWindow", false, 3));

    const pMetal = createBox({
      size: [4.55, 0.13, 0.36],
      position: [0, topY + 0.18, cutawayOffset],
      color: 0xf97316,
      metalness: 0.45,
      roughness: 0.32
    });
    chip.add(tagPart(pMetal, "pMetal"));

    const nContact = createBox({
      size: [5.9, 0.08, fullWidth + 0.05],
      position: [0, -0.08, 0],
      color: 0x475569,
      metalness: 0.4,
      roughness: 0.34
    });
    chip.add(tagPart(nContact, "nContact"));

    const gratingGroup = new THREE.Group();
    const gratingY = layerCenters["upper SCH"] + 0.065;
    const period = 0.22;
    for (let x = -2.65; x <= 2.65; x += period) {
      if (Math.abs(x) < 0.14) continue;
      const tooth = createBox({
        size: [0.042, 0.048, 0.42],
        position: [x, gratingY, cutawayOffset],
        color: 0x0d9488
      });
      gratingGroup.add(tagPart(tooth, "grating", false, 3));
    }
    chip.add(tagPart(gratingGroup, "grating"));

    const phaseShift = createBox({
      size: [0.12, 0.07, 0.48],
      position: [0, gratingY + 0.012, cutawayOffset],
      color: 0x1e293b,
      opacity: 0.86
    });
    chip.add(tagPart(phaseShift, "phase", false, 4));

    const facetFront = createBox({
      size: [0.045, topY + 0.35, fullWidth + 0.08],
      position: [length / 2 + 0.025, (topY + 0.25) / 2, 0],
      color: 0x334155,
      opacity: 0.56
    });
    const facetBack = facetFront.clone();
    facetBack.position.x = -length / 2 - 0.025;
    chip.add(tagPart(facetFront, "facet"), tagPart(facetBack, "facet"));

    const arCoating = createBox({
      size: [0.035, topY + 0.2, 0.86],
      position: [length / 2 + 0.07, (topY + 0.2) / 2, cutawayOffset],
      color: 0xa855f7,
      opacity: 0.74
    });
    const hrCoating = createBox({
      size: [0.035, topY + 0.2, 0.86],
      position: [-length / 2 - 0.07, (topY + 0.2) / 2, cutawayOffset],
      color: 0x7e22ce,
      opacity: 0.8
    });
    chip.add(tagPart(arCoating, "coating", false, 3), tagPart(hrCoating, "coating", false, 3));

    const modeGeometry = new THREE.SphereGeometry(1, 48, 24);
    const mode = new THREE.Mesh(modeGeometry, transparent(0x0891b2, 0.76));
    mode.scale.set(2.65, 0.07, 0.28);
    mode.position.set(0, layerCenters["MQW active region"], cutawayOffset);
    chip.add(tagPart(mode, "mode"));

    const cutawayPlane = createBox({
      size: [length + 0.1, topY + 0.18, 0.018],
      position: [0, (topY + 0.05) / 2, cutawayOffset - 0.7],
      color: 0x0f766e,
      opacity: 0.12
    });
    cutawayPlane.name = "cutaway plane";
    chip.add(cutawayPlane);

    chip.add(tagPart(createArrow([-2.2, topY + 0.58, cutawayOffset], [-2.2, topY + 0.22, cutawayOffset], 0x22c55e), "current"));
    chip.add(tagPart(createArrow([0, topY + 0.58, cutawayOffset], [0, topY + 0.22, cutawayOffset], 0x22c55e), "current"));
    chip.add(tagPart(createArrow([2.2, topY + 0.58, cutawayOffset], [2.2, topY + 0.22, cutawayOffset], 0x22c55e), "current"));
    chip.add(tagPart(createArrow([0, layerCenters["MQW active region"] + 0.18, cutawayOffset], [0, -0.08, cutawayOffset], 0x22c55e, 0.14, 0.07), "current"));
    chip.add(tagPart(createArrow([length / 2 + 0.05, layerCenters["MQW active region"], cutawayOffset], [length / 2 + 1.35, layerCenters["MQW active region"], cutawayOffset], 0x60a5fa), "output"));

    const beam = createCylinder({
      radiusTop: 0.05,
      radiusBottom: 0.25,
      height: 2.45,
      position: [length / 2 + 1.4, layerCenters["MQW active region"], cutawayOffset],
      color: 0x67e8f9,
      opacity: 0.5
    });
    beam.rotation.z = Math.PI / 2;
    chip.add(tagPart(beam, "output"));

    const currentPathGroup = new THREE.Group();
    const currentPathCurves = [];
    const currentGlowSpheres = [];
    for (const x of [-2.2, 0, 2.2]) {
      const currentPoints = [
        new THREE.Vector3(x, topY + 0.34, cutawayOffset),
        new THREE.Vector3(x, topY + 0.08, cutawayOffset),
        new THREE.Vector3(x, layerCenters["MQW active region"], cutawayOffset),
        new THREE.Vector3(x, -0.08, cutawayOffset)
      ];
      const curve = createSegmentedPathCurve(currentPoints);
      currentPathCurves.push(curve);
      const geometry = new THREE.TubeGeometry(curve, 24, 0.018, 8, false);
      currentPathGroup.add(tagPart(new THREE.Mesh(geometry, transparent(0x22c55e, 0.42)), "current"));
      const glowSpheres = createGlowSpheres({ count: 5, radius: 0.032, color: 0x22c55e });
      for (const item of glowSpheres) {
        currentPathGroup.add(tagPart(item.mesh, "current", false, 3));
      }
      currentGlowSpheres.push(glowSpheres);
    }
    chip.add(tagPart(currentPathGroup, "current"));

    const gratingFeedbackGroup = new THREE.Group();
    const gratingFeedbackCurve = createSegmentedPathCurve([
      new THREE.Vector3(-length / 2 + 0.42, layerCenters["MQW active region"] + 0.12, cutawayOffset - 0.18),
      new THREE.Vector3(length / 2 - 0.42, layerCenters["MQW active region"] + 0.12, cutawayOffset - 0.18)
    ]);
    const gratingFeedbackPulses = [
      { offset: 0.02, direction: 1, zPhase: 0 },
      { offset: 0.28, direction: 1, zPhase: 1.8 },
      { offset: 0.54, direction: 1, zPhase: 3.6 },
      { offset: 0.14, direction: -1, zPhase: 0.9 },
      { offset: 0.4, direction: -1, zPhase: 2.7 },
      { offset: 0.66, direction: -1, zPhase: 4.5 }
    ].map((spec) => {
      const pulse = new THREE.Mesh(
        new THREE.SphereGeometry(0.035, 14, 8),
        new THREE.MeshBasicMaterial({
          color: spec.direction > 0 ? 0x38bdf8 : 0xa5f3fc,
          transparent: true,
          opacity: 0.42,
          depthTest: false,
          depthWrite: false
        })
      );
      pulse.userData.offset = spec.offset;
      pulse.userData.direction = spec.direction;
      pulse.userData.baseZ = cutawayOffset - 0.18;
      pulse.userData.zPhase = spec.zPhase;
      gratingFeedbackGroup.add(tagPart(pulse, "grating", false, 3));
      return pulse;
    });
    chip.add(tagPart(gratingFeedbackGroup, "grating", false, 3));

    const braggSelectionGroup = new THREE.Group();
    const braggSelectionLines = [
      { color: 0x38bdf8, baseY: layerCenters["MQW active region"], baseZ: cutawayOffset - 0.52, phaseOffset: 0.05, waveNumber: 8.2, isTargetBragg: true },
      { color: 0x93c5fd, baseY: layerCenters["MQW active region"], baseZ: cutawayOffset - 0.38, phaseOffset: 0.42, waveNumber: 8.2, isTargetBragg: true },
      { color: 0xf472b6, baseY: layerCenters["MQW active region"], baseZ: cutawayOffset - 0.2, phaseOffset: 0.18, waveNumber: 6.6, isTargetBragg: false },
      { color: 0xf59e0b, baseY: layerCenters["MQW active region"], baseZ: cutawayOffset - 0.08, phaseOffset: 0.5, waveNumber: 10.1, isTargetBragg: false },
      { color: 0xa78bfa, baseY: layerCenters["MQW active region"], baseZ: cutawayOffset + 0.06, phaseOffset: 0.76, waveNumber: 7.4, isTargetBragg: false }
    ].map((spec) => {
      const line = createBraggWaveLine(spec);
      updateBraggWaveLine(line, 0);
      braggSelectionGroup.add(tagPart(line, "braggSelection", false, 3));
      return line;
    });
    chip.add(tagPart(braggSelectionGroup, "braggSelection", false, 3));

    const photonGroup = new THREE.Group();
    const activePhotons = [];
    const photonSpecs = [
      { color: 0x60a5fa, z: cutawayOffset - 0.46, offset: 0.04, speed: 0.18, amplitude: 2.35, isTarget: true },
      { color: 0x67e8f9, z: cutawayOffset - 0.3, offset: 0.36, speed: 0.2, amplitude: 2.15, isTarget: true },
      { color: 0xf472b6, z: cutawayOffset - 0.38, offset: 0.12, speed: 0.16, amplitude: 2.1, isTarget: false },
      { color: 0xf59e0b, z: cutawayOffset - 0.22, offset: 0.38, speed: 0.14, amplitude: 2.1, isTarget: false },
      { color: 0xa78bfa, z: cutawayOffset - 0.12, offset: 0.62, speed: 0.13, amplitude: 2.0, isTarget: false },
      { color: 0xfb7185, z: cutawayOffset - 0.54, offset: 0.78, speed: 0.15, amplitude: 2.0, isTarget: false }
    ];
    for (const spec of photonSpecs) {
      const photon = new THREE.Mesh(
        new THREE.SphereGeometry(spec.isTarget ? 0.072 : 0.06, 16, 10),
        new THREE.MeshBasicMaterial({
          color: spec.color,
          transparent: true,
          opacity: spec.isTarget ? 0.86 : 0.72,
          depthTest: false,
          depthWrite: false
        })
      );
      photon.userData.baseY = layerCenters["MQW active region"] + 0.055;
      photon.userData.baseZ = spec.z;
      photon.userData.offset = spec.offset;
      photon.userData.speed = spec.speed;
      photon.userData.amplitude = spec.amplitude;
      photon.userData.isTargetPhoton = spec.isTarget;
      activePhotons.push(photon);
      photonGroup.add(tagPart(photon, "photonPool", false, 3));
    }
    chip.add(tagPart(photonGroup, "photonPool", false, 3));

    const outputPhotonGroup = new THREE.Group();
    const outputPhotonCurve = createSegmentedPathCurve([
      new THREE.Vector3(length / 2 - 0.18, layerCenters["MQW active region"], cutawayOffset),
      new THREE.Vector3(length / 2 + 0.14, layerCenters["MQW active region"], cutawayOffset),
      new THREE.Vector3(length / 2 + 1.35, layerCenters["MQW active region"], cutawayOffset)
    ]);
    const outputPhotonGeometry = new THREE.TubeGeometry(outputPhotonCurve, 32, 0.018, 8, false);
    outputPhotonGroup.add(tagPart(new THREE.Mesh(outputPhotonGeometry, transparent(0x60a5fa, 0.5)), "output"));
    const outputPhotonSpheres = createGlowSpheres({ count: 5, radius: 0.04, color: 0x60a5fa, opacity: 0.8 });
    for (const item of outputPhotonSpheres) {
      outputPhotonGroup.add(tagPart(item.mesh, "output", false, 3));
    }
    chip.add(tagPart(outputPhotonGroup, "output"));

    const largeHitTargets = [
      { key: "mqw", size: [5.6, 0.24, 0.42], position: [0, layerCenters["MQW active region"], cutawayOffset], priority: 4 },
      { key: "sch", size: [5.7, 0.42, 0.5], position: [0, layerCenters["MQW active region"], cutawayOffset + 0.42], priority: 3 },
      { key: "grating", size: [5.45, 0.42, 0.38], position: [0, gratingY, cutawayOffset - 0.45], priority: 4 },
      { key: "phase", size: [0.5, 0.44, 0.5], position: [0, gratingY, cutawayOffset - 0.45], priority: 5 },
      { key: "currentWindow", size: [5.25, 0.24, 0.45], position: [0, topY + 0.08, cutawayOffset - 0.45], priority: 4 },
      { key: "coating", size: [0.22, topY + 0.28, 0.9], position: [length / 2 + 0.1, (topY + 0.2) / 2, cutawayOffset], priority: 4 },
      { key: "photonPool", size: [5.15, 0.36, 0.92], position: [0, layerCenters["MQW active region"], cutawayOffset], priority: 4 },
      { key: "braggSelection", size: [5.35, 0.42, 1.0], position: [0, layerCenters["MQW active region"] + 0.14, cutawayOffset - 0.24], priority: 4 },
      { key: "output", size: [1.5, 0.4, 0.5], position: [length / 2 + 0.72, layerCenters["MQW active region"], cutawayOffset], priority: 4 },
      { key: "nContact", size: [5.95, 0.24, fullWidth + 0.12], position: [0, -0.08, 0], priority: 3 }
    ];
    for (const target of largeHitTargets) {
      chip.add(createHitBox(target));
    }

    assignChildrenToLayers();

    const outline = new THREE.Box3().setFromObject(chip);
    const center = outline.getCenter(new THREE.Vector3());
    for (const child of chip.children) {
      child.position.sub(center);
    }
    for (const group of layerGroups) {
      group.userData.baseY = group.position.y;
    }
    chip.rotation.x = -0.18;
    chip.rotation.y = -0.58;
    const viewBox = new THREE.Box3().setFromObject(chip);
    const viewSphere = viewBox.getBoundingSphere(new THREE.Sphere());
    chip.userData.modelViewRadius = viewSphere.radius;
    chip.userData.layerGroups = layerGroups;
    chip.userData.animations = {
      currentPathCurves,
      currentGlowSpheres,
      gratingFeedbackCurve,
      gratingFeedbackPulses,
      braggSelectionLines,
      activePhotons,
      outputPhotonCurve,
      outputPhotonSpheres
    };
    return chip;
  }

  for (const root of roots) {
    const canvas = root.querySelector("canvas");
    const figure = root.closest(".dfb-model");
    const infoTitle = figure?.querySelector("[data-dfb-part-title]");
    const infoBody = figure?.querySelector("[data-dfb-part-body]");
    const indexButtons = figure?.querySelectorAll("[data-dfb-part-index]") || [];
    const explodeBtn = figure?.querySelector("[data-dfb-explode-toggle]");
    const scene = new THREE.Scene();
    scene.background = null;

    const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 100);
    camera.position.set(4.8, 3.4, 5.4);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
      preserveDrawingBuffer: true,
      powerPreference: "high-performance"
    });
    renderer.setClearColor(0x000000, 0);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.enableRotate = true;
    controls.dampingFactor = 0.08;
    controls.rotateSpeed = 0.75;
    controls.minDistance = 0.35;
    controls.maxDistance = 80;
    controls.minPolarAngle = 0.01;
    controls.maxPolarAngle = Math.PI - 0.01;
    controls.enableZoom = true;
    controls.touches.ONE = THREE.TOUCH.ROTATE;
    controls.touches.TWO = THREE.TOUCH.DOLLY_PAN;
    controls.target.set(0, 0, 0);

    const _right = new THREE.Vector3();
    const _up = new THREE.Vector3();
    const _fwd = new THREE.Vector3();
    const wheelHandler = (e) => {
      if (e.target !== canvas) return;
      e.preventDefault();
      e.stopPropagation();
      if (e.ctrlKey) {
        const factor = e.deltaY > 0 ? 1.025 : 0.975;
        camera.position.sub(controls.target).multiplyScalar(factor).add(controls.target);
      } else {
        const s = 0.006;
        const dx = e.deltaX * s;
        const dy = -e.deltaY * s;
        camera.getWorldDirection(_fwd);
        _right.crossVectors(_fwd, camera.up).normalize();
        _up.crossVectors(_right, _fwd).normalize();
        controls.target.addScaledVector(_right, dx).addScaledVector(_up, dy);
        camera.position.addScaledVector(_right, dx).addScaledVector(_up, dy);
      }
    };
    window.addEventListener("wheel", wheelHandler, { capture: true, passive: false });

    scene.add(new THREE.HemisphereLight(0xffffff, 0xdbeafe, 2.45));
    const key = new THREE.DirectionalLight(0xffffff, 2.25);
    key.position.set(3, 5, 4);
    scene.add(key);
    const fill = new THREE.DirectionalLight(0xbfdbfe, 1.1);
    fill.position.set(-4, 2, -3);
    scene.add(fill);

    const model = buildModel(scene);
    const layerGroups = model.userData.layerGroups;
    const {
      currentPathCurves,
      currentGlowSpheres,
      gratingFeedbackCurve,
      gratingFeedbackPulses,
      braggSelectionLines,
      activePhotons,
      outputPhotonCurve,
      outputPhotonSpheres
    } = model.userData.animations;
    const modelViewRadius = model.userData.modelViewRadius;
    const defaultCameraDirection = new THREE.Vector3(4.8, 3.4, 5.4).normalize();
    const minCameraDistance = 7.4;
    const modelViewPadding = 0.68;
    const getCameraDistanceForAspect = (aspect) => {
      const fitAspect = Math.max(Math.min(aspect, 1), 0.1);
      const fitDistance = modelViewRadius / (Math.tan(THREE.MathUtils.degToRad(camera.fov) / 2) * fitAspect) * modelViewPadding;
      return Math.max(minCameraDistance, fitDistance);
    };
    const setDefaultCameraFrame = () => {
      controls.target.set(0, 0, 0);
      camera.position.copy(defaultCameraDirection).multiplyScalar(getCameraDistanceForAspect(camera.aspect)).add(controls.target);
      camera.lookAt(controls.target);
      controls.update();
    };
    setDefaultCameraFrame();
    const raycaster = new THREE.Raycaster();
    const pointer = new THREE.Vector2();
    let selectedPart = "";
    let pointerDownState = null;
    const dragSelectionThreshold = 5;
    const referenceOpacity = 0.08;
    let isExploded = false;
    const explodeGap = 0.38;
    const explodeSpeed = 0.09;

    const setSelectedPart = (partKey) => {
      if (!partKey || !partInfo[partKey] || !infoTitle || !infoBody) return;
      if (selectedPart === partKey) {
        clearSelectedPart();
        return;
      }
      selectedPart = partKey;
      infoTitle.textContent = partInfo[partKey].title;
      infoTitle.style.setProperty("--part-title-color", partInfo[partKey].color);
      infoBody.textContent = partInfo[partKey].body;

      for (const button of indexButtons) {
        const buttonPart = button.getAttribute("data-dfb-part-index");
        button.style.setProperty("--part-color", partInfo[buttonPart]?.color || "var(--border)");
        button.setAttribute("aria-pressed", String(buttonPart === partKey));
      }

      dimNonSelectedParts(partKey);
    };

    const storeBaseMaterial = (object) => {
      if (!object.material) return;
      const material = object.material;
      if (object.userData.baseMaterialStored) return;
      object.userData.baseMaterialStored = true;
      object.userData.baseOpacity = material.opacity ?? 1;
      object.userData.baseTransparent = !!material.transparent;
      object.userData.baseDepthWrite = material.depthWrite;
      object.userData.baseColor = material.color?.getHex();
      object.userData.baseEmissive = material.emissive?.getHex();
    };

    const requestMaterialUpdate = (material) => {
      material.needsUpdate = true;
    };

    const dimNonSelectedParts = (partKey) => {
      model.traverse((object) => {
        if (!object.material || !object.userData.partKey) return;
        storeBaseMaterial(object);
        if (object.userData.hitProxy) {
          object.material.opacity = 0;
          object.material.transparent = true;
          requestMaterialUpdate(object.material);
          return;
        }

        const isSelectedObject = object.userData.partKey === partKey;
        const targetOpacity = isSelectedObject
          ? Math.min(1, Math.max(object.userData.baseOpacity ?? 1, 0.82))
          : Math.min(object.userData.baseOpacity ?? 1, referenceOpacity);

        if (isSelectedObject) {
          if (object.material.color) {
            object.material.color.set(partColor(partKey));
            object.material.color.multiplyScalar(0.72);
          }
          object.material.opacity = targetOpacity;
          object.material.transparent = object.userData.baseTransparent || object.material.opacity < 1;
          if (typeof object.userData.baseDepthWrite === "boolean") {
            object.material.depthWrite = object.userData.baseDepthWrite;
          }
          if (object.material.emissive) {
            object.material.emissive.setHex(partColor(partKey));
            object.material.emissiveIntensity = 0.08;
          }
          requestMaterialUpdate(object.material);
        } else {
          if (object.material.color && object.userData.baseColor !== undefined) {
            object.material.color.setHex(object.userData.baseColor);
          }
          object.material.opacity = targetOpacity;
          object.material.transparent = true;
          object.material.depthWrite = false;
          if (object.material.emissive) {
            object.material.emissive.setHex(object.userData.baseEmissive ?? 0x000000);
            object.material.emissiveIntensity = 0;
          }
          requestMaterialUpdate(object.material);
        }
      });
    };

    const clearSelectedPart = () => {
      selectedPart = "";
      infoTitle.textContent = "结构说明";
      infoTitle.style.removeProperty("--part-title-color");
      infoBody.textContent = "选择模型中的结构，或点击下方结构索引，这里会显示它在激光器中的作用。";

      for (const button of indexButtons) {
        const buttonPart = button.getAttribute("data-dfb-part-index");
        button.style.setProperty("--part-color", partInfo[buttonPart]?.color || "var(--border)");
        button.setAttribute("aria-pressed", "false");
      }

      model.traverse((object) => {
        if (!object.material || !object.userData.partKey) return;
        storeBaseMaterial(object);
        object.material.opacity = object.userData.hitProxy ? 0 : (object.userData.baseOpacity ?? 1);
        object.material.transparent = object.userData.hitProxy ? true : object.userData.baseTransparent;
        if (typeof object.userData.baseDepthWrite === "boolean") {
          object.material.depthWrite = object.userData.baseDepthWrite;
        }
        if (object.material.color && object.userData.baseColor !== undefined) {
          object.material.color.setHex(object.userData.baseColor);
        }
        if (object.material.emissive && object.userData.baseEmissive !== undefined) {
          object.material.emissive.setHex(object.userData.baseEmissive);
          object.material.emissiveIntensity = 0;
        }
        requestMaterialUpdate(object.material);
      });
    };

    const findPartHit = (hits) =>
      hits
        .filter((item) => item.object.userData.partKey)
        .sort((a, b) => {
          const priorityDelta = (b.object.userData.selectionPriority || 0) - (a.object.userData.selectionPriority || 0);
          return priorityDelta || a.distance - b.distance;
        })[0];

    const pickPart = (event) => {
      const bounds = renderer.domElement.getBoundingClientRect();
      pointer.x = ((event.clientX - bounds.left) / bounds.width) * 2 - 1;
      pointer.y = -((event.clientY - bounds.top) / bounds.height) * 2 + 1;
      raycaster.setFromCamera(pointer, camera);
      const hits = raycaster.intersectObject(model, true);
      const hit = findPartHit(hits);
      if (hit) setSelectedPart(hit.object.userData.partKey);
    };

    const handlePointerDown = (event) => {
      if (event.button !== 0) return;
      pointerDownState = {
        pointerId: event.pointerId,
        x: event.clientX,
        y: event.clientY
      };
      renderer.domElement.style.cursor = "grabbing";
    };

    const handlePointerUp = (event) => {
      if (!pointerDownState) return;
      const distance = Math.hypot(
        event.clientX - pointerDownState.x,
        event.clientY - pointerDownState.y
      );
      const wasDraggingModel = distance > dragSelectionThreshold;
      pointerDownState = null;
      if (wasDraggingModel) {
        updateCursor(event);
        return;
      }
      pickPart(event);
    };

    const clearPointerDownState = () => {
      pointerDownState = null;
    };

    const updateCursor = (event) => {
      if (pointerDownState) {
        const distance = Math.hypot(
          event.clientX - pointerDownState.x,
          event.clientY - pointerDownState.y
        );
        if (distance > dragSelectionThreshold) {
          renderer.domElement.style.cursor = "grabbing";
          return;
        }
      }

      const bounds = renderer.domElement.getBoundingClientRect();
      pointer.x = ((event.clientX - bounds.left) / bounds.width) * 2 - 1;
      pointer.y = -((event.clientY - bounds.top) / bounds.height) * 2 + 1;
      raycaster.setFromCamera(pointer, camera);
      const hit = findPartHit(raycaster.intersectObject(model, true));
      renderer.domElement.style.cursor = hit ? "pointer" : "grab";
    };

    renderer.domElement.addEventListener("pointerdown", handlePointerDown);
    renderer.domElement.addEventListener("pointerup", handlePointerUp);
    renderer.domElement.addEventListener("pointercancel", clearPointerDownState);
    renderer.domElement.addEventListener("pointerleave", clearPointerDownState);
    renderer.domElement.addEventListener("pointermove", updateCursor);

    const indexClickHandlers = [];
    for (const button of indexButtons) {
      const buttonPart = button.getAttribute("data-dfb-part-index");
      button.style.setProperty("--part-color", partInfo[buttonPart]?.color || "var(--border)");
      const handler = () => setSelectedPart(button.getAttribute("data-dfb-part-index"));
      button.addEventListener("click", handler);
      indexClickHandlers.push([button, handler]);
    }

    const handleExplodeToggle = () => {
      isExploded = !isExploded;
      if (explodeBtn) {
        explodeBtn.setAttribute("aria-pressed", String(isExploded));
      }
    };
    explodeBtn?.addEventListener("click", handleExplodeToggle);

    const resize = () => {
      const { width } = root.getBoundingClientRect();
      const canvasHeight = Math.max(380, Math.min(600, width * 0.6));
      root.style.setProperty("--model-height", `${canvasHeight}px`);
      renderer.setSize(width, canvasHeight, false);
      camera.aspect = width / canvasHeight;
      setDefaultCameraFrame();
      camera.updateProjectionMatrix();
    };

    const observer = new ResizeObserver(resize);
    observer.observe(root);
    resize();

    let frame = 0;
    const animate = () => {
      frame = requestAnimationFrame(animate);
      const time = performance.now() * 0.001;

      const explodeTarget = isExploded ? explodeGap : 0;
      for (let i = 0; i < layerGroups.length; i += 1) {
        const current = layerGroups[i].userData.explodeY || 0;
        const target = i * explodeTarget;
        const newVal = current + (target - current) * explodeSpeed;
        layerGroups[i].userData.explodeY = newVal;
        layerGroups[i].position.y = (layerGroups[i].userData.baseY || 0) + newVal;
      }

      if (currentGlowSpheres && currentPathCurves) {
        for (let i = 0; i < currentGlowSpheres.length; i += 1) {
          for (const item of currentGlowSpheres[i]) {
            const t = (item.offset + time * 0.72) % 1;
            const pt = currentPathCurves[i].getPointAt(t);
            item.mesh.position.copy(pt);
            const fade = Math.sin(t * Math.PI);
            item.mesh.material.opacity = 0.22 + 0.58 * fade;
            item.mesh.scale.setScalar(0.72 + 0.42 * fade);
          }
        }
      }

      if (gratingFeedbackPulses && gratingFeedbackCurve) {
        for (const pulse of gratingFeedbackPulses) {
          const t = (pulse.userData.offset + time * 0.5) % 1;
          const reflectedT = pulse.userData.direction > 0 ? t : 1 - t;
          const feedbackPoint = gratingFeedbackCurve.getPointAt(reflectedT);
          pulse.position.copy(feedbackPoint);
          pulse.position.z = pulse.userData.baseZ + Math.sin(time * 3.4 + pulse.userData.zPhase) * 0.045;
          const envelope = Math.sin(t * Math.PI);
          pulse.material.opacity = 0.16 + 0.58 * envelope;
          pulse.scale.setScalar(0.72 + 0.36 * envelope);
        }
      }

      if (braggSelectionLines) {
        for (const wave of braggSelectionLines) {
          updateBraggWaveLine(wave, time);
        }
      }

      if (activePhotons) {
        for (const photon of activePhotons) {
          const travel = (time * photon.userData.speed + photon.userData.offset) % 1;
          if (photon.userData.isTargetPhoton) {
            const bounce = 0.5 - 0.5 * Math.cos(travel * Math.PI * 2);
            photon.position.x = THREE.MathUtils.lerp(-photon.userData.amplitude, photon.userData.amplitude, bounce);
            photon.position.y = photon.userData.baseY + Math.sin(time * 2.1 + photon.userData.offset * Math.PI * 2) * 0.025;
            photon.position.z = photon.userData.baseZ + Math.sin(time * 1.6 + photon.userData.offset * 8) * 0.035;
            const pulse = 0.5 + 0.5 * Math.sin(time * 3.2 + photon.userData.offset * 10);
            photon.material.opacity = 0.56 + pulse * 0.24;
            photon.scale.setScalar(0.86 + pulse * 0.22);
          } else {
            const suppression = smoothstep(0.58, 0.9, travel);
            photon.position.x = THREE.MathUtils.lerp(-photon.userData.amplitude, photon.userData.amplitude, travel);
            photon.position.y = photon.userData.baseY + Math.sin(time * 2.4 + photon.userData.offset * 7) * 0.032;
            photon.position.z = photon.userData.baseZ + Math.cos(time * 2.1 + photon.userData.offset * 9) * 0.045;
            const flicker = 0.5 + 0.5 * Math.sin(time * 4.2 + photon.userData.offset * 11);
            photon.material.opacity = (0.22 + flicker * 0.34) * (1 - suppression) + 0.035 * (1 - smoothstep(0.9, 1, travel));
            photon.scale.setScalar((0.7 + flicker * 0.22) * (1 - suppression * 0.72));
          }
        }
      }

      if (outputPhotonSpheres && outputPhotonCurve) {
        for (const item of outputPhotonSpheres) {
          const t = (item.offset + time * 0.36) % 1;
          const pt = outputPhotonCurve.getPointAt(t);
          item.mesh.position.copy(pt);
          const fade = Math.sin(t * Math.PI);
          item.mesh.material.opacity = 0.25 + 0.6 * fade;
          item.mesh.scale.setScalar(0.75 + 0.48 * fade);
        }
      }

      controls.update();
      renderer.render(scene, camera);
    };
    animate();

    document.addEventListener("astro:before-swap", () => {
      cancelAnimationFrame(frame);
      observer.disconnect();
      renderer.domElement.removeEventListener("pointerdown", handlePointerDown);
      renderer.domElement.removeEventListener("pointerup", handlePointerUp);
      renderer.domElement.removeEventListener("pointercancel", clearPointerDownState);
      renderer.domElement.removeEventListener("pointerleave", clearPointerDownState);
      renderer.domElement.removeEventListener("pointermove", updateCursor);
      for (const [button, handler] of indexClickHandlers) {
        button.removeEventListener("click", handler);
      }
      explodeBtn?.removeEventListener("click", handleExplodeToggle);
      window.removeEventListener("wheel", wheelHandler, { capture: true });
      controls.dispose();
      renderer.dispose();
    }, { once: true });
  }
</script>

