      txeGlowSpheres.push({ mesh: glow, offset: i / 6 });
      txeGroup.add(glow);
    }
    chip.add(tagPart(txeGroup, "electricalPath"));

    // TX optical path (CW laser → input coupler → waveguide → MMI splitter → phase arms → MMI combiner → output waveguide → output coupler)
    const txPathGroup = new THREE.Group();
    const txPathY = siSlabTop + ribRidgeH / 2;
    const txPathTopY = siSlabTop + ribRidgeH;

    // Two paths through the MZM — one per phase arm (from GC at Z=-0.4)
    const txPathPoints1 = [
      new THREE.Vector3(-2.4, fiberBottomY + 0.2, -0.4), // above TX GC
      new THREE.Vector3(-2.4, fiberBottomY, -0.4),        // fiber end
      new THREE.Vector3(-2.4, txPathTopY, -0.4),          // GC surface
      new THREE.Vector3(-2.4, txPathY, 0),                // Z-branch
      new THREE.Vector3(-0.5, txPathY, 0.4),              // TX waveguide
      new THREE.Vector3(0.5, txPathY, 0.15),              // phase arm 1
      new THREE.Vector3(1.7, txPathY, 0.4),               // MMI combiner
