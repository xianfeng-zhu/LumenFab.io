    lSiDevice.add(createFaceLabel("RX 光栅耦合器", new THREE.Vector3(-2.4, wgTopY, rxZ), faceTop, { scale: 0.10 }));
    lSiDevice.add(createFaceLabel("TX 光栅耦合器", new THREE.Vector3(-2.4, wgTopY, -0.4), faceTop, { scale: 0.10 }));
    lSiDevice.add(createFaceLabel("TX 光栅耦合器", new THREE.Vector3(2.2, wgTopY, -0.4), faceTop, { scale: 0.10 }));

