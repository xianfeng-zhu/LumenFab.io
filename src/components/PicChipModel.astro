    const facePX = new THREE.Vector3(1, 0, 0);
    const faceNX = new THREE.Vector3(-1, 0, 0);
    const ecY = siSlabTop - siSlabH / 2 + siRibH / 2 + 0.04;
    const ecRX = chipLen / 2 + 0.02 + eps;
    const ecLX = -chipLen / 2 - 0.02 - eps;
    lSiDevice.add(createFaceLabel("RX 边缘耦合器", new THREE.Vector3(ecRX, ecY, rxEdgeZ), facePX, { scale: 0.08 }));
    lSiDevice.add(createFaceLabel("TX 输入边缘耦合器", new THREE.Vector3(ecLX, ecY, 0.4), faceNX, { scale: 0.08 }));
    lSiDevice.add(createFaceLabel("TX 输出边缘耦合器", new THREE.Vector3(ecRX, ecY, 0.4), facePX, { scale: 0.08 }));

    // Heaters — above heater top surface (heater strip too narrow for face label)
    const heaterTopY = cladTopY + heaterH + eps;
    lHeater.add(createFaceLabel("TiN 加热器", new THREE.Vector3(0.5, heaterTopY, 0.15), faceTop, { scale: 0.09, depthTest: false }));
    lHeater.add(createFaceLabel("TiN 加热器", new THREE.Vector3(0.5, heaterTopY, 0.65), faceTop, { scale: 0.09, depthTest: false }));
    // M1 interconnect — above M1 top surface
    const m1TopY = cladTopY + heaterH + m1H + eps;
    lM1.add(createFaceLabel("M1 互连", new THREE.Vector3(geX, m1TopY, rxZ), faceTop, { scale: 0.10, depthTest: false }));

