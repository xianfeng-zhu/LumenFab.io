    // Ge detector — top face
    const geTopY = siSlabTop + geH + eps;
    lGeDetector.add(createFaceLabel("Ge 光电探测器", new THREE.Vector3(geX, geTopY, rxZ), faceTop, { scale: 0.11 }));

