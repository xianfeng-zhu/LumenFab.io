---
interface Props {
  title?: string;
  caption?: string;
}

const {
  title = "硅光 PIC 芯片物理结构模型",
  caption = "可旋转模型以透视剖面方式显示硅光 PIC 芯片的纵向层叠结构与关键组件。为便于观察，垂直层厚均经过示意化放大，属于 not to scale 教学模型。"
} = Astro.props;

const legendItems = [
  ["substrate", "#2563eb", "Si 衬底"],
  ["box", "#94a3b8", "BOX 埋氧层"],
  ["siDevice", "#0d9488", "Si 器件层 / 波导"],
  ["geDetector", "#16a34a", "Ge 光电探测器"],
  ["cladding", "#94a3b8", "SiO₂ 上包层"],
  ["heater", "#eab308", "TiN 加热器"],
  ["m1Interconnect", "#f97316", "M1 Cu 互连"],
  ["rfElectrode", "#ef4444", "RF 电极 (GSG)"],
  ["bondPad", "#475569", "Al 焊盘"],
  ["gratingCoupler", "#7c3aed", "光栅耦合器"],
  ["edgeCoupler", "#a855f7", "边缘耦合器"],
  ["opticalPath", "#0891b2", "光信号路径"],
  ["electricalPath", "#f59e0b", "电信号路径"]
];

const indexItems = [
  ["substrate", "#2563eb", "Si 衬底"],
  ["box", "#94a3b8", "BOX 埋氧层"],
  ["siDevice", "#0d9488", "Si 器件层"],
  ["stripWaveguide", "#14b8a6", "条形波导 (全刻蚀)"],
  ["ribWaveguide", "#0f766e", "脊形波导 (浅刻蚀)"],
  ["geDetector", "#16a34a", "Ge 光电探测器"],
  ["cladding", "#94a3b8", "SiO₂ 上包层"],
  ["heater", "#eab308", "TiN 微加热器"],
  ["m1Interconnect", "#f97316", "M1 互连"],
  ["rfElectrode", "#ef4444", "GSG 行波电极"],
  ["bondPad", "#475569", "Al 焊盘"],
  ["gratingCoupler", "#7c3aed", "光栅耦合器"],
  ["edgeCoupler", "#a855f7", "边缘耦合器端面"],
  ["opticalPath", "#0891b2", "光信号路径"],
  ["electricalPath", "#f59e0b", "电信号路径"]
];
---

<figure class="pic-model">
  <div class="pic-model__viewport" data-pic-chip-model>
    <canvas aria-label={title}></canvas>
    <div class="pic-model__legend" aria-hidden="true">
      {legendItems.map(([key, color, label]) => (
        <span data-key={key}><i style={`--swatch: ${color}`}></i>{label}</span>
      ))}
    </div>
    <div class="pic-model__controls">
      <div class="pic-model__controls-row">
        <button type="button" class="pic-model__control-btn" data-pic-explode-toggle aria-pressed="false">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 5.5L7 1.5L11 5.5"/>
            <path d="M3 8.5L7 12.5L11 8.5"/>
          </svg>
          <span>分层展开</span>
        </button>
        <button type="button" class="pic-model__control-btn" data-pic-section-toggle aria-pressed="false">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <rect x="1" y="1" width="12" height="12" rx="1"/>
            <line x1="7" y1="1" x2="7" y2="13"/>
          </svg>
          <span>剖面视图</span>
        </button>
        <button type="button" class="pic-model__control-btn" data-pic-cladding-toggle aria-pressed="false">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 7C1 7 3 2 7 2C11 2 13 7 13 7C13 7 11 12 7 12C3 12 1 7 1 7Z"/>
            <circle cx="7" cy="7" r="2.5"/>
          </svg>
          <span>透明包层</span>
        </button>
      </div>
      <div class="pic-model__slider" data-pic-section-slider-wrap hidden>
        <input type="range" data-pic-section-slider min="-3.8" max="3.8" step="0.05" value="0">
        <span>切面位置</span>
      </div>
    </div>
  </div>
  <div class="pic-model__index" aria-label="3D 模型结构索引">
    {indexItems.map(([key, color, label]) => (
      <button type="button" data-pic-part-index={key} style={`--part-color: ${color}`}>{label}</button>
    ))}
  </div>
  <div class="pic-model__info" data-pic-part-info aria-live="polite">
    <strong data-pic-part-title>结构说明</strong>
    <span data-pic-part-body>选择模型中的结构，或点击下方结构索引，这里会显示它在 PIC 芯片中的作用。</span>
  </div>
  <figcaption>
    <strong>{title}</strong>
    <span>{caption}</span>
  </figcaption>
</figure>

<script>
  import * as THREE from "three";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";

  const roots = document.querySelectorAll("[data-pic-chip-model]");

  const partInfo = {
    substrate: {
      color: "#2563eb",
      title: "Si 衬底 (handle wafer)",
      body: "约 725 μm 厚的单晶硅衬底，提供机械支撑。在高速调制器区域下方通常选用高阻硅 (>750 Ω·cm)，以减少衬底对 RF 信号的损耗。是整个 PIC 芯片的最底层。"
    },
    box: {
      color: "#94a3b8",
      title: "BOX 埋氧层 (buried oxide)",
      body: "约 2 μm 的热氧化 SiO₂。光子 SOI 的 BOX 远厚于电子 SOI (后者仅 50–100 nm)，目的是保证 1550 nm 波段的光学隔离——防止上方的光波导模式泄漏到硅衬底中。"
    },
    siDevice: {
      color: "#0d9488",
      title: "Si 器件层 (220 nm 单晶硅)",
      body: "所有光子器件的「画布」。220 nm 厚的单晶硅层通过三种蚀刻深度（全刻蚀 220 nm、深部分 ~160 nm、浅部分 ~70 nm）形成条形波导、脊形波导和光栅耦合器等结构，同时通过离子注入形成调制器所需的 p-n 结。"
    },
    stripWaveguide: {
      color: "#14b8a6",
      title: "条形波导 (全刻蚀)",
      body: "硅被完全刻穿至 BOX，留下宽约 400–500 nm 的条形波导芯层。光场被强烈约束，弯曲半径可至数微米，用于紧凑布线、微环谐振器和定向耦合器。传播损耗相对较高 (~2–3 dB/cm)，来自全刻蚀侧壁的散射。"
    },
    ribWaveguide: {
      color: "#0f766e",
      title: "脊形波导 (部分刻蚀)",
      body: "仅刻蚀掉部分硅厚度 (~70 nm 或 ~150 nm)，留下一层硅平板。传播损耗更低 (可低于 0.3 dB/cm)，但弯曲半径较大 (数十微米)。用于长距离布线、MMI、调制器相位臂和延迟线。"
    },
    geDetector: {
      color: "#16a34a",
      title: "Ge 光电探测器",
      body: "在指定区域通过 RPCVD 选择性外延生长约 200–500 nm 的单晶锗。光从下方硅波导倏逝耦合进入 Ge 层被吸收，产生电子-空穴对并在偏置电场下形成光电流。Ge 只生长在暴露的硅窗口上，氧化层区域不生长。"
    },
    cladding: {
      color: "#94a3b8",
      title: "SiO₂ 上包层 (ILD)",
      body: "约 1–2 μm 的 PECVD 沉积 SiO₂，覆盖整个芯片表面。它同时承担波导上包层 (光场约束) 和电学隔离层 (防止金属电极吸收光) 的双重角色。加热器的热量也通过此层向下传导至波导。"
    },
    heater: {
      color: "#eab308",
      title: "TiN 微加热器",
      body: "一层专用的 TiN (或 Ni) 金属电阻条，位于波导上方约 1 μm 处。通电后通过 SiO₂ 包层向下传热，利用硅的热光效应 (dn/dT ≈ 1.86×10⁻⁴ K⁻¹) 调节波导的相位或微环的共振波长。单个 π 相移功耗约 10–50 mW。"
    },
    m1Interconnect: {
      color: "#f97316",
      title: "M1 Cu 互连",
      body: "第一层 Cu 金属互连 (~200 nm–1 μm)。提供就近的信号引出——例如为加热器供电、连接 Ge PD 电极——并通过 W 通孔向下连接到硅掺杂区和加热器端点。"
    },
    rfElectrode: {
      color: "#ef4444",
      title: "GSG 行波 RF 电极",
      body: "在 M2 层形成的地-信号-地 (GSG) 共面波导结构，位于调制器波导上方。目标特性阻抗 50 Ω，追求 RF 信号与光信号的群速度匹配以最大化电光带宽。M2 层厚度通常 ~2 μm 以保证 RF 性能。"
    },
    bondPad: {
      color: "#475569",
      title: "Al 焊盘",
      body: "芯片最顶层的 Al 焊盘，通过钝化层开窗暴露。用于引线键合 (wire bonding) 或倒装互连 (flip-chip)，将芯片的直流偏置、RF 信号和控制信号连接到封装或 EIC。"
    },
    gratingCoupler: {
      color: "#7c3aed",
      title: "光栅耦合器",
      body: "利用周期性刻蚀结构，将片上波导中的光向上 (或向下) 衍射到芯片表面外，也可将上方光纤的光耦合进波导。便于晶圆级测试——光纤可以从芯片上方直接访问，无需芯片端面加工。"
    },
    edgeCoupler: {
      color: "#a855f7",
      title: "边缘耦合器端面",
      body: "位于芯片边缘的光学端面，通过反向锥形结构 (inverse taper) 或 SSC 将片上小模场逐步扩展，与光纤的 ~9–10 μm 模场匹配。通常提供更宽的光学带宽和更低的耦合损耗，但需要高质量芯片端面和精密对准。"
    },
    opticalPath: {
      color: "#0891b2",
      title: "光信号路径",
      body: "光从激光源进入 PIC 后，经耦合器进入波导层，在硅器件层中传输、分束、调制、滤波，最终到达 Ge PD 被探测或经输出耦合器离开芯片。这条路径完全位于硅器件层内 (或 SiN 层内)。"
    },
    electricalPath: {
      color: "#f59e0b",
      title: "电信号路径",
      body: "Ge 探测器吸收光子后产生电子-空穴对，在反向偏压下形成光电流。电流经 W 接触通孔向上进入 M1 铜互连层，再经 M1 引线传输至 Al 焊盘，最终通过引线键合送到片外的 TIA/CDR 电路。"
    }
  };

  const partOrder = Object.keys(partInfo);
  const partColor = (key) => Number.parseInt(partInfo[key].color.slice(1), 16);

  const material = (color, options = {}) =>
    new THREE.MeshStandardMaterial({
      color,
      roughness: 0.68,
      metalness: 0,
      ...options
    });

  const transparent = (color, opacity) =>
    material(color, {
      transparent: true,
      opacity,
      depthWrite: false
    });

  function createBox({ size, position, color, opacity = 1, metalness = 0, roughness = 0.68 }) {
    const mat = material(color, {
      transparent: opacity < 1,
      opacity,
      metalness,
      roughness
    });
    const mesh = new THREE.Mesh(new THREE.BoxGeometry(...size), mat);
    mesh.position.set(...position);
    return mesh;
  }

  function createHitBox({ size, position, key, priority = 2 }) {
    const mesh = new THREE.Mesh(
      new THREE.BoxGeometry(...size),
      new THREE.MeshBasicMaterial({
        transparent: true,
        opacity: 0,
        depthWrite: false
      })
    );
    mesh.position.set(...position);
    return tagPart(mesh, key, true, priority);
  }

  function tagPart(object, key, isHitProxy = false, priority = 0) {
    object.userData.partKey = key;
    object.userData.hitProxy = isHitProxy;
    object.userData.selectionPriority = priority;
    object.traverse((child) => {
      child.userData.partKey = key;
      child.userData.hitProxy = isHitProxy;
      child.userData.selectionPriority = priority;
    });
    return object;
  }

  function createFaceLabel(text, position, normal, { color = "#334155", scale = 0.09, depthTest = true } = {}) {
    const canvas = document.createElement("canvas");
    const ctx = canvas.getContext("2d");
    const fontSize = 64;
    ctx.font = `${fontSize}px "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif`;
    const metrics = ctx.measureText(text);
    const pad = 20;
    const w = Math.ceil(metrics.width + pad * 2);
    const h = Math.ceil(fontSize * 1.5);
    canvas.width = w;
    canvas.height = h;
    // pill background
    const rx = pad - 8, ry = Math.round((h - fontSize) / 2) - 6, rw = Math.ceil(metrics.width) + 16, rh = fontSize + 12;
    ctx.fillStyle = "rgba(255, 255, 255, 0.88)";
    ctx.beginPath();
    const r = 10;
    ctx.moveTo(rx + r, ry);
    ctx.lineTo(rx + rw - r, ry);
    ctx.quadraticCurveTo(rx + rw, ry, rx + rw, ry + r);
    ctx.lineTo(rx + rw, ry + rh - r);
    ctx.quadraticCurveTo(rx + rw, ry + rh, rx + rw - r, ry + rh);
    ctx.lineTo(rx + r, ry + rh);
    ctx.quadraticCurveTo(rx, ry + rh, rx, ry + rh - r);
    ctx.lineTo(rx, ry + r);
    ctx.quadraticCurveTo(rx, ry, rx + r, ry);
    ctx.closePath();
    ctx.fill();
    ctx.strokeStyle = "rgba(148, 163, 184, 0.45)";
    ctx.lineWidth = 1.5;
    ctx.stroke();
    // text
    ctx.fillStyle = color;
    ctx.font = `${fontSize}px "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif`;
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText(text, w / 2, h / 2);
    const texture = new THREE.CanvasTexture(canvas);
    texture.minFilter = THREE.LinearFilter;
    texture.magFilter = THREE.LinearFilter;
    const aspect = w / h;
    const planeW = scale * aspect;
    const planeH = scale;
    const geom = new THREE.PlaneGeometry(planeW, planeH);
    const mat = new THREE.MeshBasicMaterial({
      map: texture,
      transparent: true,
      depthWrite: false,
      side: THREE.DoubleSide,
      depthTest
    });
    const plane = new THREE.Mesh(geom, mat);
    plane.position.copy(position);
    const q = new THREE.Quaternion().setFromUnitVectors(
      new THREE.Vector3(0, 0, 1),
      normal.clone().normalize()
    );
    plane.setRotationFromQuaternion(q);
    return plane;
  }

  function buildModel(scene) {
    const chip = new THREE.Group();
    scene.add(chip);

    const chipLen = 7.5;
    const chipWidth = 7.5;
    // RX path Z — shifted up to make room for new devices between TX and RX
    const rxZ = 2.2;
    const rxEdgeZ = 2.55;
    const rxPadZ = 2.55;

    // ---- Layer groups for explode view ----
    const layerGroups = [];
    function addLayer(key) {
      const group = new THREE.Group();
      group.userData.layerKey = key;
      group.userData.layerIndex = layerGroups.length;
      layerGroups.push(group);
      chip.add(group);
      return group;
    }

    const lSubstrate = addLayer("substrate");
    const lBox = addLayer("box");
    const lSiDevice = addLayer("siDevice");
    const lGeDetector = addLayer("geDetector");
    const lCladding = addLayer("cladding");
    const lHeater = addLayer("heater");
    const lM1 = addLayer("m1Interconnect");
    const lRf = addLayer("rfElectrode");
    const lTop = addLayer("topLayer");

    let yBase = 0;

    // === Layer 1: Si substrate ===
    const substrateH = 1.2;
    const substrate = createBox({
      size: [chipLen, substrateH, chipWidth],
      position: [0, yBase + substrateH / 2, 0],
      color: 0x2563eb,
      roughness: 0.78,
      metalness: 0
    });
    lSubstrate.add(tagPart(substrate, "substrate"));
    yBase += substrateH;

    // === Layer 2: BOX ===
    const boxH = 0.25;
    const box = createBox({
      size: [chipLen, boxH, chipWidth],
      position: [0, yBase + boxH / 2, 0],
      color: 0x94a3b8,
      roughness: 0.5,
      metalness: 0
    });
    lBox.add(tagPart(box, "box"));
    yBase += boxH;

    // === Layer 3: Si device layer ===
    const siBase = yBase;
    const siFullH = 0.34;
    const siSlabH = 0.19;
    const siRibH = 0.26;

    const siSlab = createBox({
      size: [chipLen, siSlabH, chipWidth],
      position: [0, yBase + siSlabH / 2, 0],
      color: 0x0d9488,
      roughness: 0.48,
      metalness: 0.08,
      opacity: 0.85
    });
    lSiDevice.add(tagPart(siSlab, "siDevice"));

    const siSlabTop = yBase + siSlabH;
    const stripRidgeH = siFullH - siSlabH;

    // Rib waveguide — right segment (does not pass through grating coupler region)
    const ribRidgeH = siRibH - siSlabH;
    const gcRightEdge = -2.4 + 6 * 0.16 + 0.05 / 2; // ~-1.415
    const ribStartX = -0.9;
    const ribEndX = chipLen / 2 - 0.3;
    const ribRightLen = ribEndX - ribStartX;
    const ribRightCenter = (ribStartX + ribEndX) / 2;

    const ribWG = createBox({
      size: [ribRightLen, ribRidgeH, 0.32],
      position: [ribRightCenter, siSlabTop + ribRidgeH / 2, rxZ],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(ribWG, "ribWaveguide", false, 4));

    // Connector from grating coupler to rib waveguide
    const connLen = ribStartX - gcRightEdge;
    const connCenterX = (gcRightEdge + ribStartX) / 2;
    const conn = createBox({
      size: [connLen, ribRidgeH, 0.32],
      position: [connCenterX, siSlabTop + ribRidgeH / 2, rxZ],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(conn, "ribWaveguide", false, 4));

    const siTopY = siSlabTop + stripRidgeH;
    yBase = siBase + siSlabH;

    // WDM demux — three microrings on RX bus, each with drop port + Ge PD
    const ringR = [0.22, 0.25, 0.28]; // slightly different radii → different λ
    const ringXs = [-0.3, 0.8, 1.9];
    const ringGap = 0.05;
    const ringY = siSlabTop + ribRidgeH / 2;
    const ringTag = ["ring1", "ring2", "ring3"];
    const dropLen = 0.42;
    const dropGeH = 0.12;
    const dropGeData = [];
    for (let i = 0; i < 3; i++) {
      const rr = ringR[i];
      const rx = ringXs[i];
      const rz = rxZ + 0.16 + ringGap + rr + 0.035;
      // ring torus
      const geom = new THREE.TorusGeometry(rr, 0.032, 16, 48);
      const mesh = new THREE.Mesh(geom, material(0x14b8a6, { roughness: 0.38, metalness: 0.12 }));
      mesh.position.set(rx, ringY, rz);
      mesh.rotation.x = Math.PI / 2;
      lSiDevice.add(tagPart(mesh, "stripWaveguide", false, 5));
      // drop waveguide (Z direction from ring far side upward)
      const dropZ = rz + rr + 0.032 + dropLen / 2 + 0.03;
      const dwg = createBox({
        size: [0.24, ribRidgeH, dropLen],
        position: [rx, siSlabTop + ribRidgeH / 2, dropZ],
        color: 0x0f766e, roughness: 0.42, metalness: 0.12
      });
      lSiDevice.add(tagPart(dwg, "ribWaveguide", false, 4));
      // Ge PD at drop waveguide end
      const geZ = dropZ + dropLen / 2 + dropGeH / 2 + 0.04;
      const pd = createBox({
        size: [0.45, dropGeH, 0.22],
        position: [rx, siSlabTop + dropGeH / 2, geZ],
        color: 0x16a34a, roughness: 0.38, metalness: 0.08
      });
      lGeDetector.add(tagPart(pd, "geDetector", false, 5));
      // W via + M1 stub deferred to after cladding (needs cladTopY)
      dropGeData.push({ rx, geZ });
    }

    // === Layer 4: Ge photodetector ===
    const geH = 0.18;
    const geX = 3.0; // after all 3 rings: through-port monitor
    const geDetector = createBox({
      size: [1.2, geH, 0.5],
      position: [geX, siSlabTop + geH / 2, rxZ],
      color: 0x16a34a,
      roughness: 0.38,
      metalness: 0.08
    });
    lGeDetector.add(tagPart(geDetector, "geDetector", false, 5));

    // === Layer 5: Cladding ===
    const cladH = 0.65;
    const claddingFull = createBox({
      size: [chipLen, cladH, chipWidth],
      position: [0, siTopY + cladH / 2, 0],
      color: 0x94a3b8,
      roughness: 0.6,
      metalness: 0,
      opacity: 0.58
    });
    claddingFull.material.depthWrite = false;
    lCladding.add(tagPart(claddingFull, "cladding"));

    const cladTopY = siTopY + cladH;

    // === Layer 6: Heaters (TX MZM phase arms) ===
    const heaterH = 0.06;

    // === Layer 7: M1 interconnect ===
    const m1H = 0.09;
    const m1Line = createBox({
      size: [1.6, m1H, 0.12],
      position: [geX, cladTopY + heaterH + m1H / 2, rxZ],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lM1.add(tagPart(m1Line, "m1Interconnect", false, 4));

    // === Layer 8: RF electrodes ===
    const rfH = 0.18;
    const rfBaseY = cladTopY + heaterH + m1H;

    const rfSignal = createBox({
      size: [3.2, rfH, 0.12],
      position: [0.6, rfBaseY + rfH / 2, 0.4],
      color: 0xef4444,
      metalness: 0.7,
      roughness: 0.18
    });
    lRf.add(tagPart(rfSignal, "rfElectrode", false, 4));

    const rfGnd1 = createBox({
      size: [3.2, rfH, 0.12],
      position: [0.6, rfBaseY + rfH / 2, -0.4],
      color: 0xdc2626,
      metalness: 0.7,
      roughness: 0.18
    });
    const rfGnd2 = createBox({
      size: [3.2, rfH, 0.12],
      position: [0.6, rfBaseY + rfH / 2, 1.2],
      color: 0xdc2626,
      metalness: 0.7,
      roughness: 0.18
    });
    lRf.add(tagPart(rfGnd1, "rfElectrode"), tagPart(rfGnd2, "rfElectrode"));

    // === ILD cover over metal structures ===
    // In a real PIC, heater / M1 / RF electrodes are embedded in SiO₂ ILD,
    // not exposed to air. A semi-transparent cover layer eliminates the
    // "floating" visual artefacts above the cladding.
    const ildCoverH = 0.38;
    const ildCover = createBox({
      size: [chipLen - 0.08, ildCoverH, chipWidth - 0.08],
      position: [0, cladTopY + ildCoverH / 2, 0],
      color: 0x94a3b8,
      roughness: 0.6,
      metalness: 0,
      opacity: 0.58
    });
    ildCover.material.depthWrite = false;
    lTop.add(tagPart(ildCover, "cladding"));

    // Drop Ge PD W vias + M1 stubs + top vias (deferred — needs cladTopY)
    const padH = 0.1;
    const padBaseY = rfBaseY + rfH;
    for (const d of dropGeData) {
      const geTopY = siSlabTop + dropGeH;
      // W via: Ge → M1
      const viaH_drop = cladTopY + heaterH - geTopY;
      lM1.add(tagPart(createBox({
        size: [0.06, viaH_drop, 0.06],
        position: [d.rx, geTopY + viaH_drop / 2, d.geZ],
        color: 0x78716c, metalness: 0.75, roughness: 0.25
      }), "m1Interconnect", false, 4));
      // M1 stub
      const m1StubY = cladTopY + heaterH + m1H / 2;
      lM1.add(tagPart(createBox({
        size: [0.3, m1H, 0.08],
        position: [d.rx, m1StubY, d.geZ],
        color: 0xf97316, metalness: 0.65, roughness: 0.22
      }), "m1Interconnect", false, 4));
      // Top via: M1 → bond pad
      const topViaH = padBaseY - (cladTopY + heaterH + m1H);
      lM1.add(tagPart(createBox({
        size: [0.06, topViaH, 0.06],
        position: [d.rx, cladTopY + heaterH + m1H + topViaH / 2, d.geZ],
        color: 0x78716c, metalness: 0.75, roughness: 0.25
      }), "m1Interconnect", false, 4));
    }

    // Monitor PD W via + M1 stub (deferred — needs cladTopY)
    const mpdGeTopY = siSlabTop + mpdH;
    const mpdViaH = cladTopY + heaterH - mpdGeTopY;
    lM1.add(tagPart(createBox({
      size: [0.05, mpdViaH, 0.05],
      position: [mpdX, mpdGeTopY + mpdViaH / 2, mpdZ],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    }), "m1Interconnect", false, 4));
    lM1.add(tagPart(createBox({
      size: [0.2, m1H, 0.06],
      position: [mpdX, cladTopY + heaterH + m1H / 2, mpdZ],
      color: 0xf97316, metalness: 0.65, roughness: 0.22
    }), "m1Interconnect", false, 4));

    // === Layer 9: Bond pads ===
    const padPositions = [
      [2.8, rxPadZ], [2.8, 0.8],
      ...dropGeData.map(d => [d.rx, d.geZ])
    ];
    for (const [px, pz] of padPositions) {
      const pad = createBox({
        size: [0.35, padH, 0.35],
        position: [px, padBaseY + padH / 2, pz],
        color: 0x475569,
        metalness: 0.55,
        roughness: 0.28
      });
      lTop.add(tagPart(pad, "bondPad"));
    }

    // W contact via: Ge detector → M1
    const wViaH = cladTopY + heaterH - (siSlabTop + geH);
    const wVia = createBox({
      size: [0.1, wViaH, 0.1],
      position: [geX, siSlabTop + geH + wViaH / 2, rxZ],
      color: 0x78716c,
      metalness: 0.75,
      roughness: 0.25
    });
    lM1.add(tagPart(wVia, "m1Interconnect", false, 4));

    // M1 branch: from Ge area toward bond pad [2.8, rxPadZ]
    const m1BranchZLen = rxPadZ - rxZ;
    const m1BranchZ = createBox({
      size: [0.12, m1H, m1BranchZLen],
      position: [geX, cladTopY + heaterH + m1H / 2, rxZ + m1BranchZLen / 2],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lM1.add(tagPart(m1BranchZ, "m1Interconnect", false, 4));

    const m1BranchXLen = geX - 2.8;
    const m1BranchX = createBox({
      size: [m1BranchXLen, m1H, 0.12],
      position: [2.8 + m1BranchXLen / 2, cladTopY + heaterH + m1H / 2, rxPadZ],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lM1.add(tagPart(m1BranchX, "m1Interconnect", false, 4));

    // Top via: M1 → bond pad
    const topViaH = padBaseY - (cladTopY + heaterH + m1H);
    const topVia = createBox({
      size: [0.1, topViaH, 0.1],
      position: [2.8, cladTopY + heaterH + m1H + topViaH / 2, rxPadZ],
      color: 0x78716c,
      metalness: 0.75,
      roughness: 0.25
    });
    lM1.add(tagPart(topVia, "m1Interconnect", false, 4));

    // Reference point for incoming optical path (fiber tip above GC)
    const fiberCenterX = -2.32;
    const fiberBottomY = padBaseY + padH + 0.05;

    // Grating coupler — 与 rib 波导同高度的周期性刻蚀结构
    const gcGroup = new THREE.Group();
    const gcPeriod = 0.16;
    const gcY = siSlabTop + ribRidgeH / 2;
    for (let i = -6; i <= 6; i++) {
      const gcTooth = createBox({
        size: [0.05, ribRidgeH, 0.55],
        position: [-2.4 + i * gcPeriod, gcY, rxZ],
        color: 0x7c3aed,
        roughness: 0.35,
        metalness: 0.25
      });
      gcGroup.add(tagPart(gcTooth, "gratingCoupler", false, 5));
    }
    lSiDevice.add(tagPart(gcGroup, "gratingCoupler"));

    // Edge coupler facet
    const edgeCoupler = createBox({
      size: [0.08, siRibH + 0.06, 0.6],
      position: [chipLen / 2 - 0.02, siSlabTop - siSlabH / 2 + siRibH / 2 + 0.04, rxEdgeZ],
      color: 0xa855f7,
      roughness: 0.4,
      metalness: 0.15,
      opacity: 0.7
    });
    lSiDevice.add(tagPart(edgeCoupler, "edgeCoupler", false, 5));

    // TX input edge coupler (left facet — CW laser input)
    const txInputEdgeCoupler = createBox({
      size: [0.08, siRibH + 0.06, 0.6],
      position: [-chipLen / 2 + 0.02, siSlabTop - siSlabH / 2 + siRibH / 2 + 0.04, 0.4],
      color: 0xa855f7,
      roughness: 0.4,
      metalness: 0.15,
      opacity: 0.7
    });
    lSiDevice.add(tagPart(txInputEdgeCoupler, "edgeCoupler", false, 5));

    // TX input grating coupler (Z = -0.4, independent from edge coupler)
    const txGcGroup = new THREE.Group();
    const txGcPeriod = 0.16;
    const txGcY = siSlabTop + ribRidgeH / 2;
    for (let i = -6; i <= 6; i++) {
      const txGcTooth = createBox({
        size: [0.05, ribRidgeH, 0.55],
        position: [-2.4 + i * txGcPeriod, txGcY, -0.4],
        color: 0x7c3aed,
        roughness: 0.35,
        metalness: 0.25
      });
      txGcGroup.add(tagPart(txGcTooth, "gratingCoupler", false, 5));
    }
    lSiDevice.add(tagPart(txGcGroup, "gratingCoupler"));

    // Z-branch from TX main waveguide (Z bottom edge 0.24) to TX input GC (Z top edge -0.24)
    const txInputZBranch = createBox({
      size: [0.32, ribRidgeH, 0.48],
      position: [-2.4, siSlabTop + ribRidgeH / 2, 0],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txInputZBranch, "ribWaveguide", false, 4));

    // Short X-stub waveguide for TX input GC at Z = -0.4
    const txInputGcStub = createBox({
      size: [0.8, ribRidgeH, 0.32],
      position: [-2.4, siSlabTop + ribRidgeH / 2, -0.4],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txInputGcStub, "ribWaveguide", false, 4));

    // TX main waveguide (rib) — from input couplers toward Y-branch
    const ybX = -2.15;
    const txWaveguide = createBox({
      size: [0.8, ribRidgeH, 0.32],
      position: [-2.75, siSlabTop + ribRidgeH / 2, 0.4],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txWaveguide, "ribWaveguide", false, 4));

    // Y-branch splitter — stem + two diverging outputs
    const ybJunction = createBox({
      size: [0.16, ribRidgeH, 0.46],
      position: [ybX, siSlabTop + ribRidgeH / 2, 0.4],
      color: 0x14b8a6, roughness: 0.42, metalness: 0.12
    });
    lSiDevice.add(tagPart(ybJunction, "stripWaveguide", false, 5));
    // Bridge from Y-branch to DC
    const ybToDC = createBox({
      size: [0.22, ribRidgeH, 0.32],
      position: [-1.96, siSlabTop + ribRidgeH / 2, 0.4],
      color: 0x0f766e, roughness: 0.42, metalness: 0.12
    });
    lSiDevice.add(tagPart(ybToDC, "ribWaveguide", false, 4));
    // Tap branch — goes +Z to monitor PD
    const ybTapZ = 0.68;
    const ybTapLen = 0.28;
    const ybTap = createBox({
      size: [ybTapLen, ribRidgeH, 0.24],
      position: [ybX, siSlabTop + ribRidgeH / 2, ybTapZ],
      color: 0x0f766e, roughness: 0.42, metalness: 0.12
    });
    lSiDevice.add(tagPart(ybTap, "ribWaveguide", false, 4));
    // Monitor PD at end of tap branch
    const mpdX = ybX;
    const mpdH = 0.1;
    const mpdZ = ybTapZ + ybTapLen / 2 + 0.06;
    const mpd = createBox({
      size: [0.24, mpdH, 0.16],
      position: [mpdX, siSlabTop + mpdH / 2, mpdZ],
      color: 0x16a34a, roughness: 0.38, metalness: 0.08
    });
    lGeDetector.add(tagPart(mpd, "geDetector", false, 5));
    // W via + M1 stub for monitor PD (deferred — needs cladTopY)

    // Directional coupler — two parallel waveguides with narrow gap
    const dcLen = 0.55;
    const dcGap = 0.06;
    const dcX = -1.65;
    const dcBusWG = createBox({
      size: [dcLen, ribRidgeH, 0.12],
      position: [dcX, siSlabTop + ribRidgeH / 2, 0.4 - dcGap / 2 - 0.06],
      color: 0x14b8a6,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(dcBusWG, "stripWaveguide", false, 5));
    const dcCoupledWG = createBox({
      size: [dcLen, ribRidgeH, 0.12],
      position: [dcX, siSlabTop + ribRidgeH / 2, 0.4 + dcGap / 2 + 0.06],
      color: 0x14b8a6,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(dcCoupledWG, "stripWaveguide", false, 5));

    // TX waveguide from DC to MMI splitter
    const txWaveguideDC = createBox({
      size: [0.75, ribRidgeH, 0.32],
      position: [-1.0, siSlabTop + ribRidgeH / 2, 0.4],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txWaveguideDC, "ribWaveguide", false, 4));

    // TX MMI splitter + MZM phase arms
    const txMmiSplitter = createBox({
      size: [0.5, ribRidgeH, 0.6],
      position: [-0.7, siSlabTop + ribRidgeH / 2, 0.4],
      color: 0x14b8a6,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txMmiSplitter, "stripWaveguide", false, 4));

    const txArm1 = createBox({
      size: [1.9, ribRidgeH, 0.32],
      position: [0.5, siSlabTop + ribRidgeH / 2, 0.15],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txArm1, "ribWaveguide", false, 4));

    const txArm2 = createBox({
      size: [1.9, ribRidgeH, 0.32],
      position: [0.5, siSlabTop + ribRidgeH / 2, 0.65],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txArm2, "ribWaveguide", false, 4));

    // TX MMI combiner (output end of MZM)
    const txMmiCombiner = createBox({
      size: [0.5, ribRidgeH, 0.6],
      position: [1.7, siSlabTop + ribRidgeH / 2, 0.4],
      color: 0x14b8a6,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txMmiCombiner, "stripWaveguide", false, 4));

    // TX output waveguide (from combiner toward output coupler)
    const txOutputWaveguide = createBox({
      size: [1.6, ribRidgeH, 0.32],
      position: [2.75, siSlabTop + ribRidgeH / 2, 0.4],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txOutputWaveguide, "ribWaveguide", false, 4));

    // TX output edge coupler (right facet — modulated light output)
    const txOutputEdgeCoupler = createBox({
      size: [0.08, siRibH + 0.06, 0.6],
      position: [chipLen / 2 - 0.02, siSlabTop - siSlabH / 2 + siRibH / 2 + 0.04, 0.4],
      color: 0xa855f7,
      roughness: 0.4,
      metalness: 0.15,
      opacity: 0.7
    });
    lSiDevice.add(tagPart(txOutputEdgeCoupler, "edgeCoupler", false, 5));

    // TX output grating coupler (wafer-level test output, Z = -0.4)
    const txOutputGcBranchX = 2.2;
    // Z-branch from main output waveguide (Z bottom edge 0.24) to GC stub (Z top edge -0.24)
    const txOutputZBranch = createBox({
      size: [0.32, ribRidgeH, 0.48],
      position: [txOutputGcBranchX, siSlabTop + ribRidgeH / 2, 0],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txOutputZBranch, "ribWaveguide", false, 4));

    // Short X-stub waveguide to place GC teeth on
    const txOutputGcStub = createBox({
      size: [0.8, ribRidgeH, 0.32],
      position: [txOutputGcBranchX, siSlabTop + ribRidgeH / 2, -0.4],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txOutputGcStub, "ribWaveguide", false, 4));

    // GC teeth on the output stub
    const txOutputGcGroup = new THREE.Group();
    for (let i = -6; i <= 6; i++) {
      const txOutputGcTooth = createBox({
        size: [0.05, ribRidgeH, 0.55],
        position: [txOutputGcBranchX + i * 0.16, txGcY, -0.4],
        color: 0x7c3aed,
        roughness: 0.35,
        metalness: 0.25
      });
      txOutputGcGroup.add(tagPart(txOutputGcTooth, "gratingCoupler", false, 5));
    }
    lSiDevice.add(tagPart(txOutputGcGroup, "gratingCoupler"));

    // TX heaters above phase arms (thermal tuning / bias)
    const txHeater1 = createBox({
      size: [1.6, heaterH, 0.1],
      position: [0.5, cladTopY + heaterH / 2, 0.15],
      color: 0xeab308,
      metalness: 0.5,
      roughness: 0.3
    });
    lHeater.add(tagPart(txHeater1, "heater", false, 5));

    const txHeater2 = createBox({
      size: [1.6, heaterH, 0.1],
      position: [0.5, cladTopY + heaterH / 2, 0.65],
      color: 0xeab308,
      metalness: 0.5,
      roughness: 0.3
    });
    lHeater.add(tagPart(txHeater2, "heater", false, 5));

    // Heater W vias up to M1 level
    const viaToM1H = heaterH + m1H;
    const heaterVia1 = createBox({
      size: [0.06, viaToM1H, 0.06],
      position: [0.5, cladTopY + viaToM1H / 2, 0.15],
      color: 0x78716c,
      metalness: 0.75,
      roughness: 0.25
    });
    lHeater.add(tagPart(heaterVia1, "heater", false, 5));
    const heaterVia2 = createBox({
      size: [0.06, viaToM1H, 0.06],
      position: [0.5, cladTopY + viaToM1H / 2, 0.65],
      color: 0x78716c,
      metalness: 0.75,
      roughness: 0.25
    });
    lHeater.add(tagPart(heaterVia2, "heater", false, 5));

    // Short M1 traces from heater vias toward bond pads
    const heaterM1Trace1 = createBox({
      size: [0.5, m1H, 0.08],
      position: [0.75, cladTopY + heaterH + m1H / 2, 0.15],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lM1.add(tagPart(heaterM1Trace1, "m1Interconnect", false, 4));
    const heaterM1Trace2 = createBox({
      size: [0.5, m1H, 0.08],
      position: [0.75, cladTopY + heaterH + m1H / 2, 0.65],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lM1.add(tagPart(heaterM1Trace2, "m1Interconnect", false, 4));

    // === p-n junction doping for MZM phase arms ===
    // Each arm has n++ on one side, p++ on the other, forming a lateral p-n junction
    const dopingLen = 1.9;
    const dopingX = 0.5;
    const dopingW = 0.12;
    const dopingH = siSlabH;
    const dopingY = siBase + siSlabH / 2;
    const slabTopY = siSlabTop;

    // Arm1 (Z=0.15, edges at Z=-0.01 and 0.31)
    const arm1nZ = -0.01 - dopingW / 2;  // n++ strip, lower side
    const arm1pZ = 0.31 + dopingW / 2;   // p++ strip, upper side
    // Arm2 (Z=0.65, edges at Z=0.49 and 0.81)
    const arm2nZ = 0.49 - dopingW / 2;   // n++ strip, lower side
    const arm2pZ = 0.81 + dopingW / 2;   // p++ strip, upper side

    const addDoping = (z, colorHex) => {
      const strip = createBox({
        size: [dopingLen, dopingH, dopingW],
        position: [dopingX, dopingY, z],
        color: colorHex,
        roughness: 0.45,
        metalness: 0.05
      });
      lSiDevice.add(tagPart(strip, "siDevice", false, 6));
    };
    addDoping(arm1nZ, 0x1d4ed8); // n++
    addDoping(arm1pZ, 0xdc2626); // p++
    addDoping(arm2nZ, 0x1d4ed8); // n++
    addDoping(arm2pZ, 0xdc2626); // p++

    // Contact vias from doped slab up through cladding to M1 level
    const viaBaseY = slabTopY;
    const viaTopY = cladTopY + heaterH + m1H;
    const contactViaH = viaTopY - viaBaseY;
    const contactViaY = viaBaseY + contactViaH / 2;
    const viaXs = [-0.3, 0.5, 1.3]; // three contacts along each strip

    const addContactVias = (z, group) => {
      for (const vx of viaXs) {
        const via = createBox({
          size: [0.04, contactViaH, 0.04],
          position: [vx, contactViaY, z],
          color: 0x78716c,
          metalness: 0.75,
          roughness: 0.25
        });
        lM1.add(tagPart(via, "m1Interconnect", false, 4));
      }
    };
    addContactVias(arm1nZ); // n++ contacts for arm 1
    addContactVias(arm1pZ); // p++ contacts for arm 1
    addContactVias(arm2nZ); // n++ contacts for arm 2
    addContactVias(arm2pZ); // p++ contacts for arm 2

    // Small M1 contact pads atop the via groups (landing pads for electrode connection)
    const addM1ContactPads = (z) => {
      for (const vx of viaXs) {
        const pad = createBox({
          size: [0.08, m1H, 0.08],
          position: [vx, viaTopY + m1H / 2, z],
          color: 0xf97316,
          metalness: 0.65,
          roughness: 0.22
        });
        lM1.add(tagPart(pad, "m1Interconnect", false, 4));
      }
    };
    addM1ContactPads(arm1nZ);
    addM1ContactPads(arm1pZ);
    addM1ContactPads(arm2nZ);
    addM1ContactPads(arm2pZ);

    // M1 Z-bridges: lateral traces to connect doping contact pads to RF electrodes
    // RF signal electrode (Z range [0.34, 0.46]) covers arm1 p++ (0.37) and arm2 n++ (0.43) directly
    // arm1 n++ (Z=-0.07) → rfGnd1 (Z=-0.4)
    // arm2 p++ (Z=0.87) → rfGnd2 (Z=1.2)
    const rfPadY = viaTopY + m1H / 2;
    const gnd1ZCenter = (-0.07 + (-0.4)) / 2;
    const gnd2ZCenter = (0.87 + 1.2) / 2;
    const gndBridgeLen = 0.33;

    const gndBridge1 = createBox({
      size: [1.9, m1H, gndBridgeLen],
      position: [0.5, rfPadY, gnd1ZCenter],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lRf.add(tagPart(gndBridge1, "rfElectrode", false, 4));

    const gndBridge2 = createBox({
      size: [1.9, m1H, gndBridgeLen],
      position: [0.5, rfPadY, gnd2ZCenter],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lRf.add(tagPart(gndBridge2, "rfElectrode", false, 4));

    // Signal-side M1 bars (arm1 p++ at 0.37, arm2 n++ at 0.43) directly under RF signal electrode
    const sigBar1 = createBox({
      size: [1.9, m1H, 0.08],
      position: [0.5, rfPadY, 0.37],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lRf.add(tagPart(sigBar1, "rfElectrode", false, 4));

    const sigBar2 = createBox({
      size: [1.9, m1H, 0.08],
      position: [0.5, rfPadY, 0.43],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lRf.add(tagPart(sigBar2, "rfElectrode", false, 4));

    // Optical path (RX: fiber → GC → waveguide → Ge detector)
    const pathGroup = new THREE.Group();
    const pathY = siSlabTop - siSlabH / 2 + siRibH / 2;
    const gcTopY = siSlabTop + ribRidgeH;
    const pathPoints = [
      new THREE.Vector3(fiberCenterX, fiberBottomY + 0.2, rxZ), // 光纤内
      new THREE.Vector3(fiberCenterX, fiberBottomY, rxZ),        // 光纤端面
      new THREE.Vector3(fiberCenterX, gcTopY, rxZ),              // GC表面
      new THREE.Vector3(-0.5, pathY, rxZ),                       // 波导（转折后）
      new THREE.Vector3(0.5, pathY, rxZ),                        // 波导
      new THREE.Vector3(1.5, pathY, rxZ),                        // 波导（经过环2、环3）
      new THREE.Vector3(geX, pathY, rxZ),                        // Ge探测器（吞吐端）
    ];
    const pathCurve = new THREE.CatmullRomCurve3(pathPoints);
    const pathGeometry = new THREE.TubeGeometry(pathCurve, 64, 0.025, 8, false);
    const pathMesh = new THREE.Mesh(pathGeometry, transparent(0x0891b2, 0.55));
    pathGroup.add(tagPart(pathMesh, "opticalPath"));

    // Animated glow spheres along the path
    const pathGlowSpheres = [];
    for (let i = 0; i < 10; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.038, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      pathGlowSpheres.push({ mesh: glow, offset: i / 10 });
      pathGroup.add(glow);
    }
    chip.add(tagPart(pathGroup, "opticalPath"));

    // WDM drop optical paths — light from bus → ring → drop WG → Ge PD
    const wdmPathGroup = new THREE.Group();
    for (let i = 0; i < 3; i++) {
      const rr = ringR[i];
      const rx = ringXs[i];
      const rz = rxZ + 0.16 + ringGap + rr + 0.035;
      const dropZ = rz + rr + 0.032 + dropLen / 2 + 0.03;
      const geZ = dropZ + dropLen / 2 + dropGeH / 2 + 0.04;
      const pts = [
        new THREE.Vector3(rx, pathY, rxZ),         // bus waveguide
        new THREE.Vector3(rx, pathY, (rxZ + rz - rr) / 2), // mid to ring
        new THREE.Vector3(rx, pathY, rz),           // ring center
        new THREE.Vector3(rx, pathY, dropZ),        // drop waveguide
        new THREE.Vector3(rx, pathY, geZ),           // Ge detector
      ];
      const curve = new THREE.CatmullRomCurve3(pts);
      const geom = new THREE.TubeGeometry(curve, 40, 0.018, 6, false);
      const mesh = new THREE.Mesh(geom, transparent(0x67e8f9, 0.45));
      wdmPathGroup.add(tagPart(mesh, "opticalPath"));
      // glow spheres
      for (let j = 0; j < 5; j++) {
        const glow = new THREE.Mesh(
          new THREE.SphereGeometry(0.028, 8, 4),
          new THREE.MeshBasicMaterial({ color: 0x22d3ee, transparent: true, opacity: 0.45 })
        );
        glow.position.copy(curve.getPointAt(j / 4));
        wdmPathGroup.add(glow);
      }
    }
    chip.add(tagPart(wdmPathGroup, "opticalPath"));

    // Monitor PD tap optical path
    const mpdPathGroup = new THREE.Group();
    const mpdPathY = siSlabTop + ribRidgeH / 2;
    const mpdPts = [
      new THREE.Vector3(ybX, mpdPathY, 0.4),     // Y-branch junction
      new THREE.Vector3(ybX, mpdPathY, ybTapZ),  // tap waveguide
      new THREE.Vector3(ybX, mpdPathY, mpdZ),    // monitor PD
    ];
    const mpdCurve = new THREE.CatmullRomCurve3(mpdPts);
    const mpdGeom = new THREE.TubeGeometry(mpdCurve, 20, 0.015, 6, false);
    mpdPathGroup.add(tagPart(new THREE.Mesh(mpdGeom, transparent(0x67e8f9, 0.4)), "opticalPath"));
    chip.add(tagPart(mpdPathGroup, "opticalPath"));

    // Electrical path (Ge → W via → M1 → bond pad → external)
    const elecGroup = new THREE.Group();
    const m1CenterY = cladTopY + heaterH + m1H / 2;
    const padCenterY = padBaseY + padH / 2;
    const elecPoints = [
      new THREE.Vector3(geX, siSlabTop + geH, rxZ),          // Ge top (start)
      new THREE.Vector3(geX, cladTopY + heaterH, rxZ),       // W via bottom
      new THREE.Vector3(geX, m1CenterY, rxZ),                // M1 over Ge
      new THREE.Vector3(geX, m1CenterY, rxPadZ),             // M1 Z-branch
      new THREE.Vector3(2.8, m1CenterY, rxPadZ),             // M1 X-branch to pad
      new THREE.Vector3(2.8, padCenterY, rxPadZ),            // Bond pad (end)
      new THREE.Vector3(2.8, padCenterY + 0.25, rxPadZ),     // External wire direction
    ];
    const elecCurve = new THREE.CatmullRomCurve3(elecPoints);
    const elecGeometry = new THREE.TubeGeometry(elecCurve, 64, 0.022, 8, false);
    const elecMesh = new THREE.Mesh(elecGeometry, transparent(0xf59e0b, 0.5));
    elecGroup.add(tagPart(elecMesh, "electricalPath"));

    const elecGlowSpheres = [];
    for (let i = 0; i < 8; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0xfcd34d, transparent: true, opacity: 0.5 })
      );
      elecGlowSpheres.push({ mesh: glow, offset: i / 8 });
      elecGroup.add(glow);
    }
    chip.add(tagPart(elecGroup, "electricalPath"));

    // TX RF electrical path (bond pad → RF signal electrode → over MZM phase arms)
    const txeGroup = new THREE.Group();
    const rfCenterY = rfBaseY + rfH / 2;
    const txePoints = [
      new THREE.Vector3(2.8, padCenterY + 0.2, 0.8),     // external (above bond pad)
      new THREE.Vector3(2.8, padCenterY, 0.8),            // bond pad surface
      new THREE.Vector3(2.8, rfCenterY, 0.8),             // via down to RF level
      new THREE.Vector3(2.2, rfCenterY, 0.4),             // Z-bend to RF signal line
      new THREE.Vector3(0.6, rfCenterY, 0.4),             // along RF signal electrode
    ];
    const txeCurve = new THREE.CatmullRomCurve3(txePoints);
    const txeGeometry = new THREE.TubeGeometry(txeCurve, 48, 0.02, 8, false);
    const txeMesh = new THREE.Mesh(txeGeometry, transparent(0xf59e0b, 0.5));
    txeGroup.add(tagPart(txeMesh, "electricalPath"));

    const txeGlowSpheres = [];
    for (let i = 0; i < 6; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.03, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0xfcd34d, transparent: true, opacity: 0.5 })
