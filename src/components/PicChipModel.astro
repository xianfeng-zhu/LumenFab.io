    const txPathCurve1 = new THREE.CatmullRomCurve3(txPathPoints1);
    const txPathCurve2 = new THREE.CatmullRomCurve3(txPathPoints2);
    const txPathGeom1 = new THREE.TubeGeometry(txPathCurve1, 64, 0.022, 8, false);
    const txPathGeom2 = new THREE.TubeGeometry(txPathCurve2, 64, 0.022, 8, false);
