      new THREE.Vector3(-3.73, fiberBottomY, 0.4),
      new THREE.Vector3(-3.73, txPathTopY, 0.4),
      new THREE.Vector3(-0.5, txPathY, 0.4),
      new THREE.Vector3(0.5, txPathY, 0.65),              // phase arm 2
      new THREE.Vector3(1.7, txPathY, 0.4),
      new THREE.Vector3(2.75, txPathY, 0.4),
      new THREE.Vector3(3.73, txPathY, 0.4),
