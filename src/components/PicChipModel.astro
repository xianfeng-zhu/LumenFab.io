---
interface Props {
  title?: string;
  caption?: string;
}

const {
  title = "硅光 PIC 芯片物理结构模型",
  caption = "可旋转模型以透视剖面方式显示硅光 PIC 芯片的纵向层叠结构与关键组件。为便于观察，垂直层厚均经过示意化放大，属于 not to scale 教学模型。"
} = Astro.props;

const legendItems = [
  ["substrate", "#2563eb", "Si 衬底"],
  ["box", "#94a3b8", "BOX 埋氧层"],
  ["siDevice", "#0d9488", "Si 器件层 / 波导"],
  ["geDetector", "#16a34a", "Ge 光电探测器"],
  ["cladding", "#94a3b8", "SiO₂ 上包层"],
  ["heater", "#eab308", "TiN 加热器"],
  ["m1Interconnect", "#f97316", "M1 Cu 互连"],
  ["rfElectrode", "#ef4444", "RF 电极 (GSG)"],
  ["bondPad", "#475569", "Al 焊盘"],
  ["gratingCoupler", "#7c3aed", "光栅耦合器"],
  ["edgeCoupler", "#a855f7", "边缘耦合器"],
  ["opticalPath", "#0891b2", "光信号路径"]
];

const indexItems = [
  ["substrate", "#2563eb", "Si 衬底"],
  ["box", "#94a3b8", "BOX 埋氧层"],
  ["siDevice", "#0d9488", "Si 器件层"],
  ["stripWaveguide", "#14b8a6", "条形波导 (全刻蚀)"],
  ["ribWaveguide", "#0f766e", "脊形波导 (浅刻蚀)"],
  ["geDetector", "#16a34a", "Ge 光电探测器"],
  ["cladding", "#94a3b8", "SiO₂ 上包层"],
  ["heater", "#eab308", "TiN 微加热器"],
  ["m1Interconnect", "#f97316", "M1 互连"],
  ["rfElectrode", "#ef4444", "GSG 行波电极"],
  ["bondPad", "#475569", "Al 焊盘"],
  ["gratingCoupler", "#7c3aed", "光栅耦合器"],
  ["edgeCoupler", "#a855f7", "边缘耦合器端面"],
  ["opticalPath", "#0891b2", "光信号路径"]
];
---

<figure class="pic-model">
  <div class="pic-model__viewport" data-pic-chip-model>
    <canvas aria-label={title}></canvas>
    <div class="pic-model__legend" aria-hidden="true">
      {legendItems.map(([key, color, label]) => (
        <span data-key={key}><i style={`--swatch: ${color}`}></i>{label}</span>
      ))}
    </div>
    <div class="pic-model__controls">
      <div class="pic-model__controls-row">
        <button type="button" class="pic-model__control-btn" data-pic-explode-toggle aria-pressed="false">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 5.5L7 1.5L11 5.5"/>
            <path d="M3 8.5L7 12.5L11 8.5"/>
          </svg>
          <span>分层展开</span>
        </button>
        <button type="button" class="pic-model__control-btn" data-pic-section-toggle aria-pressed="false">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <rect x="1" y="1" width="12" height="12" rx="1"/>
            <line x1="7" y1="1" x2="7" y2="13"/>
          </svg>
          <span>剖面视图</span>
        </button>
      </div>
      <div class="pic-model__slider" data-pic-section-slider-wrap hidden>
        <input type="range" data-pic-section-slider min="-3.8" max="3.8" step="0.05" value="0">
        <span>切面位置</span>
      </div>
    </div>
  </div>
  <div class="pic-model__index" aria-label="3D 模型结构索引">
    {indexItems.map(([key, color, label]) => (
      <button type="button" data-pic-part-index={key} style={`--part-color: ${color}`}>{label}</button>
    ))}
  </div>
  <div class="pic-model__info" data-pic-part-info aria-live="polite">
    <strong data-pic-part-title>结构说明</strong>
    <span data-pic-part-body>选择模型中的结构，或点击下方结构索引，这里会显示它在 PIC 芯片中的作用。</span>
  </div>
  <figcaption>
    <strong>{title}</strong>
    <span>{caption}</span>
  </figcaption>
</figure>

<script>
  import * as THREE from "three";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";

  const roots = document.querySelectorAll("[data-pic-chip-model]");

  const partInfo = {
    substrate: {
      color: "#2563eb",
      title: "Si 衬底 (handle wafer)",
      body: "约 725 μm 厚的单晶硅衬底，提供机械支撑。在高速调制器区域下方通常选用高阻硅 (>750 Ω·cm)，以减少衬底对 RF 信号的损耗。是整个 PIC 芯片的最底层。"
    },
    box: {
      color: "#94a3b8",
      title: "BOX 埋氧层 (buried oxide)",
      body: "约 2 μm 的热氧化 SiO₂。光子 SOI 的 BOX 远厚于电子 SOI (后者仅 50–100 nm)，目的是保证 1550 nm 波段的光学隔离——防止上方的光波导模式泄漏到硅衬底中。"
    },
    siDevice: {
      color: "#0d9488",
      title: "Si 器件层 (220 nm 单晶硅)",
      body: "所有光子器件的「画布」。220 nm 厚的单晶硅层通过三种蚀刻深度（全刻蚀 220 nm、深部分 ~160 nm、浅部分 ~70 nm）形成条形波导、脊形波导和光栅耦合器等结构，同时通过离子注入形成调制器所需的 p-n 结。"
    },
    stripWaveguide: {
      color: "#14b8a6",
      title: "条形波导 (全刻蚀)",
      body: "硅被完全刻穿至 BOX，留下宽约 400–500 nm 的条形波导芯层。光场被强烈约束，弯曲半径可至数微米，用于紧凑布线、微环谐振器和定向耦合器。传播损耗相对较高 (~2–3 dB/cm)，来自全刻蚀侧壁的散射。"
    },
    ribWaveguide: {
      color: "#0f766e",
      title: "脊形波导 (部分刻蚀)",
      body: "仅刻蚀掉部分硅厚度 (~70 nm 或 ~150 nm)，留下一层硅平板。传播损耗更低 (可低于 0.3 dB/cm)，但弯曲半径较大 (数十微米)。用于长距离布线、MMI、调制器相位臂和延迟线。"
    },
    geDetector: {
      color: "#16a34a",
      title: "Ge 光电探测器",
      body: "在指定区域通过 RPCVD 选择性外延生长约 200–500 nm 的单晶锗。光从下方硅波导倏逝耦合进入 Ge 层被吸收，产生电子-空穴对并在偏置电场下形成光电流。Ge 只生长在暴露的硅窗口上，氧化层区域不生长。"
    },
    cladding: {
      color: "#94a3b8",
      title: "SiO₂ 上包层 (ILD)",
      body: "约 1–2 μm 的 PECVD 沉积 SiO₂，覆盖整个芯片表面。它同时承担波导上包层 (光场约束) 和电学隔离层 (防止金属电极吸收光) 的双重角色。加热器的热量也通过此层向下传导至波导。"
    },
    heater: {
      color: "#eab308",
      title: "TiN 微加热器",
      body: "一层专用的 TiN (或 Ni) 金属电阻条，位于波导上方约 1 μm 处。通电后通过 SiO₂ 包层向下传热，利用硅的热光效应 (dn/dT ≈ 1.86×10⁻⁴ K⁻¹) 调节波导的相位或微环的共振波长。单个 π 相移功耗约 10–50 mW。"
    },
    m1Interconnect: {
      color: "#f97316",
      title: "M1 Cu 互连",
      body: "第一层 Cu 金属互连 (~200 nm–1 μm)。提供就近的信号引出——例如为加热器供电、连接 Ge PD 电极——并通过 W 通孔向下连接到硅掺杂区和加热器端点。"
    },
    rfElectrode: {
      color: "#ef4444",
      title: "GSG 行波 RF 电极",
      body: "在 M2 层形成的地-信号-地 (GSG) 共面波导结构，位于调制器波导上方。目标特性阻抗 50 Ω，追求 RF 信号与光信号的群速度匹配以最大化电光带宽。M2 层厚度通常 ~2 μm 以保证 RF 性能。"
    },
    bondPad: {
      color: "#475569",
      title: "Al 焊盘",
      body: "芯片最顶层的 Al 焊盘，通过钝化层开窗暴露。用于引线键合 (wire bonding) 或倒装互连 (flip-chip)，将芯片的直流偏置、RF 信号和控制信号连接到封装或 EIC。"
    },
    gratingCoupler: {
      color: "#7c3aed",
      title: "光栅耦合器",
      body: "利用周期性刻蚀结构，将片上波导中的光向上 (或向下) 衍射到芯片表面外，也可将上方光纤的光耦合进波导。便于晶圆级测试——光纤可以从芯片上方直接访问，无需芯片端面加工。"
    },
    edgeCoupler: {
      color: "#a855f7",
      title: "边缘耦合器端面",
      body: "位于芯片边缘的光学端面，通过反向锥形结构 (inverse taper) 或 SSC 将片上小模场逐步扩展，与光纤的 ~9–10 μm 模场匹配。通常提供更宽的光学带宽和更低的耦合损耗，但需要高质量芯片端面和精密对准。"
    },
    opticalPath: {
      color: "#0891b2",
      title: "光信号路径",
      body: "光从激光源进入 PIC 后，经耦合器进入波导层，在硅器件层中传输、分束、调制、滤波，最终到达 Ge PD 被探测或经输出耦合器离开芯片。这条路径完全位于硅器件层内 (或 SiN 层内)。"
    }
  };

  const partOrder = Object.keys(partInfo);
  const partColor = (key) => Number.parseInt(partInfo[key].color.slice(1), 16);

  const material = (color, options = {}) =>
    new THREE.MeshStandardMaterial({
      color,
      roughness: 0.68,
      metalness: 0,
      ...options
    });

  const transparent = (color, opacity) =>
    material(color, {
      transparent: true,
      opacity,
      depthWrite: false
    });

  function createBox({ size, position, color, opacity = 1, metalness = 0, roughness = 0.68 }) {
    const mat = material(color, {
      transparent: opacity < 1,
      opacity,
      metalness,
      roughness
    });
    const mesh = new THREE.Mesh(new THREE.BoxGeometry(...size), mat);
    mesh.position.set(...position);
    return mesh;
  }

  function createHitBox({ size, position, key, priority = 2 }) {
    const mesh = new THREE.Mesh(
      new THREE.BoxGeometry(...size),
      new THREE.MeshBasicMaterial({
        transparent: true,
        opacity: 0,
        depthWrite: false
      })
    );
    mesh.position.set(...position);
    return tagPart(mesh, key, true, priority);
  }

  function tagPart(object, key, isHitProxy = false, priority = 0) {
    object.userData.partKey = key;
    object.userData.hitProxy = isHitProxy;
    object.userData.selectionPriority = priority;
    object.traverse((child) => {
      child.userData.partKey = key;
      child.userData.hitProxy = isHitProxy;
      child.userData.selectionPriority = priority;
    });
    return object;
  }

  function buildModel(scene) {
    const chip = new THREE.Group();
    scene.add(chip);

    const chipLen = 7.5;
    const chipWidth = 5.0;

    // ---- Layer groups for explode view ----
    const layerGroups = [];
    function addLayer(key) {
      const group = new THREE.Group();
      group.userData.layerKey = key;
      group.userData.layerIndex = layerGroups.length;
      layerGroups.push(group);
      chip.add(group);
      return group;
    }

    const lSubstrate = addLayer("substrate");
    const lBox = addLayer("box");
    const lSiDevice = addLayer("siDevice");
    const lGeDetector = addLayer("geDetector");
    const lCladding = addLayer("cladding");
    const lHeater = addLayer("heater");
    const lM1 = addLayer("m1Interconnect");
    const lRf = addLayer("rfElectrode");
    const lTop = addLayer("topLayer");

    let yBase = 0;

    // === Layer 1: Si substrate ===
    const substrateH = 1.2;
    const substrate = createBox({
      size: [chipLen, substrateH, chipWidth],
      position: [0, yBase + substrateH / 2, 0],
      color: 0x2563eb,
      roughness: 0.78,
      metalness: 0
    });
    lSubstrate.add(tagPart(substrate, "substrate"));
    yBase += substrateH;

    // === Layer 2: BOX ===
    const boxH = 0.25;
    const box = createBox({
      size: [chipLen, boxH, chipWidth],
      position: [0, yBase + boxH / 2, 0],
      color: 0x94a3b8,
      roughness: 0.5,
      metalness: 0
    });
    lBox.add(tagPart(box, "box"));
    yBase += boxH;

    // === Layer 3: Si device layer ===
    const siBase = yBase;
    const siFullH = 0.34;
    const siSlabH = 0.19;
    const siRibH = 0.26;

    const siSlab = createBox({
      size: [chipLen, siSlabH, chipWidth],
      position: [0, yBase + siSlabH / 2, 0],
      color: 0x0d9488,
      roughness: 0.48,
      metalness: 0.08,
      opacity: 0.85
    });
    lSiDevice.add(tagPart(siSlab, "siDevice"));

    const siSlabTop = yBase + siSlabH;

    // Strip waveguides
    const stripRidgeH = siFullH - siSlabH;
    const stripWidth = 0.06;
    for (let z = -1.5; z <= 1.5; z += 0.55) {
      const stripWG = createBox({
        size: [chipLen - 0.4, stripRidgeH, stripWidth],
        position: [0, siSlabTop + stripRidgeH / 2, z],
        color: 0x14b8a6,
        roughness: 0.42,
        metalness: 0.12
      });
      lSiDevice.add(tagPart(stripWG, "stripWaveguide", false, 4));
    }

    // Rib waveguide — right segment (does not pass through grating coupler region)
    const ribRidgeH = siRibH - siSlabH;
    const gcRightEdge = -2.4 + 6 * 0.16 + 0.05 / 2; // ~-1.415
    const ribStartX = -0.9;
    const ribEndX = chipLen / 2 - 0.3;
    const ribRightLen = ribEndX - ribStartX;
    const ribRightCenter = (ribStartX + ribEndX) / 2;

    const ribWG = createBox({
      size: [ribRightLen, ribRidgeH, 0.32],
      position: [ribRightCenter, siSlabTop + ribRidgeH / 2, 1.45],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(ribWG, "ribWaveguide", false, 4));

    // Connector from grating coupler to rib waveguide
    const connLen = ribStartX - gcRightEdge;
    const connCenterX = (gcRightEdge + ribStartX) / 2;
    const conn = createBox({
      size: [connLen, ribRidgeH, 0.32],
      position: [connCenterX, siSlabTop + ribRidgeH / 2, 1.45],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(conn, "ribWaveguide", false, 4));

    const siTopY = siSlabTop + stripRidgeH;
    yBase = siBase + siSlabH;

    // === Layer 4: Ge photodetector ===
    const geH = 0.18;
    const geX = 1.0;
    const geDetector = createBox({
      size: [1.2, geH, 0.5],
      position: [geX, siSlabTop + geH / 2, 1.45],
      color: 0x16a34a,
      roughness: 0.38,
      metalness: 0.08
    });
    lGeDetector.add(tagPart(geDetector, "geDetector", false, 5));

    // === Layer 5: Cladding ===
    const cladH = 0.65;
    const claddingFull = createBox({
      size: [chipLen, cladH, chipWidth],
      position: [0, siTopY + cladH / 2, 0],
      color: 0x94a3b8,
      roughness: 0.6,
      metalness: 0,
      opacity: 0.58
    });
    claddingFull.material.depthWrite = false;
    lCladding.add(tagPart(claddingFull, "cladding"));

    const cladTopY = siTopY + cladH;

    // === Layer 6: Heater ===
    const heaterH = 0.06;
    const heater = createBox({
      size: [2.8, heaterH, 0.1],
      position: [0.6, cladTopY + heaterH / 2, 1.45],
      color: 0xeab308,
      metalness: 0.5,
      roughness: 0.3
    });
    lHeater.add(tagPart(heater, "heater", false, 5));

    // === Layer 7: M1 interconnect ===
    const m1H = 0.09;
    const m1Line = createBox({
      size: [1.6, m1H, 0.12],
      position: [geX, cladTopY + heaterH + m1H / 2, 1.45],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lM1.add(tagPart(m1Line, "m1Interconnect", false, 4));

    const m1HeaterConn = createBox({
      size: [0.4, m1H, 0.08],
      position: [0.6, cladTopY + heaterH + m1H / 2, 1.15],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lM1.add(tagPart(m1HeaterConn, "m1Interconnect", false, 4));

    // === Layer 8: RF electrodes ===
    const rfH = 0.18;
    const rfBaseY = cladTopY + heaterH + m1H;

    const rfSignal = createBox({
      size: [3.2, rfH, 0.12],
      position: [0.6, rfBaseY + rfH / 2, 0.4],
      color: 0xef4444,
      metalness: 0.7,
      roughness: 0.18
    });
    lRf.add(tagPart(rfSignal, "rfElectrode", false, 4));

    const rfGnd1 = createBox({
      size: [3.2, rfH, 0.12],
      position: [0.6, rfBaseY + rfH / 2, -0.4],
      color: 0xdc2626,
      metalness: 0.7,
      roughness: 0.18
    });
    const rfGnd2 = createBox({
      size: [3.2, rfH, 0.12],
      position: [0.6, rfBaseY + rfH / 2, 1.2],
      color: 0xdc2626,
      metalness: 0.7,
      roughness: 0.18
    });
    lRf.add(tagPart(rfGnd1, "rfElectrode"), tagPart(rfGnd2, "rfElectrode"));

    // === ILD cover over metal structures ===
    // In a real PIC, heater / M1 / RF electrodes are embedded in SiO₂ ILD,
    // not exposed to air. A semi-transparent cover layer eliminates the
    // "floating" visual artefacts above the cladding.
    const ildCoverH = 0.38;
    const ildCover = createBox({
      size: [chipLen - 0.08, ildCoverH, chipWidth - 0.08],
      position: [0, cladTopY + ildCoverH / 2, 0],
      color: 0x94a3b8,
      roughness: 0.6,
      metalness: 0,
      opacity: 0.58
    });
    ildCover.material.depthWrite = false;
    lTop.add(tagPart(ildCover, "cladding"));

    // === Layer 9: Bond pads ===
    const padH = 0.1;
    const padBaseY = rfBaseY + rfH;
    const padPositions = [
      [-3.0, 1.8], [-3.0, 0.8], [-3.0, -0.2],
      [2.8, 1.8], [2.8, 0.8]
    ];
    for (const [px, pz] of padPositions) {
      const pad = createBox({
        size: [0.35, padH, 0.35],
        position: [px, padBaseY + padH / 2, pz],
        color: 0x475569,
        metalness: 0.55,
        roughness: 0.28
      });
      lTop.add(tagPart(pad, "bondPad"));
    }

    // Reference point for incoming optical path (fiber tip above GC)
    const fiberCenterX = -2.32;
    const fiberBottomY = padBaseY + padH + 0.05;

    // Grating coupler — 与 rib 波导同高度的周期性刻蚀结构
    const gcGroup = new THREE.Group();
    const gcPeriod = 0.16;
    const gcY = siSlabTop + ribRidgeH / 2;
    for (let i = -6; i <= 6; i++) {
      const gcTooth = createBox({
        size: [0.05, ribRidgeH, 0.55],
        position: [-2.4 + i * gcPeriod, gcY, 1.45],
        color: 0x7c3aed,
        roughness: 0.35,
        metalness: 0.25
      });
      gcGroup.add(tagPart(gcTooth, "gratingCoupler", false, 5));
    }
    lSiDevice.add(tagPart(gcGroup, "gratingCoupler"));

    // Edge coupler facet
    const edgeCoupler = createBox({
      size: [0.08, siRibH + 0.06, 0.6],
      position: [chipLen / 2 - 0.02, siSlabTop - siSlabH / 2 + siRibH / 2 + 0.04, 1.8],
      color: 0xa855f7,
      roughness: 0.4,
      metalness: 0.15,
      opacity: 0.7
    });
    lSiDevice.add(tagPart(edgeCoupler, "edgeCoupler", false, 5));

    // Optical path (RX: fiber → GC → waveguide → Ge detector)
    const pathGroup = new THREE.Group();
    const pathY = siSlabTop - siSlabH / 2 + siRibH / 2;
    const gcTopY = siSlabTop + ribRidgeH;
    const pathPoints = [
      new THREE.Vector3(fiberCenterX, fiberBottomY + 0.2, 1.45), // 光纤内
      new THREE.Vector3(fiberCenterX, fiberBottomY, 1.45),        // 光纤端面
      new THREE.Vector3(fiberCenterX, gcTopY, 1.45),              // GC表面
      new THREE.Vector3(-0.5, pathY, 1.45),                       // 波导（转折后）
      new THREE.Vector3(0.5, pathY, 1.45),                        // 波导
      new THREE.Vector3(geX, pathY, 1.45),                        // Ge探测器
    ];
    const pathCurve = new THREE.CatmullRomCurve3(pathPoints);
    const pathGeometry = new THREE.TubeGeometry(pathCurve, 64, 0.025, 8, false);
    const pathMesh = new THREE.Mesh(pathGeometry, transparent(0x0891b2, 0.55));
    pathGroup.add(tagPart(pathMesh, "opticalPath"));

    // Animated glow spheres along the path
    const pathGlowSpheres = [];
    for (let i = 0; i < 10; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.038, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      pathGlowSpheres.push({ mesh: glow, offset: i / 10 });
      pathGroup.add(glow);
    }
    chip.add(tagPart(pathGroup, "opticalPath"));

    // Hit targets — organised by layer so they move with explode view
    const largeHitTargets = [
      { key: "substrate", size: [chipLen - 0.3, substrateH + 0.08, chipWidth - 0.3], position: [0, substrateH / 2, 0], priority: 2 },
      { key: "box", size: [chipLen - 0.3, boxH + 0.08, chipWidth - 0.3], position: [0, substrateH + boxH / 2, 0], priority: 2 },
      { key: "siDevice", size: [chipLen - 0.3, siSlabH + 0.08, chipWidth - 0.3], position: [0, siBase + siSlabH / 2, 0], priority: 2 },
      { key: "stripWaveguide", size: [chipLen - 0.2, stripRidgeH + 0.14, 0.4], position: [0, siSlabTop + stripRidgeH / 2 + 0.02, 0], priority: 5 },
      { key: "ribWaveguide", size: [5.0, ribRidgeH + 0.14, 0.5], position: [1.0, siSlabTop + ribRidgeH / 2, 1.45], priority: 5 },
      { key: "geDetector", size: [1.5, geH + 0.1, 0.7], position: [geX, siSlabTop + geH / 2, 1.45], priority: 6 },
      { key: "heater", size: [3.0, heaterH + 0.12, 0.3], position: [0.6, cladTopY + heaterH / 2 + 0.02, 1.45], priority: 6 },
      { key: "m1Interconnect", size: [1.8, m1H + 0.12, 0.4], position: [geX, cladTopY + heaterH + m1H / 2 + 0.04, 1.45], priority: 5 },
      { key: "rfElectrode", size: [3.4, rfH + 0.14, 1.6], position: [0.6, rfBaseY + rfH / 2, 0.4], priority: 5 },
      { key: "gratingCoupler", size: [2.2, 0.1, 0.7], position: [-2.4, siSlabTop + ribRidgeH / 2, 1.45], priority: 6 },
      { key: "edgeCoupler", size: [0.2, siRibH + 0.2, 0.8], position: [chipLen / 2 - 0.02, siSlabTop - siSlabH / 2 + siRibH / 2 + 0.04, 1.8], priority: 6 },
      { key: "cladding", size: [chipLen - 0.3, cladH + 0.04, chipWidth - 0.3], position: [0, siTopY + cladH / 2, 0], priority: 1 },
    ];

    const hitTargetLayerMap = {
      substrate: lSubstrate, box: lBox, siDevice: lSiDevice,
      stripWaveguide: lSiDevice, ribWaveguide: lSiDevice,
      geDetector: lGeDetector, cladding: lCladding,
      heater: lHeater, m1Interconnect: lM1,
      rfElectrode: lRf, gratingCoupler: lSiDevice, edgeCoupler: lSiDevice
    };

    for (const target of largeHitTargets) {
      const layer = hitTargetLayerMap[target.key] || lTop;
      layer.add(createHitBox(target));
    }

    // Center the model
    const outline = new THREE.Box3().setFromObject(chip);
    const center = outline.getCenter(new THREE.Vector3());
    for (const child of chip.children) {
      child.position.sub(center);
    }

    // Record base Y for each layer group (after centering)
    for (const group of layerGroups) {
      group.userData.baseY = group.position.y;
    }

    chip.rotation.x = -0.22;
    chip.rotation.y = -0.45;

    return { chip, layerGroups, pathCurve, pathGlowSpheres };
  }

  for (const root of roots) {
    const canvas = root.querySelector("canvas");
    const figure = root.closest(".pic-model");
    const infoTitle = figure?.querySelector("[data-pic-part-title]");
    const infoBody = figure?.querySelector("[data-pic-part-body]");
    const indexButtons = figure?.querySelectorAll("[data-pic-part-index]") || [];

    // Controls
    const explodeBtn = figure?.querySelector("[data-pic-explode-toggle]");
    const sectionBtn = figure?.querySelector("[data-pic-section-toggle]");
    const sectionSliderWrap = figure?.querySelector("[data-pic-section-slider-wrap]");
    const sectionSlider = figure?.querySelector("[data-pic-section-slider]");

    const scene = new THREE.Scene();
    scene.background = null;

    const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 100);
    camera.position.set(4.2, 4.8, 5.8);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
      preserveDrawingBuffer: true,
      powerPreference: "high-performance"
    });
    renderer.setClearColor(0x000000, 0);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.enableRotate = true;
    controls.dampingFactor = 0.08;
    controls.rotateSpeed = 0.75;
    controls.minDistance = 0.35;
    controls.maxDistance = 80;
    controls.minPolarAngle = 0.01;
    controls.maxPolarAngle = Math.PI - 0.01;
    controls.target.set(0, 0, 0);

    scene.add(new THREE.HemisphereLight(0xffffff, 0xdbeafe, 2.45));
    const key = new THREE.DirectionalLight(0xffffff, 2.25);
    key.position.set(3, 5, 4);
    scene.add(key);
    const fill = new THREE.DirectionalLight(0xbfdbfe, 1.1);
    fill.position.set(-4, 2, -3);
    scene.add(fill);
    // Rim light for layer-edge definition
    const rim = new THREE.DirectionalLight(0xa5f3fc, 0.6);
    rim.position.set(0, -3, 5);
    scene.add(rim);

    const { chip, layerGroups, pathCurve, pathGlowSpheres } = buildModel(scene);

    // ---- Section / clipping plane ----
    const clippingPlane = new THREE.Plane(new THREE.Vector3(1, 0, 0), 0);
    const sectionNormal = new THREE.Vector3(1, 0, 0);
    sectionNormal.applyEuler(chip.rotation);
    clippingPlane.normal.copy(sectionNormal);
    renderer.localClippingEnabled = true;

    const raycaster = new THREE.Raycaster();
    const pointer = new THREE.Vector2();
    let selectedPart = "";
    let pointerDownState = null;
    const dragSelectionThreshold = 5;
    const referenceOpacity = 0.16;

    // Explode & section state
    let isExploded = false;
    let isSectionView = false;
    const explodeGap = 0.6;
    const sectionSpeed = 0.08;

    const setSelectedPart = (partKey) => {
      if (!partKey || !partInfo[partKey] || !infoTitle || !infoBody) return;
      if (selectedPart === partKey) {
        clearSelectedPart();
        return;
      }
      selectedPart = partKey;
      infoTitle.textContent = partInfo[partKey].title;
      infoTitle.style.setProperty("--part-title-color", partInfo[partKey].color);
      infoBody.textContent = partInfo[partKey].body;

      for (const button of indexButtons) {
        const buttonPart = button.getAttribute("data-pic-part-index");
        button.style.setProperty("--part-color", partInfo[buttonPart]?.color || "var(--border)");
        button.setAttribute("aria-pressed", String(buttonPart === partKey));
      }

      dimNonSelectedParts(partKey);
    };

    const storeBaseMaterial = (object) => {
      if (!object.material) return;
      const mat = object.material;
      if (object.userData.baseMaterialStored) return;
      object.userData.baseMaterialStored = true;
      object.userData.baseOpacity = mat.opacity ?? 1;
      object.userData.baseTransparent = !!mat.transparent;
      object.userData.baseDepthWrite = mat.depthWrite;
      object.userData.baseColor = mat.color?.getHex();
      object.userData.baseEmissive = mat.emissive?.getHex();
    };

    const requestMaterialUpdate = (mat) => { mat.needsUpdate = true; };

    const dimNonSelectedParts = (partKey) => {
      chip.traverse((object) => {
        if (!object.material || !object.userData.partKey) return;
        storeBaseMaterial(object);
        if (object.userData.hitProxy) {
          object.material.opacity = 0;
          object.material.transparent = true;
          requestMaterialUpdate(object.material);
          return;
        }

        const isSelected = object.userData.partKey === partKey;
        const targetOpacity = isSelected
          ? Math.min(1, Math.max(object.userData.baseOpacity ?? 1, 0.82))
          : Math.min(object.userData.baseOpacity ?? 1, referenceOpacity);

        if (isSelected) {
          if (object.material.color) {
            object.material.color.set(partColor(partKey));
            object.material.color.multiplyScalar(0.72);
          }
          object.material.opacity = targetOpacity;
          object.material.transparent = object.userData.baseTransparent || object.material.opacity < 1;
          if (typeof object.userData.baseDepthWrite === "boolean") {
            object.material.depthWrite = object.userData.baseDepthWrite;
          }
          if (object.material.emissive) {
            object.material.emissive.setHex(partColor(partKey));
            object.material.emissiveIntensity = 0.08;
          }
          requestMaterialUpdate(object.material);
        } else {
          if (object.material.color && object.userData.baseColor !== undefined) {
            object.material.color.setHex(object.userData.baseColor);
          }
          object.material.opacity = targetOpacity;
          object.material.transparent = true;
          object.material.depthWrite = false;
          if (object.material.emissive) {
            object.material.emissive.setHex(object.userData.baseEmissive ?? 0x000000);
            object.material.emissiveIntensity = 0;
          }
          requestMaterialUpdate(object.material);
        }
      });
    };

    const clearSelectedPart = () => {
      selectedPart = "";
      infoTitle.textContent = "结构说明";
      infoTitle.style.removeProperty("--part-title-color");
      infoBody.textContent = "选择模型中的结构，或点击下方结构索引，这里会显示它在 PIC 芯片中的作用。";

      for (const button of indexButtons) {
        const buttonPart = button.getAttribute("data-pic-part-index");
        button.style.setProperty("--part-color", partInfo[buttonPart]?.color || "var(--border)");
        button.setAttribute("aria-pressed", "false");
      }

      chip.traverse((object) => {
        if (!object.material || !object.userData.partKey) return;
        storeBaseMaterial(object);
        object.material.opacity = object.userData.hitProxy ? 0 : (object.userData.baseOpacity ?? 1);
        object.material.transparent = object.userData.hitProxy ? true : object.userData.baseTransparent;
        if (typeof object.userData.baseDepthWrite === "boolean") {
          object.material.depthWrite = object.userData.baseDepthWrite;
        }
        if (object.material.color && object.userData.baseColor !== undefined) {
          object.material.color.setHex(object.userData.baseColor);
        }
        if (object.material.emissive && object.userData.baseEmissive !== undefined) {
          object.material.emissive.setHex(object.userData.baseEmissive);
          object.material.emissiveIntensity = 0;
        }
        requestMaterialUpdate(object.material);
      });
    };

    const findPartHit = (hits) =>
      hits
        .filter((item) => item.object.userData.partKey)
        .sort((a, b) => {
          const priorityDelta = (b.object.userData.selectionPriority || 0) - (a.object.userData.selectionPriority || 0);
          return priorityDelta || a.distance - b.distance;
        })[0];

    const pickPart = (event) => {
      const bounds = renderer.domElement.getBoundingClientRect();
      pointer.x = ((event.clientX - bounds.left) / bounds.width) * 2 - 1;
      pointer.y = -((event.clientY - bounds.top) / bounds.height) * 2 + 1;
      raycaster.setFromCamera(pointer, camera);
      const hits = raycaster.intersectObject(chip, true);
      const hit = findPartHit(hits);
      if (hit) setSelectedPart(hit.object.userData.partKey);
    };

    const handlePointerDown = (event) => {
      if (event.button !== 0) return;
      pointerDownState = {
        pointerId: event.pointerId,
        x: event.clientX,
        y: event.clientY
      };
      renderer.domElement.style.cursor = "grabbing";
    };

    const handlePointerUp = (event) => {
      if (!pointerDownState) return;
      const distance = Math.hypot(
        event.clientX - pointerDownState.x,
        event.clientY - pointerDownState.y
      );
      const wasDragging = distance > dragSelectionThreshold;
      pointerDownState = null;
      if (wasDragging) {
        updateCursor(event);
        return;
      }
      pickPart(event);
    };

    const clearPointerDownState = () => { pointerDownState = null; };

    const updateCursor = (event) => {
      if (pointerDownState) {
        const distance = Math.hypot(
          event.clientX - pointerDownState.x,
          event.clientY - pointerDownState.y
        );
        if (distance > dragSelectionThreshold) {
          renderer.domElement.style.cursor = "grabbing";
          return;
        }
      }

      const bounds = renderer.domElement.getBoundingClientRect();
      pointer.x = ((event.clientX - bounds.left) / bounds.width) * 2 - 1;
      pointer.y = -((event.clientY - bounds.top) / bounds.height) * 2 + 1;
      raycaster.setFromCamera(pointer, camera);
      const hit = findPartHit(raycaster.intersectObject(chip, true));
      renderer.domElement.style.cursor = hit ? "pointer" : "grab";
    };

    renderer.domElement.addEventListener("pointerdown", handlePointerDown);
    renderer.domElement.addEventListener("pointerup", handlePointerUp);
    renderer.domElement.addEventListener("pointercancel", clearPointerDownState);
    renderer.domElement.addEventListener("pointerleave", clearPointerDownState);
    renderer.domElement.addEventListener("pointermove", updateCursor);

    const indexClickHandlers = [];
    for (const button of indexButtons) {
      const buttonPart = button.getAttribute("data-pic-part-index");
      button.style.setProperty("--part-color", partInfo[buttonPart]?.color || "var(--border)");
      const handler = () => setSelectedPart(button.getAttribute("data-pic-part-index"));
      button.addEventListener("click", handler);
      indexClickHandlers.push([button, handler]);
    }

    // ---- Explode toggle ----
    const handleExplodeToggle = () => {
      isExploded = !isExploded;
      if (explodeBtn) {
        explodeBtn.setAttribute("aria-pressed", String(isExploded));
      }
    };
    explodeBtn?.addEventListener("click", handleExplodeToggle);

    // ---- Section toggle ----
    const handleSectionToggle = () => {
      isSectionView = !isSectionView;
      if (sectionBtn) {
        sectionBtn.setAttribute("aria-pressed", String(isSectionView));
      }
      if (sectionSliderWrap) {
        sectionSliderWrap.hidden = !isSectionView;
      }
    };
    sectionBtn?.addEventListener("click", handleSectionToggle);

    let sectionSliderValue = 0;
    const handleSectionSlider = () => {
      sectionSliderValue = parseFloat(sectionSlider?.value ?? 0);
    };
    sectionSlider?.addEventListener("input", handleSectionSlider);

    const resize = () => {
      const { width } = root.getBoundingClientRect();
      const canvasHeight = Math.max(400, Math.min(640, width * 0.64));
      root.style.setProperty("--model-height", `${canvasHeight}px`);
      renderer.setSize(width, canvasHeight, false);
      camera.aspect = width / canvasHeight;
      camera.updateProjectionMatrix();
    };

    const observer = new ResizeObserver(resize);
    observer.observe(root);
    resize();

    let frame = 0;
    const animate = () => {
      frame = requestAnimationFrame(animate);
      const time = performance.now() * 0.001;

      // Explode animation (smooth lerp)
      const explodeTarget = isExploded ? explodeGap : 0;
      for (let i = 0; i < layerGroups.length; i++) {
        const current = layerGroups[i].userData.explodeY || 0;
        const target = i * explodeTarget;
        const newVal = current + (target - current) * sectionSpeed;
        layerGroups[i].userData.explodeY = newVal;
        layerGroups[i].position.y = (layerGroups[i].userData.baseY || 0) + newVal;
      }

      // Section clipping plane
      if (isSectionView) {
        renderer.clippingPlanes = [clippingPlane];
        clippingPlane.constant = -sectionSliderValue;
      } else {
        renderer.clippingPlanes = [];
      }

      // Optical path glow animation (vertical: fiber → GC surface)
      if (pathGlowSpheres) {
        for (const item of pathGlowSpheres) {
          const t = (item.offset + time * 0.18) % 1;
          const pt = pathCurve.getPointAt(t);
          item.mesh.position.copy(pt);
          const fade = Math.sin(t * Math.PI);
          item.mesh.material.opacity = 0.25 + 0.55 * fade;
          const s = 0.7 + 0.45 * fade;
          item.mesh.scale.setScalar(s);
        }
      }

      controls.update();
      renderer.render(scene, camera);
    };
    animate();

    document.addEventListener("astro:before-swap", () => {
      cancelAnimationFrame(frame);
      observer.disconnect();
      renderer.domElement.removeEventListener("pointerdown", handlePointerDown);
      renderer.domElement.removeEventListener("pointerup", handlePointerUp);
      renderer.domElement.removeEventListener("pointercancel", clearPointerDownState);
      renderer.domElement.removeEventListener("pointerleave", clearPointerDownState);
      renderer.domElement.removeEventListener("pointermove", updateCursor);
      for (const [button, handler] of indexClickHandlers) {
        button.removeEventListener("click", handler);
      }
      explodeBtn?.removeEventListener("click", handleExplodeToggle);
      sectionBtn?.removeEventListener("click", handleSectionToggle);
      sectionSlider?.removeEventListener("input", handleSectionSlider);
      controls.dispose();
      renderer.dispose();
    }, { once: true });
  }
</script>

