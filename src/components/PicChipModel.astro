    const txEdgePathCurve1 = new THREE.CatmullRomCurve3(txEdgePathPoints1);
    const txEdgePathCurve2 = new THREE.CatmullRomCurve3(txEdgePathPoints2);
    const txEdgePathGeom1 = new THREE.TubeGeometry(txEdgePathCurve1, 64, 0.022, 8, false);
    const txEdgePathGeom2 = new THREE.TubeGeometry(txEdgePathCurve2, 64, 0.022, 8, false);
    txPathGroup.add(tagPart(new THREE.Mesh(txEdgePathGeom1, txPathMat.clone()), "opticalPath"));
    txPathGroup.add(tagPart(new THREE.Mesh(txEdgePathGeom2, txPathMat.clone()), "opticalPath"));

    const txEdgeGlowSpheres1 = [];
    const txEdgeGlowSpheres2 = [];
    for (let i = 0; i < 8; i++) {
      const glow1 = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      txEdgeGlowSpheres1.push({ mesh: glow1, offset: i / 8 });
      txPathGroup.add(glow1);

      const glow2 = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      txEdgeGlowSpheres2.push({ mesh: glow2, offset: i / 8 });
      txPathGroup.add(glow2);
    }
    // TX output GC optical path (waveguide → Z-branch → GC → upward out of chip)
    const txOutGcPathPoints = [
      new THREE.Vector3(2.2, txPathY, 0.4),              // TX output waveguide (junction)
      new THREE.Vector3(2.2, txPathY, 0),                // middle of Z-branch
      new THREE.Vector3(2.2, txPathY, -0.4),             // GC surface
      new THREE.Vector3(2.2, txPathTopY, -0.4),          // above GC
      new THREE.Vector3(2.2, fiberBottomY, -0.4),        // fiber end
      new THREE.Vector3(2.2, fiberBottomY + 0.2, -0.4),  // above fiber
