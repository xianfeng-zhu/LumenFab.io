    const txOutGcPathCurve = new THREE.CatmullRomCurve3(txOutGcPathPoints);
    const txOutGcPathGeom = new THREE.TubeGeometry(txOutGcPathCurve, 48, 0.022, 8, false);
    const txOutGcPathMesh = new THREE.Mesh(txOutGcPathGeom, txPathMat.clone());
    txPathGroup.add(tagPart(txOutGcPathMesh, "opticalPath"));

    const txOutGcGlowSpheres = [];
    for (let i = 0; i < 6; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      txOutGcGlowSpheres.push({ mesh: glow, offset: i / 6 });
      txPathGroup.add(glow);
    }

    chip.add(tagPart(txPathGroup, "opticalPath"));

    // === Labels (face-attached planes) ===
    const faceZ = new THREE.Vector3(0, 0, 1);   // +Z side face
    const faceTop = new THREE.Vector3(0, 1, 0); // top face
    const eps = 0.025; // slight offset above surface
    const sideZ = chipWidth / 2 + eps;
    const wgTopY = siSlabTop + ribRidgeH + eps;

    // Vertical layer stack — +Z side face
    lSubstrate.add(createFaceLabel("Si 衬底", new THREE.Vector3(0, substrateH / 2, sideZ), faceZ, { scale: 0.12 }));
    lBox.add(createFaceLabel("BOX 埋氧层", new THREE.Vector3(0, substrateH + boxH / 2, sideZ), faceZ, { scale: 0.08 }));
    lSiDevice.add(createFaceLabel("Si 器件层", new THREE.Vector3(0, substrateH + boxH + siSlabH / 2, sideZ), faceZ, { scale: 0.08 }));
    lCladding.add(createFaceLabel("SiO₂ 上包层", new THREE.Vector3(0, siTopY + cladH / 2, sideZ), faceZ, { scale: 0.11 }));

    // Waveguides — top face
    lSiDevice.add(createFaceLabel("TX 脊形波导", new THREE.Vector3(-2.6, wgTopY, 0.4), faceTop, { scale: 0.10 }));
    lSiDevice.add(createFaceLabel("RX 脊形波导", new THREE.Vector3(1.8, wgTopY, rxZ), faceTop, { scale: 0.10 }));

    // MMI & MZM — top face
    lSiDevice.add(createFaceLabel("MMI 分束器", new THREE.Vector3(-0.7, wgTopY, 0.4), faceTop, { scale: 0.10 }));
    lSiDevice.add(createFaceLabel("MMI 合束器", new THREE.Vector3(1.7, wgTopY, 0.4), faceTop, { scale: 0.10 }));
    lSiDevice.add(createFaceLabel("MZM 相位臂", new THREE.Vector3(0.5, wgTopY, 0.15), faceTop, { scale: 0.08 }));
    lSiDevice.add(createFaceLabel("MZM 相位臂", new THREE.Vector3(0.5, wgTopY, 0.65), faceTop, { scale: 0.08 }));

    // Y-branch
    lSiDevice.add(createFaceLabel("Y 分支", new THREE.Vector3(ybX, wgTopY, 0.4), faceTop, { scale: 0.08 }));
    // Monitor PD
    lGeDetector.add(createFaceLabel("监测 PD", new THREE.Vector3(mpdX, siSlabTop + mpdH + eps, mpdZ), faceTop, { scale: 0.07 }));

    // Directional coupler
    lSiDevice.add(createFaceLabel("定向耦合器", new THREE.Vector3(dcX, wgTopY, 0.4), faceTop, { scale: 0.08 }));

    // Microring resonators
    for (let i = 0; i < 3; i++) {
      const rr = ringR[i];
      const rx = ringXs[i];
      const rz = rxZ + 0.16 + ringGap + rr + 0.035;
      lSiDevice.add(createFaceLabel("λ" + (i + 1) + " 微环", new THREE.Vector3(rx, wgTopY, rz + rr + 0.06), faceTop, { scale: 0.07 }));
      // Ge PD label on each drop
      const dropZ = rz + rr + 0.032 + dropLen / 2 + 0.03;
      const geZ = dropZ + dropLen / 2 + dropGeH / 2 + 0.04;
      lGeDetector.add(createFaceLabel("Ge PD", new THREE.Vector3(rx, siSlabTop + dropGeH + eps, geZ), faceTop, { scale: 0.06 }));
