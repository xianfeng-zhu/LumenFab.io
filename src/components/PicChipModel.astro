    txPathGroup.add(tagPart(new THREE.Mesh(txPathGeom2, txPathMat.clone()), "opticalPath"));

    // GC-based glow spheres
    const txGlowSpheres1 = [];
    const txGlowSpheres2 = [];
    for (let i = 0; i < 8; i++) {
      const glow1 = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
