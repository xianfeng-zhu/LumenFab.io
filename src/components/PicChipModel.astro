---
interface Props {
  title?: string;
  caption?: string;
}

const {
  title = "硅光 PIC 芯片物理结构模型",
  caption = "可旋转模型以透视剖面方式显示硅光 PIC 芯片的纵向层叠结构与关键组件。为便于观察，垂直层厚均经过示意化放大，属于 not to scale 教学模型。"
} = Astro.props;

const indexItems = [
  ["substrate", "#2563eb", "Si 衬底"],
  ["box", "#94a3b8", "BOX 埋氧层"],
  ["siDevice", "#0d9488", "Si 器件层"],
  ["cladding", "#94a3b8", "SiO₂ 上包层"],
  ["stripWaveguide", "#14b8a6", "条形波导 (全刻蚀)"],
  ["ribWaveguide", "#0f766e", "脊形波导 (浅刻蚀)"],
  ["mmiWaveguide", "#2dd4bf", "MMI 多模区 (深部分刻蚀)"],
  ["doping", "#1d4ed8", "PN 结掺杂区"],
  ["geDetector", "#16a34a", "Ge 光电探测器"],
  ["heater", "#eab308", "TiN 微加热器"],
  ["m1Interconnect", "#f97316", "M1 互连"],
  ["rfElectrode", "#ef4444", "GSG 行波电极"],
  ["bondPad", "#475569", "Al 焊盘"],
  ["gratingCoupler", "#7c3aed", "光栅耦合器"],
  ["edgeCoupler", "#a855f7", "边缘耦合器端面"],
  ["opticalPath", "#0891b2", "光信号路径"],
  ["electricalPath", "#f59e0b", "电信号路径"]
];
---

<figure class="pic-model">
  <div class="pic-model__viewport" data-pic-chip-model>
    <canvas aria-label={title}></canvas>
    <div class="pic-model__controls">
      <div class="pic-model__controls-row">
        <button type="button" class="pic-model__control-btn" data-pic-explode-toggle aria-pressed="false">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 5.5L7 1.5L11 5.5"/>
            <path d="M3 8.5L7 12.5L11 8.5"/>
          </svg>
          <span>分层展开</span>
        </button>
        <button type="button" class="pic-model__control-btn" data-pic-section-toggle aria-pressed="false">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <rect x="1" y="1" width="12" height="12" rx="1"/>
            <line x1="7" y1="1" x2="7" y2="13"/>
          </svg>
          <span>剖面视图</span>
        </button>
        <button type="button" class="pic-model__control-btn" data-pic-cladding-toggle aria-pressed="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 7C1 7 3 2 7 2C11 2 13 7 13 7C13 7 11 12 7 12C3 12 1 7 1 7Z"/>
            <circle cx="7" cy="7" r="2.5"/>
          </svg>
          <span>透明包层</span>
        </button>
      </div>
      <div class="pic-model__slider" data-pic-section-slider-wrap hidden>
        <input type="range" data-pic-section-slider min="-3.8" max="3.8" step="0.05" value="0">
        <span>切面位置</span>
      </div>
    </div>
  </div>
  <div class="pic-model__index" aria-label="3D 模型结构索引">
    {indexItems.map(([key, color, label]) => (
      <button type="button" data-pic-part-index={key} style={`--part-color: ${color}`}>{label}</button>
    ))}
  </div>
  <div class="pic-model__index" aria-label="器件索引" data-pic-device-index>
    <button type="button" data-pic-device-index="mzm" style="--part-color: #ef4444">MZM 调制器</button>
    <button type="button" data-pic-device-index="dc" style="--part-color: #14b8a6">定向耦合器</button>
    <button type="button" data-pic-device-index="microring" style="--part-color: #0891b2">微环 WDM 组</button>
  </div>
  <div class="pic-model__info" data-pic-part-info aria-live="polite">
    <strong data-pic-part-title>结构说明</strong>
    <span data-pic-part-body>选择模型中的结构，或点击下方结构索引，这里会显示它在 PIC 芯片中的作用。</span>
  </div>
  <figcaption>
    <strong>{title}</strong>
    <span>{caption}</span>
  </figcaption>
</figure>

<script>
  import * as THREE from "three";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";
  import { zBendPoint } from "../lib/pic-model-geometry.mjs";

  const roots = document.querySelectorAll("[data-pic-chip-model]");

  const partInfo = {
    substrate: {
      color: "#2563eb",
      title: "Si 衬底 (handle wafer)",
      body: "约 725 μm 厚的单晶硅衬底，提供机械支撑。在高速调制器区域下方通常选用高阻硅 (>750 Ω·cm)，以减少衬底对 RF 信号的损耗。是整个 PIC 芯片的最底层。"
    },
    box: {
      color: "#94a3b8",
      title: "BOX 埋氧层 (buried oxide)",
      body: "约 2 μm 的热氧化 SiO₂。光子 SOI 的 BOX 远厚于电子 SOI (后者仅 50–100 nm)，目的是保证 1550 nm 波段的光学隔离——防止上方的光波导模式泄漏到硅衬底中。"
    },
    siDevice: {
      color: "#0d9488",
      title: "Si 器件层 (220 nm 单晶硅)",
      body: "所有光子器件的「画布」。220 nm 厚的单晶硅层通过三种蚀刻深度（全刻蚀 220 nm、深部分 ~160 nm、浅部分 ~70 nm）形成条形波导、脊形波导和光栅耦合器等结构，同时通过离子注入形成调制器所需的 p-n 结。"
    },
    stripWaveguide: {
      color: "#14b8a6",
      title: "条形波导 (全刻蚀)",
      body: "硅被完全刻穿至 BOX，留下宽约 400–500 nm 的条形波导芯层。光场被强烈约束，弯曲半径可至数微米，用于紧凑布线、微环谐振器和定向耦合器。传播损耗相对较高 (~2–3 dB/cm)，来自全刻蚀侧壁的散射。"
    },
    ribWaveguide: {
      color: "#0f766e",
      title: "脊形波导 (部分刻蚀)",
      body: "仅浅刻蚀掉部分硅厚度，留下一层硅平板。传播损耗更低 (可低于 0.3 dB/cm)，但弯曲半径较大 (数十微米)。用于长距离布线、调制器相位臂和延迟线。"
    },
    mmiWaveguide: {
      color: "#2dd4bf",
      title: "MMI 多模区 (深部分刻蚀)",
      body: "MMI 的宽多模区通常采用深部分刻蚀截面：比长距离 rib 波导约束更强，又保留硅平板以提升多模干涉区的工艺容差。它不等同于紧凑微环和定向耦合器所用的全刻蚀 strip 波导。"
    },
    doping: {
      color: "#1d4ed8",
      title: "PN 结掺杂区",
      body: "MZM 相位臂两侧的 p++ / n++ 离子注入区。与脊形波导中的本征硅共同形成横向 PN 结——外加反向偏压改变耗尽区宽度，通过等离子色散效应改变波导折射率，实现纯电控相位调制。蓝色为 n++ 注入，红色为 p++ 注入。"
    },
    geDetector: {
      color: "#16a34a",
      title: "Ge 光电探测器",
      body: "在指定区域通过 RPCVD 选择性外延生长约 200–500 nm 的单晶锗。光从下方硅波导倏逝耦合进入 Ge 层被吸收，产生电子-空穴对并在偏置电场下形成光电流。Ge 只生长在暴露的硅窗口上，氧化层区域不生长。"
    },
    cladding: {
      color: "#94a3b8",
      title: "SiO₂ 上包层 (ILD)",
      body: "约 1–2 μm 的 PECVD 沉积 SiO₂，覆盖整个芯片表面。它同时承担波导上包层 (光场约束) 和电学隔离层 (防止金属电极吸收光) 的双重角色。加热器的热量也通过此层向下传导至波导。"
    },
    heater: {
      color: "#eab308",
      title: "TiN 微加热器",
      body: "一层专用的 TiN (或 Ni) 金属电阻条，位于波导上方约 1 μm 处。通电后通过 SiO₂ 包层向下传热，利用硅的热光效应 (dn/dT ≈ 1.86×10⁻⁴ K⁻¹) 调节波导的相位或微环的共振波长。单个 π 相移功耗约 10–50 mW。"
    },
    m1Interconnect: {
      color: "#f97316",
      title: "M1 Cu 互连",
      body: "第一层 Cu 金属互连 (~200 nm–1 μm)。提供就近的信号引出——例如为加热器供电、连接 Ge PD 电极——并通过 W 通孔向下连接到硅掺杂区和加热器端点。"
    },
    rfElectrode: {
      color: "#ef4444",
      title: "GSG 行波 RF 电极",
      body: "在 M2 层形成的地-信号-地 (GSG) 共面波导结构，位于调制器波导上方。目标特性阻抗 50 Ω，追求 RF 信号与光信号的群速度匹配以最大化电光带宽。M2 层厚度通常 ~2 μm 以保证 RF 性能。"
    },
    bondPad: {
      color: "#475569",
      title: "Al 焊盘",
      body: "芯片最顶层的 Al 焊盘，通过钝化层开窗暴露。用于引线键合 (wire bonding) 或倒装互连 (flip-chip)，将芯片的直流偏置、RF 信号和控制信号连接到封装或 EIC。"
    },
    gratingCoupler: {
      color: "#7c3aed",
      title: "光栅耦合器",
      body: "利用周期性刻蚀结构，将片上波导中的光向上 (或向下) 衍射到芯片表面外，也可将上方光纤的光耦合进波导。便于晶圆级测试——光纤可以从芯片上方直接访问，无需芯片端面加工。"
    },
    edgeCoupler: {
      color: "#a855f7",
      title: "边缘耦合器端面",
      body: "位于芯片边缘的光学端面，通过反向锥形结构 (inverse taper) 或 SSC 将片上小模场逐步扩展，与光纤的 ~9–10 μm 模场匹配。通常提供更宽的光学带宽和更低的耦合损耗，但需要高质量芯片端面和精密对准。"
    },
    opticalPath: {
      color: "#0891b2",
      title: "光信号路径",
      body: "光从激光源进入 PIC 后，经耦合器进入波导层，在硅器件层中传输、分束、调制、滤波，最终到达 Ge PD 被探测或经输出耦合器离开芯片。这条路径完全位于硅器件层内 (或 SiN 层内)。"
    },
    electricalPath: {
      color: "#f59e0b",
      title: "电信号路径",
      body: "Ge 探测器吸收光子后产生电子-空穴对，在反向偏压下形成光电流。电流经 W 接触通孔向上进入 M1 铜互连层，再经 M1 引线传输至 Al 焊盘，最终通过引线键合送到片外的 TIA/CDR 电路。"
    },
    mzm: {
      color: "#ef4444",
      title: "MZM 马赫-曾德尔调制器",
      body: "TX 光路的核心有源器件。连续光经 MMI 分束器分为两路，进入两根相位臂。EIC 驱动器通过 GSG 行波电极向两臂 PN 结施加推挽信号，利用载流子等离子色散效应改变折射率、产生相位差，在输出 MMI 合束时干涉为强度调制光。TiN 加热器提供静态偏置补偿。"
    },
    dc: {
      color: "#14b8a6",
      title: "定向耦合器 (tap coupler)",
      body: "主路条形波导与较窄的监测支路以小间距平行排列，通过倏逝场耦合交换少量功率。此处配置为 tap 耦合器——仅约 1–5% 的光从总线耦合到监测支路，其余继续沿总线传输。耦合波导经 S-bend 引出至监测 PD，用于实时追踪光功率。"
    },
    microring: {
      color: "#0891b2",
      title: "微环 WDM 解复用组",
      body: "三个半径略有不同的微环谐振器共用同一根 RX 总线波导。每个环的共振波长匹配一个 WDM 信道——当输入光波长等于某环的共振波长时，光被下载到对应的 drop 端口，由 Ge PD 探测。环间波长间隔由半径差决定，热调谐补偿工艺偏差。"
    }
  };

  const deviceKeys = ["mzm", "dc", "microring", "siDevice"];
  const compoundKeys = { siDevice: ["stripWaveguide", "ribWaveguide", "mmiWaveguide", "siDevice", "doping"] };

  const partOrder = Object.keys(partInfo);
  const partColor = (key) => Number.parseInt(partInfo[key].color.slice(1), 16);

  const material = (color, options = {}) =>
    new THREE.MeshStandardMaterial({
      color,
      roughness: 0.68,
      metalness: 0,
      ...options
    });

  const transparent = (color, opacity) =>
    material(color, {
      transparent: true,
      opacity,
      depthWrite: false
    });

  function createBox({ size, position, color, opacity = 1, metalness = 0, roughness = 0.68 }) {
    const mat = material(color, {
      transparent: opacity < 1,
      opacity,
      metalness,
      roughness
    });
    const mesh = new THREE.Mesh(new THREE.BoxGeometry(...size), mat);
    mesh.position.set(...position);
    return mesh;
  }

  function createHitBox({ size, position, key, priority = 2 }) {
    const mesh = new THREE.Mesh(
      new THREE.BoxGeometry(...size),
      new THREE.MeshBasicMaterial({
        transparent: true,
        opacity: 0,
        depthWrite: false
      })
    );
    mesh.position.set(...position);
    return tagPart(mesh, key, true, priority);
  }

  function tagPart(object, key, isHitProxy = false, priority = 0, deviceGroup = '') {
    object.userData.partKey = key;
    object.userData.hitProxy = isHitProxy;
    object.userData.selectionPriority = priority;
    if (deviceGroup) object.userData.deviceGroup = deviceGroup;
    object.traverse((child) => {
      child.userData.partKey = key;
      child.userData.hitProxy = isHitProxy;
      child.userData.selectionPriority = priority;
      if (deviceGroup) child.userData.deviceGroup = deviceGroup;
    });
    return object;
  }

  function createFaceLabel(text, position, normal, { color = "#334155", scale = 0.09, depthTest = true } = {}) {
    const canvas = document.createElement("canvas");
    const ctx = canvas.getContext("2d");
    const fontSize = 64;
    ctx.font = `${fontSize}px "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif`;
    const metrics = ctx.measureText(text);
    const pad = 20;
    const w = Math.ceil(metrics.width + pad * 2);
    const h = Math.ceil(fontSize * 1.5);
    canvas.width = w;
    canvas.height = h;
    // pill background
    const rx = pad - 8, ry = Math.round((h - fontSize) / 2) - 6, rw = Math.ceil(metrics.width) + 16, rh = fontSize + 12;
    ctx.fillStyle = "rgba(255, 255, 255, 0.88)";
    ctx.beginPath();
    const r = 10;
    ctx.moveTo(rx + r, ry);
    ctx.lineTo(rx + rw - r, ry);
    ctx.quadraticCurveTo(rx + rw, ry, rx + rw, ry + r);
    ctx.lineTo(rx + rw, ry + rh - r);
    ctx.quadraticCurveTo(rx + rw, ry + rh, rx + rw - r, ry + rh);
    ctx.lineTo(rx + r, ry + rh);
    ctx.quadraticCurveTo(rx, ry + rh, rx, ry + rh - r);
    ctx.lineTo(rx, ry + r);
    ctx.quadraticCurveTo(rx, ry, rx + r, ry);
    ctx.closePath();
    ctx.fill();
    ctx.strokeStyle = "rgba(148, 163, 184, 0.45)";
    ctx.lineWidth = 1.5;
    ctx.stroke();
    // text
    ctx.fillStyle = color;
    ctx.font = `${fontSize}px "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif`;
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText(text, w / 2, h / 2);
    const texture = new THREE.CanvasTexture(canvas);
    texture.minFilter = THREE.LinearFilter;
    texture.magFilter = THREE.LinearFilter;
    const aspect = w / h;
    const planeW = scale * aspect;
    const planeH = scale;
    const geom = new THREE.PlaneGeometry(planeW, planeH);
    const mat = new THREE.MeshBasicMaterial({
      map: texture,
      transparent: true,
      depthWrite: false,
      side: THREE.DoubleSide,
      depthTest
    });
    const plane = new THREE.Mesh(geom, mat);
    plane.position.copy(position);
    const q = new THREE.Quaternion().setFromUnitVectors(
      new THREE.Vector3(0, 0, 1),
      normal.clone().normalize()
    );
    plane.setRotationFromQuaternion(q);
    return plane;
  }

  function buildModel(scene) {
    const chip = new THREE.Group();
    scene.add(chip);

    const xScale = 1.5;
    const chipLeftX = -5.625; // fixed left chip edge (original centre=0, halfLen=5.625)
    const chipRightExt = 1.2; // extra right-side chip length for output structures
    const chipRightX = 5.625 + chipRightExt;
    const chipLen = chipRightX - chipLeftX;
    const chipCenterX = (chipLeftX + chipRightX) / 2;
    const chipWidth = 7.5;
    // Key X positions used early
    const dopingX = 0.5 * xScale; // center of MZM phase arms / doping / heaters
    const rfPadPx = dopingX + 0.6; // RF bond pad near MZM
    // RX path Z — shifted up to make room for new devices between TX and RX
    const rxZ = 2.2;
    const rxEdgeZ = 2.55;
    const rxPadZ = 2.55;
    const txZ = 0.4; // TX1 main waveguide Z

    // TX2 (λ2) channel — mirrored below TX1 at Z ≈ -1.4
    const tx2Z = -1.4;
    const tx2ArmZ1 = tx2Z - 0.125;
    const tx2ArmZ2 = tx2Z + 0.125;

    // MMI & arm length — needed early (used by RF electrodes before MMIs are created)
    const mmiLen = 0.85;
    const mmiWidth = 0.36;
    const mmiSplitterCx = -0.7 * xScale;
    const mmiCombinerCx = (0.5 * 2 + 0.7) * xScale; // symmetric around dopingX
    const armLen = (mmiCombinerCx - mmiLen / 2 - 0.15) - (mmiSplitterCx + mmiLen / 2 + 0.15);

    // ---- Layer groups for explode view ----
    const layerGroups = [];
    function addLayer(key) {
      const group = new THREE.Group();
      group.userData.layerKey = key;
      group.userData.layerIndex = layerGroups.length;
      layerGroups.push(group);
      chip.add(group);
      return group;
    }

    const lSubstrate = addLayer("substrate");
    const lBox = addLayer("box");
    const lSiDevice = addLayer("siDevice");
    const lGeDetector = addLayer("geDetector");
    const lCladding = addLayer("cladding");
    const lHeater = addLayer("heater");
    const lM1 = addLayer("m1Interconnect");
    const lRf = addLayer("rfElectrode");
    const lTop = addLayer("topLayer");

    let yBase = 0;

    // === Layer 1: Si substrate ===
    const substrateH = 0.6;
    const substrate = createBox({
      size: [chipLen, substrateH, chipWidth],
      position: [chipCenterX, yBase + substrateH / 2, 0],
      color: 0x2563eb,
      roughness: 0.78,
      metalness: 0
    });
    lSubstrate.add(tagPart(substrate, "substrate"));
    yBase += substrateH;

    // === Layer 2: BOX ===
    const boxH = 0.25;
    const box = createBox({
      size: [chipLen, boxH, chipWidth],
      position: [chipCenterX, yBase + boxH / 2, 0],
      color: 0x94a3b8,
      roughness: 0.5,
      metalness: 0
    });
    lBox.add(tagPart(box, "box"));
    yBase += boxH;

    // === Layer 3: Si device layer ===
    const siBase = yBase;
    const siFullH = 0.24;
    const siSlabH = 0.14;
    const siRibH = 0.19;

    const siSlabTop = yBase + siSlabH; // virtual reference (slab removed; waveguides now rest directly on BOX)
    const stripRidgeH = siFullH - siSlabH;
    const stripH = siFullH;         // full etch: BOX → full Si height
    const stripY = siBase + stripH / 2;
    const ribW = 0.24;
    const edgeCouplerW = 0.44;

    // Rib waveguide — right segment (does not pass through grating coupler region)
    const ribRidgeH = siRibH - siSlabH;
    const ribY = siBase + siRibH / 2; // rib waveguide centre — sits directly on BOX
    const mmiH = siRibH;
    const mmiY = ribY;
    const geBaseY = siBase + siRibH - 0.03;  // Ge PD overlaps rib waveguide top
    const mpdBaseY = siBase + stripH - 0.04; // monitor PD overlaps strip waveguide top
    const gcN = 7, gcPeriod = 0.08, gcToothW = 0.03, gcToothZW = 0.24;
    const gcCenterX = -3.2 * xScale;
    const gcRightEdge = gcCenterX + gcN * gcPeriod + gcToothW / 2;
    const ribStartX = -0.9 * xScale;
    const ribEndX = chipRightX - 0.3;

    // Taper helper — reusable trapezoidal transition from one waveguide port to another.
    const taperLen = 0.15;
    const taperH = (stripRidgeH + ribRidgeH) / 2;
    const addAngledTaper = (startX, startZ, endX, endZ, startW, endW) => {
      const dx = endX - startX;
      const dz = endZ - startZ;
      const len = Math.hypot(dx, dz) || 1;
      const nx = -dz / len;
      const nz = dx / len;
      const hwStart = startW / 2;
      const hwEnd = endW / 2;
      const toShapePoint = (x, z) => [x, -z];
      const shape = new THREE.Shape();
      shape.moveTo(...toShapePoint(startX + nx * hwStart, startZ + nz * hwStart));
      shape.lineTo(...toShapePoint(endX + nx * hwEnd, endZ + nz * hwEnd));
      shape.lineTo(...toShapePoint(endX - nx * hwEnd, endZ - nz * hwEnd));
      shape.lineTo(...toShapePoint(startX - nx * hwStart, startZ - nz * hwStart));
      shape.closePath();
      const geom = new THREE.ExtrudeGeometry(shape, { steps: 1, depth: taperH, bevelEnabled: false });
      const mesh = new THREE.Mesh(geom, material(0x14b8a6, { roughness: 0.42, metalness: 0.10 }));
      mesh.rotation.x = -Math.PI / 2;
      mesh.position.set(0, siBase + taperH / 2, 0);
      lSiDevice.add(tagPart(mesh, "ribWaveguide", false, 4));
    };
    const addTaper = (cx, cz, startW, endW, length = taperLen) =>
      addAngledTaper(cx - length / 2, cz, cx + length / 2, cz, startW, endW);

    // Connector from grating coupler to rib waveguide
    const connLen = ribStartX - gcRightEdge;
    const connCenterX = (gcRightEdge + ribStartX) / 2;
    const conn = createBox({
      size: [connLen, siRibH, ribW],
      position: [connCenterX, ribY, rxZ],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(conn, "ribWaveguide", false, 4));

    // WDM demux — three microrings on RX bus, each with drop port + Ge PD
    const ringR = [0.22, 0.25, 0.28]; // slightly different radii → different λ
    const ringXs = [-0.3, 0.8, 1.9].map(v => v * xScale);
    const ringGap = 0.05;
    const ringY = stripY;
    const ringTag = ["ring1", "ring2", "ring3"];
    const dropLen = 0.42;
    const dropGeH = 0.12;
    const dropGeData = [];
    const rxRingBusW = 0.16;
    const ringTubeR = 0.075;
    const ringDropW = rxRingBusW;
    const rxRingBusStartX = ringXs[0] - 0.48;
    const rxRingBusEndX = ringXs[2] + 0.48;
    const rxRibBeforeRingEndX = rxRingBusStartX - taperLen;
    const rxRibBeforeRingLen = rxRibBeforeRingEndX - ribStartX;
    const rxRibBeforeRing = createBox({
      size: [rxRibBeforeRingLen, siRibH, ribW],
      position: [(ribStartX + rxRibBeforeRingEndX) / 2, ribY, rxZ],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(rxRibBeforeRing, "ribWaveguide", false, 4));
    addTaper(rxRingBusStartX - taperLen / 2, rxZ, ribW, rxRingBusW);
    const ringBusWG = createBox({
      size: [rxRingBusEndX - rxRingBusStartX, stripH, rxRingBusW],
      position: [(rxRingBusStartX + rxRingBusEndX) / 2, stripY, rxZ],
      color: 0x14b8a6,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(ringBusWG, "stripWaveguide", false, 5, "microring"));
    addTaper(rxRingBusEndX + taperLen / 2, rxZ, rxRingBusW, ribW);
    const rxRibAfterRingStartX = rxRingBusEndX + taperLen;
    const rxRibAfterRingLen = ribEndX - rxRibAfterRingStartX;
    const rxRibAfterRingCenter = (rxRibAfterRingStartX + ribEndX) / 2;
    const rxRibAfterRing = createBox({
      size: [rxRibAfterRingLen, siRibH, ribW],
      position: [rxRibAfterRingCenter, ribY, rxZ],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(rxRibAfterRing, "ribWaveguide", false, 4));

    const siTopY = siSlabTop + stripRidgeH;
    yBase = siBase + siSlabH;
    for (let i = 0; i < 3; i++) {
      const rr = ringR[i];
      const rx = ringXs[i];
      const rz = rxZ + 0.16 + ringGap + rr + 0.035;
      // ring torus
      const geom = new THREE.TorusGeometry(rr, ringTubeR, 16, 48);
      const mesh = new THREE.Mesh(geom, material(0x14b8a6, { roughness: 0.38, metalness: 0.12 }));
      mesh.position.set(rx, ringY, rz);
      mesh.rotation.x = Math.PI / 2;
      lSiDevice.add(tagPart(mesh, "stripWaveguide", false, 5, "microring"));
      // drop waveguide (Z direction from ring far side upward)
      const dropZ = rz + rr + 0.032 + dropLen / 2 + 0.03;
      const dwg = createBox({
        size: [ringDropW, stripH, dropLen],
        position: [rx, stripY, dropZ],
        color: 0x14b8a6, roughness: 0.42, metalness: 0.12
      });
      lSiDevice.add(tagPart(dwg, "stripWaveguide", false, 4, "microring"));
      // Ge PD at drop waveguide end — sits on top, overlapping the waveguide
      const geZ = dropZ + dropLen / 2 - 0.04;
      const pd = createBox({
        size: [0.45, dropGeH, 0.22],
        position: [rx, geBaseY + dropGeH / 2, geZ],
        color: 0x16a34a, roughness: 0.38, metalness: 0.08
      });
      lGeDetector.add(tagPart(pd, "geDetector", false, 5, "microring"));
      // W via + M1 stub deferred to after cladding (needs cladTopY)
      dropGeData.push({ rx, geZ });
    }

    // === Layer 4: Ge photodetector ===
    const geH = 0.12;
    const geLen = 0.7;
    const geX = ribEndX - geLen / 2; // through-port monitor, ending at RX main waveguide tip
    const geDetector = createBox({
      size: [geLen, geH, 0.35],
      position: [geX, geBaseY + geH / 2, rxZ],
      color: 0x16a34a,
      roughness: 0.38,
      metalness: 0.08
    });
    lGeDetector.add(tagPart(geDetector, "geDetector", false, 5));

    // === Layer 5: Cladding ===
    const cladH = 0.65;
    const cladBaseH = siFullH + cladH;
    const claddingFull = createBox({
      size: [chipLen, cladBaseH, chipWidth],
      position: [chipCenterX, siBase + cladBaseH / 2, 0],
      color: 0x94a3b8,
      roughness: 0.6,
      metalness: 0,
      opacity: 0.58
    });
    claddingFull.material.depthWrite = false;
    lCladding.add(tagPart(claddingFull, "cladding"));

    const cladTopY = siTopY + cladH;

    // === Layer 6: Heaters (TX MZM phase arms) ===
    const heaterH = 0.06;
    const heaterW = 0.07;

    // === Layer 7: M1 interconnect ===
    const m1H = 0.09;

    // === Layer 8: RF electrodes (GSG travelling-wave) ===
    const rfH = 0.10;
    const rfElectrodeW = 0.07;
    const rfBaseY = cladTopY + heaterH + m1H;

    const rfSignal = createBox({
      size: [armLen + 0.1, rfH, rfElectrodeW],
      position: [dopingX, rfBaseY + rfH / 2, 0.4],
      color: 0xef4444,
      metalness: 0.7,
      roughness: 0.18
    });
    lRf.add(tagPart(rfSignal, "rfElectrode", false, 4, "mzm"));

    const rfGnd1 = createBox({
      size: [armLen + 0.1, rfH, rfElectrodeW],
      position: [dopingX, rfBaseY + rfH / 2, 0.20],
      color: 0x94a3b8,
      metalness: 0.75,
      roughness: 0.22
    });
    const rfGnd2 = createBox({
      size: [armLen + 0.1, rfH, rfElectrodeW],
      position: [dopingX, rfBaseY + rfH / 2, 0.60],
      color: 0x94a3b8,
      metalness: 0.75,
      roughness: 0.22
    });
    lRf.add(tagPart(rfGnd1, "rfElectrode", false, 0, "mzm"), tagPart(rfGnd2, "rfElectrode", false, 0, "mzm"));

    // === ILD cover over metal structures ===
    // In a real PIC, heater / M1 / RF electrodes are embedded in SiO₂ ILD,
    // not exposed to air. A semi-transparent cover layer eliminates the
    // "floating" visual artefacts above the cladding.
    const ildCoverH = 0.38;
    const ildCover = createBox({
      size: [chipLen - 0.08, ildCoverH, chipWidth - 0.08],
      position: [chipCenterX, cladTopY + ildCoverH / 2, 0],
      color: 0x94a3b8,
      roughness: 0.6,
      metalness: 0,
      opacity: 0.58
    });
    ildCover.material.depthWrite = false;
    lTop.add(tagPart(ildCover, "cladding"));

    // Drop Ge PD W vias + M1 stubs + top vias (deferred — needs cladTopY)
    const padH = 0.1;
    const padBaseY = rfBaseY + rfH + 0.12;
    for (const d of dropGeData) {
      const geTopY = geBaseY + dropGeH;
      // W via: Ge → M1
      const viaH_drop = cladTopY + heaterH - geTopY;
      lM1.add(tagPart(createBox({
        size: [0.06, viaH_drop, 0.06],
        position: [d.rx, geTopY + viaH_drop / 2, d.geZ],
        color: 0x78716c, metalness: 0.75, roughness: 0.25
      }), "m1Interconnect", false, 4, "microring"));
      // M1 stub
      const m1StubY = cladTopY + heaterH + m1H / 2;
      lM1.add(tagPart(createBox({
        size: [0.3, m1H, 0.08],
        position: [d.rx, m1StubY, d.geZ],
        color: 0xf97316, metalness: 0.65, roughness: 0.22
      }), "m1Interconnect", false, 4, "microring"));
      // Top via: M1 → bond pad
      const topViaH = padBaseY - (cladTopY + heaterH + m1H);
      lM1.add(tagPart(createBox({
        size: [0.06, topViaH, 0.06],
        position: [d.rx, cladTopY + heaterH + m1H + topViaH / 2, d.geZ],
        color: 0x78716c, metalness: 0.75, roughness: 0.25
      }), "m1Interconnect", false, 4, "microring"));
    }

    // Monitor PD W via + M1 stub (deferred — needs cladTopY)
    const mpdViaH2 = cladTopY + heaterH - (siBase + 0.1);
    lM1.add(tagPart(createBox({
      size: [0.05, mpdViaH2, 0.05],
      position: [-1.685, mpdBaseY + mpdViaH2 / 2, 1.42],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    }), "m1Interconnect", false, 4));
    lM1.add(tagPart(createBox({
      size: [0.2, m1H, 0.06],
      position: [-1.685, cladTopY + heaterH + m1H / 2, 1.42],
      color: 0xf97316, metalness: 0.65, roughness: 0.22
    }), "m1Interconnect", false, 4));
    // Top via: monitor PD M1 → bond pad
    lM1.add(tagPart(createBox({
      size: [0.06, padBaseY - (cladTopY + heaterH + m1H), 0.06],
      position: [-1.685, cladTopY + heaterH + m1H + (padBaseY - (cladTopY + heaterH + m1H)) / 2, 1.42],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    }), "m1Interconnect", false, 4));

    // TX2 Monitor PD W via + M1 stub (deferred — needs cladTopY)
    const tx2MpdViaH = cladTopY + heaterH - (siBase + 0.1);
    lM1.add(tagPart(createBox({
      size: [0.05, tx2MpdViaH, 0.05],
      position: [-1.685, mpdBaseY + tx2MpdViaH / 2, -2.45],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    }), "m1Interconnect", false, 4));
    lM1.add(tagPart(createBox({
      size: [0.2, m1H, 0.06],
      position: [-1.685, cladTopY + heaterH + m1H / 2, -2.45],
      color: 0xf97316, metalness: 0.65, roughness: 0.22
    }), "m1Interconnect", false, 4));
    // Top via: TX2 monitor PD M1 → bond pad
    lM1.add(tagPart(createBox({
      size: [0.06, padBaseY - (cladTopY + heaterH + m1H), 0.06],
      position: [-1.685, cladTopY + heaterH + m1H + (padBaseY - (cladTopY + heaterH + m1H)) / 2, -2.45],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    }), "m1Interconnect", false, 4));

    // === Layer 9: Bond pads ===
    const padPositions = [
      [geX, rxZ], [rfPadPx, 0.4], [rfPadPx, tx2Z],
      ...dropGeData.map(d => [d.rx, d.geZ])
    ];
    for (const [px, pz] of padPositions) {
      const pad = createBox({
        size: [0.18, padH, 0.18],
        position: [px, padBaseY + padH / 2, pz],
        color: 0x475569,
        metalness: 0.55,
        roughness: 0.28
      });
      lTop.add(tagPart(pad, "bondPad"));
    }

    // W contact via: Ge detector → M1
    const wViaH = cladTopY + heaterH - (geBaseY + geH);
    lM1.add(tagPart(createBox({
      size: [0.06, wViaH, 0.06],
      position: [geX, geBaseY + geH + wViaH / 2, rxZ],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    }), "m1Interconnect", false, 4));

    // M1 stub above Ge detector
    lM1.add(tagPart(createBox({
      size: [0.3, m1H, 0.08],
      position: [geX, cladTopY + heaterH + m1H / 2, rxZ],
      color: 0xf97316, metalness: 0.65, roughness: 0.22
    }), "m1Interconnect", false, 4));

    // Top via: M1 → bond pad
    const topViaH = padBaseY - (cladTopY + heaterH + m1H);
    lM1.add(tagPart(createBox({
      size: [0.06, topViaH, 0.06],
      position: [geX, cladTopY + heaterH + m1H + topViaH / 2, rxZ],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    }), "m1Interconnect", false, 4));

    // Reference point for incoming optical path (fiber tip above GC)
    const fiberCenterX = gcCenterX + 0.08 * xScale;
    const fiberBottomY = padBaseY + padH + 0.05;

    // Grating coupler — periodic teeth etched into the waveguide surface
    const gcLeftX = gcCenterX - gcN * gcPeriod - gcToothW / 2;
    const gcRightX = gcCenterX + gcN * gcPeriod + gcToothW / 2;
    // Rib waveguide under GC teeth
    const gcWG = createBox({
      size: [gcRightX - gcLeftX, siRibH, ribW],
      position: [(gcLeftX + gcRightX) / 2, ribY, rxZ],
      color: 0x0f766e, roughness: 0.42, metalness: 0.12
    });
    lSiDevice.add(tagPart(gcWG, "ribWaveguide", false, 4));
    // Teeth
    const gcGroup = new THREE.Group();
    for (let i = -gcN; i <= gcN; i++) {
      const gcTooth = createBox({
        size: [gcToothW, siRibH, gcToothZW],
        position: [gcCenterX + i * gcPeriod, ribY, rxZ],
        color: 0x7c3aed,
        roughness: 0.35,
        metalness: 0.25
      });
      gcGroup.add(tagPart(gcTooth, "gratingCoupler", false, 5));
    }
    lSiDevice.add(tagPart(gcGroup, "gratingCoupler"));

    // RX edge coupler (left facet — alternative input, bypasses GC via separate Z track)
    const rxEcZ = rxZ + 0.6; // 2.8 — separate track with clearance from GC teeth (Z≈2.48)
    const rxEcJunctionX = -1.0 * xScale; // where edge coupler waveguide joins main RX path (after GC)
    const rxInputEdgeCoupler = createBox({
      size: [0.06, siRibH + 0.04, edgeCouplerW],
      position: [chipLeftX + 0.02, ribY + 0.04, rxEcZ],
      color: 0xa855f7,
      roughness: 0.4,
      metalness: 0.15,
      opacity: 0.7
    });
    lSiDevice.add(tagPart(rxInputEdgeCoupler, "edgeCoupler", false, 5));
    // Waveguide from RX edge coupler along separate Z track to junction point
    const rxEcWgLen = rxEcJunctionX - (chipLeftX + 0.02);
    const rxEcWgCx = (chipLeftX + 0.02 + rxEcJunctionX) / 2;
    const rxEcWg = createBox({
      size: [rxEcWgLen + 0.04, siRibH, ribW],
      position: [rxEcWgCx, ribY, rxEcZ],
      color: 0x0f766e, roughness: 0.42, metalness: 0.12
    });
    lSiDevice.add(tagPart(rxEcWg, "ribWaveguide", false, 4));
    // Z-branch: connects edge-coupler track (rxEcZ) to main RX track (rxZ) after GC
    const rxEcZBranchLen = Math.abs(rxEcZ - rxZ) - ribW;
    const rxEcZbranch = createBox({
      size: [ribW, siRibH, rxEcZBranchLen],
      position: [rxEcJunctionX, ribY, (rxEcZ + rxZ) / 2],
      color: 0x0f766e, roughness: 0.42, metalness: 0.12
    });
    lSiDevice.add(tagPart(rxEcZbranch, "ribWaveguide", false, 4));

    // TX2 input edge coupler (left facet — λ2 laser input)
    const tx2InputEdgeCoupler = createBox({
      size: [0.06, siRibH + 0.04, edgeCouplerW],
      position: [chipLeftX + 0.02, ribY + 0.04, tx2Z],
      color: 0xa855f7,
      roughness: 0.4,
      metalness: 0.15,
      opacity: 0.7
    });
    lSiDevice.add(tagPart(tx2InputEdgeCoupler, "edgeCoupler", false, 5));

    // TX input edge coupler (left facet — CW laser input)
    const txInputEdgeCoupler = createBox({
      size: [0.06, siRibH + 0.04, edgeCouplerW],
      position: [chipLeftX + 0.02, ribY + 0.04, 0.4],
      color: 0xa855f7,
      roughness: 0.4,
      metalness: 0.15,
      opacity: 0.7
    });
    lSiDevice.add(tagPart(txInputEdgeCoupler, "edgeCoupler", false, 5));

    // TX input grating coupler
    const txGcWG = createBox({
      size: [gcRightX - gcLeftX, siRibH, ribW],
      position: [(gcLeftX + gcRightX) / 2, ribY, -0.4],
      color: 0x0f766e, roughness: 0.42, metalness: 0.12
    });
    lSiDevice.add(tagPart(txGcWG, "ribWaveguide", false, 4));
    const txGcGroup = new THREE.Group();
    for (let i = -gcN; i <= gcN; i++) {
      const txGcTooth = createBox({
        size: [gcToothW, siRibH, gcToothZW],
        position: [gcCenterX + i * gcPeriod, ribY, -0.4],
        color: 0x7c3aed,
        roughness: 0.35,
        metalness: 0.25
      });
      txGcGroup.add(tagPart(txGcTooth, "gratingCoupler", false, 5));
    }
    lSiDevice.add(tagPart(txGcGroup, "gratingCoupler"));

    // Z-branch from TX main waveguide (Z bottom edge 0.24) to TX input GC (Z top edge -0.24)
    const txInputZBranchLen = Math.abs(0.4 - (-0.4)) - ribW;
    const txInputZBranch = createBox({
      size: [ribW, siRibH, txInputZBranchLen],
      position: [gcCenterX, ribY, 0],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txInputZBranch, "ribWaveguide", false, 4));

    // Short X-stub waveguide for TX input GC at Z = -0.4
    const txInputGcStub = createBox({
      size: [0.8, siRibH, ribW],
      position: [gcCenterX, ribY, -0.4],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txInputGcStub, "ribWaveguide", false, 4));

    // TX2 input grating coupler (Z = -1.6, mirror of TX1 GC at -0.4)
    const tx2GcZ = tx2Z - 0.8;
    const tx2GcWG = createBox({
      size: [gcRightX - gcLeftX, siRibH, ribW],
      position: [(gcLeftX + gcRightX) / 2, ribY, tx2GcZ],
      color: 0x0f766e, roughness: 0.42, metalness: 0.12
    });
    lSiDevice.add(tagPart(tx2GcWG, "ribWaveguide", false, 4));
    const tx2GcGroup = new THREE.Group();
    for (let i = -gcN; i <= gcN; i++) {
      const tx2GcTooth = createBox({
        size: [gcToothW, siRibH, gcToothZW],
        position: [gcCenterX + i * gcPeriod, ribY, tx2GcZ],
        color: 0x7c3aed,
        roughness: 0.35,
        metalness: 0.25
      });
      tx2GcGroup.add(tagPart(tx2GcTooth, "gratingCoupler", false, 5));
    }
    lSiDevice.add(tagPart(tx2GcGroup, "gratingCoupler"));

    // Z-branch from TX2 main waveguide to TX2 input GC
    const tx2InputZBranchLen = Math.abs(tx2Z - tx2GcZ) - ribW;
    const tx2InputZBranch = createBox({
      size: [ribW, siRibH, tx2InputZBranchLen],
      position: [gcCenterX, ribY, (tx2Z + tx2GcZ) / 2],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(tx2InputZBranch, "ribWaveguide", false, 4));

    // Short X-stub waveguide for TX2 input GC
    const tx2InputGcStub = createBox({
      size: [0.8, siRibH, ribW],
      position: [gcCenterX, ribY, tx2GcZ],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(tx2InputGcStub, "ribWaveguide", false, 4));

    // DC variables needed for waveguide length computation
    const dcLen = 0.55;
    const dcGap = 0.16;
    const dcBusW = 0.2;
    const dcTapW = 0.14;
    const dcTaperLen = 0.216;
    const dcX = -1.8 * xScale;
    const dcStartX = dcX - dcLen / 2;
    const dcEndX = dcX + dcLen / 2;
    const dcParallelStartX = dcStartX;
    const dcParallelEndX = dcEndX;
    const dcRibEntryEndX = dcParallelStartX - dcTaperLen;
    const dcRibExitStartX = dcParallelEndX + dcTaperLen;
    const dcEntryTaperCx = dcParallelStartX - dcTaperLen / 2;
    const dcExitTaperCx = dcParallelEndX + dcTaperLen / 2;

    // TX input waveguide common X values (edge coupler → DC approach)
    const ecRightX = chipLeftX + 0.02;
    const txWgLen = dcRibEntryEndX - ecRightX;
    const txWgCx = (ecRightX + dcRibEntryEndX) / 2;

    // TX2 main waveguide (rib) — from edge coupler to directional coupler
    const tx2Waveguide = createBox({
      size: [txWgLen, siRibH, ribW],
      position: [txWgCx, ribY, tx2Z],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(tx2Waveguide, "ribWaveguide", false, 4));

    // TX main waveguide (rib) — from edge coupler to directional coupler
    const txWaveguide = createBox({
      size: [txWgLen, siRibH, ribW],
      position: [txWgCx, ribY, 0.4],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txWaveguide, "ribWaveguide", false, 4));

    // Directional coupler — S-bend tap coupler
    // Bus waveguide: straight coupling section bracketed by visible rib↔strip tapers.
    // Coupled waveguide: S-bend approach → parallel gap → S-bend exit → monitor PD
    // Only ~1–5% of light couples across the narrow gap via evanescent coupling
    const dcBusWG = createBox({
      size: [dcParallelEndX - dcParallelStartX, stripH, dcBusW],
      position: [(dcParallelStartX + dcParallelEndX) / 2, stripY, 0.4],
      color: 0x14b8a6,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(dcBusWG, "stripWaveguide", false, 5, "dc"));
    // Rib→strip taper at DC entry, strip→rib taper at DC exit
    addTaper(dcEntryTaperCx, 0.4, ribW, dcBusW, dcTaperLen);
    addTaper(dcExitTaperCx, 0.4, dcBusW, ribW, dcTaperLen);
    const dcCoupledZ = 0.4 + dcBusW / 2 + dcGap + dcTapW / 2;

    const dcCoupledY = stripY + 0.001;
    const dcCoupledPathPts = [
      new THREE.Vector3(dcParallelStartX, dcCoupledY, dcCoupledZ),
      new THREE.Vector3(dcParallelEndX, dcCoupledY, dcCoupledZ),
      new THREE.Vector3(dcParallelEndX + 0.5, dcCoupledY, 0.88),
      new THREE.Vector3(dcParallelEndX + 0.72, dcCoupledY, 1.42),
    ];
    const dcCoupledCurve = new THREE.CatmullRomCurve3(dcCoupledPathPts);
    // Extrude rectangular cross-section along the S-bend path
    const dcShape = new THREE.Shape();
    const hw = dcTapW / 2;
    const hh = stripH / 2;
    dcShape.moveTo(-hw, -hh);
    dcShape.lineTo( hw, -hh);
    dcShape.lineTo( hw,  hh);
    dcShape.lineTo(-hw,  hh);
    dcShape.closePath();
    const dcCoupledGeom = new THREE.ExtrudeGeometry(dcShape, { steps: 64, extrudePath: dcCoupledCurve });
    const dcCoupledMesh = new THREE.Mesh(dcCoupledGeom, material(0x14b8a6, { roughness: 0.42, metalness: 0.12 }));
    lSiDevice.add(tagPart(dcCoupledMesh, "stripWaveguide", false, 5, "dc"));

    // Monitor PD at end of coupled waveguide — centred on S-bend endpoint
    const mpdH = 0.1;
    const mpdX = dcParallelEndX + 0.72;
    const mpdZ = 1.42;
    const mpd = createBox({
      size: [0.24, mpdH, 0.16],
      position: [mpdX, mpdBaseY + mpdH / 2, mpdZ],
      color: 0x16a34a, roughness: 0.38, metalness: 0.08
    });
    lGeDetector.add(tagPart(mpd, "geDetector", false, 5));
    // Monitor PD Al bond pad
    lTop.add(tagPart(createBox({
      size: [0.18, padH, 0.18],
      position: [mpdX, padBaseY + padH / 2, mpdZ],
      color: 0x475569, metalness: 0.55, roughness: 0.28
    }), "bondPad"));

    // TX waveguide from DC to MMI splitter (ends before input taper)
    const mmiEdgeL = mmiSplitterCx - mmiLen / 2 - taperLen;
    const dcToMmiLen = mmiEdgeL - dcRibExitStartX;
    const dcToMmiCx = (dcRibExitStartX + mmiEdgeL) / 2;
    const txWaveguideDC = createBox({
      size: [dcToMmiLen, siRibH, ribW],
      position: [dcToMmiCx, ribY, 0.4],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txWaveguideDC, "ribWaveguide", false, 4));

    // TX2 Directional coupler — S-bend tap coupler (at Z ≈ -1.4)
    // Coupled waveguide bends toward negative Z to stay clear of TX1
    const tx2DcCoupledZ = tx2Z - dcBusW / 2 - dcGap - dcTapW / 2;
    const tx2DcCoupledY = stripY + 0.001;

    const tx2DcBusWG = createBox({
      size: [dcParallelEndX - dcParallelStartX, stripH, dcBusW],
      position: [(dcParallelStartX + dcParallelEndX) / 2, stripY, tx2Z],
      color: 0x14b8a6,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(tx2DcBusWG, "stripWaveguide", false, 5, "dc"));
    addTaper(dcEntryTaperCx, tx2Z, ribW, dcBusW, dcTaperLen);
    addTaper(dcExitTaperCx, tx2Z, dcBusW, ribW, dcTaperLen);

    const tx2DcCoupledPathPts = [
      new THREE.Vector3(dcParallelStartX, tx2DcCoupledY, tx2DcCoupledZ),
      new THREE.Vector3(dcParallelEndX, tx2DcCoupledY, tx2DcCoupledZ),
      new THREE.Vector3(dcParallelEndX + 0.5, tx2DcCoupledY, tx2DcCoupledZ - 0.24),
      new THREE.Vector3(dcParallelEndX + 0.72, tx2DcCoupledY, tx2DcCoupledZ - 0.78),
    ];
    const tx2DcCoupledCurve = new THREE.CatmullRomCurve3(tx2DcCoupledPathPts);
    const tx2DcShape = new THREE.Shape();
    const tx2DcHw = dcTapW / 2;
    const tx2DcHh = stripH / 2;
    tx2DcShape.moveTo(-tx2DcHw, -tx2DcHh);
    tx2DcShape.lineTo( tx2DcHw, -tx2DcHh);
    tx2DcShape.lineTo( tx2DcHw,  tx2DcHh);
    tx2DcShape.lineTo(-tx2DcHw,  tx2DcHh);
    tx2DcShape.closePath();
    const tx2DcCoupledGeom = new THREE.ExtrudeGeometry(tx2DcShape, { steps: 64, extrudePath: tx2DcCoupledCurve });
    const tx2DcCoupledMesh = new THREE.Mesh(tx2DcCoupledGeom, material(0x14b8a6, { roughness: 0.42, metalness: 0.12 }));
    lSiDevice.add(tagPart(tx2DcCoupledMesh, "stripWaveguide", false, 5, "dc"));

    // TX2 Monitor PD at end of coupled waveguide — centred on S-bend endpoint
    const tx2MpdZ = tx2DcCoupledZ - 0.78;
    const tx2MpdX = dcParallelEndX + 0.72;
    const tx2Mpd = createBox({
      size: [0.24, mpdH, 0.16],
      position: [tx2MpdX, mpdBaseY + mpdH / 2, tx2MpdZ],
      color: 0x16a34a, roughness: 0.38, metalness: 0.08
    });
    lGeDetector.add(tagPart(tx2Mpd, "geDetector", false, 5));
    lTop.add(tagPart(createBox({
      size: [0.18, padH, 0.18],
      position: [tx2MpdX, padBaseY + padH / 2, tx2MpdZ],
      color: 0x475569, metalness: 0.55, roughness: 0.28
    }), "bondPad"));

    // TX2 waveguide from DC to MMI splitter
    const tx2WaveguideDC = createBox({
      size: [dcToMmiLen, siRibH, ribW],
      position: [dcToMmiCx, ribY, tx2Z],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(tx2WaveguideDC, "ribWaveguide", false, 4));

    // TX MMI splitter + MZM phase arms
    const armZ1 = 0.275;
    const armZ2 = 0.525;
    const armWidth = 0.14;

    const txMmiSplitter = createBox({
      size: [mmiLen, mmiH, mmiWidth],
      position: [mmiSplitterCx, mmiY, 0.4],
      color: 0x2dd4bf,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txMmiSplitter, "mmiWaveguide", false, 4, "mzm"));

    const txArm1 = createBox({
      size: [armLen, siRibH,armWidth],
      position: [dopingX, ribY, armZ1],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txArm1, "ribWaveguide", false, 4, "mzm"));

    const txArm2 = createBox({
      size: [armLen, siRibH,armWidth],
      position: [dopingX, ribY, armZ2],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txArm2, "ribWaveguide", false, 4, "mzm"));

    // TX MMI combiner (output end of MZM)
    const txMmiCombiner = createBox({
      size: [mmiLen, mmiH, mmiWidth],
      position: [mmiCombinerCx, mmiY, 0.4],
      color: 0x2dd4bf,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(txMmiCombiner, "mmiWaveguide", false, 4, "mzm"));

    // === Tapers: MMI ↔ phase arms ===

    // MMI splitter → phase arm 1
    const taperSplitCx = mmiSplitterCx + mmiLen / 2 + taperLen / 2;
    const taperCombCx = mmiCombinerCx - mmiLen / 2 - taperLen / 2;
    addAngledTaper(mmiSplitterCx + mmiLen / 2, 0.4, taperSplitCx + taperLen / 2, armZ1, mmiWidth, armWidth);
    // MMI splitter → phase arm 2
    addAngledTaper(mmiSplitterCx + mmiLen / 2, 0.4, taperSplitCx + taperLen / 2, armZ2, mmiWidth, armWidth);
    // Phase arm 1 → MMI combiner
    addAngledTaper(taperCombCx - taperLen / 2, armZ1, mmiCombinerCx - mmiLen / 2, 0.4, armWidth, mmiWidth);
    // Phase arm 2 → MMI combiner
    addAngledTaper(taperCombCx - taperLen / 2, armZ2, mmiCombinerCx - mmiLen / 2, 0.4, armWidth, mmiWidth);
    // Splitter input taper: input rib waveguide → MMI body.
    addTaper(mmiSplitterCx - mmiLen / 2 - taperLen / 2, 0.4, ribW, mmiWidth);
    // Combiner output taper: MMI body → output rib waveguide.
    addTaper(mmiCombinerCx + mmiLen / 2 + taperLen / 2, 0.4, mmiWidth, ribW);

    // TX2 MZM — identical structure, shifted to tx2Z = -1.4
    const tx2MmiSplitter = createBox({
      size: [mmiLen, mmiH, mmiWidth],
      position: [mmiSplitterCx, mmiY, tx2Z],
      color: 0x2dd4bf,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(tx2MmiSplitter, "mmiWaveguide", false, 4, "mzm"));

    const tx2Arm1 = createBox({
      size: [armLen, siRibH, armWidth],
      position: [dopingX, ribY, tx2ArmZ1],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(tx2Arm1, "ribWaveguide", false, 4, "mzm"));

    const tx2Arm2 = createBox({
      size: [armLen, siRibH, armWidth],
      position: [dopingX, ribY, tx2ArmZ2],
      color: 0x0f766e,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(tx2Arm2, "ribWaveguide", false, 4, "mzm"));

    const tx2MmiCombiner = createBox({
      size: [mmiLen, mmiH, mmiWidth],
      position: [mmiCombinerCx, mmiY, tx2Z],
      color: 0x2dd4bf,
      roughness: 0.42,
      metalness: 0.12
    });
    lSiDevice.add(tagPart(tx2MmiCombiner, "mmiWaveguide", false, 4, "mzm"));

    // TX2 tapers
    addAngledTaper(mmiSplitterCx + mmiLen / 2, tx2Z, taperSplitCx + taperLen / 2, tx2ArmZ1, mmiWidth, armWidth);
    addAngledTaper(mmiSplitterCx + mmiLen / 2, tx2Z, taperSplitCx + taperLen / 2, tx2ArmZ2, mmiWidth, armWidth);
    addAngledTaper(taperCombCx - taperLen / 2, tx2ArmZ1, mmiCombinerCx - mmiLen / 2, tx2Z, armWidth, mmiWidth);
    addAngledTaper(taperCombCx - taperLen / 2, tx2ArmZ2, mmiCombinerCx - mmiLen / 2, tx2Z, armWidth, mmiWidth);
    // TX2 splitter input taper and combiner output taper
    addTaper(mmiSplitterCx - mmiLen / 2 - taperLen / 2, tx2Z, ribW, mmiWidth);
    addTaper(mmiCombinerCx + mmiLen / 2 + taperLen / 2, tx2Z, mmiWidth, ribW);

    // MZI Wavelength Multiplexer — combines λ1 (TX1) and λ2 (TX2) onto one output
    // Two 2×2 MMIs with unequal arm lengths → wavelength-selective combination
    const mziMmiLen = 0.55;                        // compact 2×2 coupler
    const mziMmiW = mmiWidth;
    const mziMmiInCx = mmiCombinerCx + 1.35;       // 3.90 — pushed right for Z-bend S-curve room
    const mziMmiOutCx = mziMmiInCx + 1.1;         // 5.00
    const mziCenterZ = (tx2Z + 0.4) / 2;           // -0.5
    const mziPort1Z = mziCenterZ + 0.15;            // -0.35
    const mziPort2Z = mziCenterZ - 0.15;            // -0.65
    const mziColor = 0x8b5cf6; // purple — MZI components
    const mziArmColor = 0xa78bfa; // lighter purple

    // S-bend Z-bend helper — curved waveguide changing Z
    const zBendColor = 0x06b6d4; // cyan
    const _bendW = 0.16;
    const makeZBendCurve = (startX, startZ, endX, endZ, y) => {
      const spec = { startX, startZ, endX, endZ, y };
      return new class extends THREE.Curve {
        getPoint(t, target = new THREE.Vector3()) {
          const point = zBendPoint(spec, t);
          return target.set(point.x, point.y, point.z);
        }
      }();
    };

    const addZBend = (startX, startZ, endX, endZ) => {
      const curve = makeZBendCurve(startX, startZ, endX, endZ, ribY);
      const shape = new THREE.Shape();
      const hw = _bendW / 2, hh = siRibH / 2;
      shape.moveTo(-hw, -hh); shape.lineTo(hw, -hh); shape.lineTo(hw, hh); shape.lineTo(-hw, hh); shape.closePath();
      lSiDevice.add(tagPart(new THREE.Mesh(new THREE.ExtrudeGeometry(shape, { steps: 48, extrudePath: curve }), material(zBendColor, { roughness: 0.42, metalness: 0.12 })), "ribWaveguide", false, 4));
    };
    // TX1 output → MZI port 1, TX2 output → MZI port 2
    const combiOutX = mmiCombinerCx + mmiLen / 2 + taperLen;
    const mziInputFaceX = mziMmiInCx - mziMmiLen / 2;
    addZBend(combiOutX, 0.4, mziInputFaceX, mziPort1Z);
    addZBend(combiOutX, tx2Z, mziInputFaceX, mziPort2Z);

    // Input 2×2 MMI
    const mziInputMmi = createBox({ size: [mziMmiLen, mmiH, mziMmiW], position: [mziMmiInCx, mmiY, mziCenterZ], color: mziColor, roughness: 0.42, metalness: 0.12 });
    lSiDevice.add(tagPart(mziInputMmi, "mmiWaveguide", false, 4));

    // MZI arms — span from input MMI face to output MMI face
    const mziArmStartX = mziMmiInCx + mziMmiLen / 2;
    const mziArmEndX = mziMmiOutCx - mziMmiLen / 2;
    const mziArmLen = mziArmEndX - mziArmStartX;
    const mziArmCx = (mziArmStartX + mziArmEndX) / 2;
    // Arm 1: short, straight
    lSiDevice.add(tagPart(createBox({ size: [mziArmLen, siRibH, armWidth], position: [mziArmCx, ribY, mziPort1Z], color: mziArmColor, roughness: 0.42, metalness: 0.12 }), "ribWaveguide", false, 4));
    // Arm 2: long with detour
    const mziArm2PathPts = [
      new THREE.Vector3(mziArmStartX, stripY + 0.001, mziPort2Z),
      new THREE.Vector3(mziArmStartX + 0.15, stripY + 0.001, mziPort2Z - 0.22),
      new THREE.Vector3((mziArmStartX + mziArmEndX) / 2, stripY + 0.001, mziPort2Z - 0.22),
      new THREE.Vector3(mziArmEndX - 0.1, stripY + 0.001, mziPort2Z),
      new THREE.Vector3(mziArmEndX, stripY + 0.001, mziPort2Z),
    ];
    const mziArm2Curve = new THREE.CatmullRomCurve3(mziArm2PathPts);
    const mziArm2Shape = new THREE.Shape();
    const _ahw = armWidth / 2, _ahh = siRibH / 2;
    mziArm2Shape.moveTo(-_ahw, -_ahh); mziArm2Shape.lineTo(_ahw, -_ahh); mziArm2Shape.lineTo(_ahw, _ahh); mziArm2Shape.lineTo(-_ahw, _ahh); mziArm2Shape.closePath();
    lSiDevice.add(tagPart(new THREE.Mesh(new THREE.ExtrudeGeometry(mziArm2Shape, { steps: 48, extrudePath: mziArm2Curve }), material(mziArmColor, { roughness: 0.42, metalness: 0.12 })), "ribWaveguide", false, 4));

    // Output 2×2 MMI
    const mziOutputMmi = createBox({ size: [mziMmiLen, mmiH, mziMmiW], position: [mziMmiOutCx, mmiY, mziCenterZ], color: mziColor, roughness: 0.42, metalness: 0.12 });
    lSiDevice.add(tagPart(mziOutputMmi, "mmiWaveguide", false, 4));

    // Output 2×2 MMI exposes two output ports; the selected WDM output uses one port.
    const outWgEndX = chipRightX - 0.02;
    const mziOutputFaceX = mziMmiOutCx + mziMmiLen / 2;
    const mziMainOutputPortZ = mziPort1Z;
    const mziUnusedOutputPortZ = mziPort2Z;
    const mziUnusedOutputLen = 0.32;
    const mziUnusedOutputCx = mziOutputFaceX + mziUnusedOutputLen / 2;
    lSiDevice.add(tagPart(createBox({
      size: [mziUnusedOutputLen, siRibH, 0.18],
      position: [mziUnusedOutputCx, ribY, mziUnusedOutputPortZ],
      color: mziArmColor, roughness: 0.42, metalness: 0.12
    }), "ribWaveguide", false, 4));
    const outWgStartX = mziOutputFaceX;
    const outWgLen = outWgEndX - outWgStartX;
    const outWgCx = (outWgStartX + outWgEndX) / 2;
    const outWgZ = mziMainOutputPortZ;
    lSiDevice.add(tagPart(createBox({
      size: [outWgLen, siRibH, ribW],
      position: [outWgCx, ribY, outWgZ],
      color: 0x0f766e, roughness: 0.42, metalness: 0.12
    }), "ribWaveguide", false, 4));

    // TX output edge coupler (right facet — modulated light output)
    const txOutputEdgeCoupler = createBox({
      size: [0.06, siRibH + 0.04, edgeCouplerW],
      position: [chipRightX - 0.02, ribY + 0.04, outWgZ],
      color: 0xa855f7,
      roughness: 0.4,
      metalness: 0.15,
      opacity: 0.7
    });
    lSiDevice.add(tagPart(txOutputEdgeCoupler, "edgeCoupler", false, 5));

    // TX output grating coupler — Z-oriented (teeth along Z, period along Z)
    const outGcZ = -1.6;
    const txOutputGcBranchX = outWgCx;
    // GC rib waveguide: Z-stub from output WG (–0.35) down through GC teeth area
    const outGcZfar = outGcZ - gcN * gcPeriod - gcToothW / 2;
    const outGcZnear = outWgZ;
    const outGcWgZspan = Math.abs(outGcZnear - outGcZfar);
    const outGcWgZcenter = (outGcZnear + outGcZfar) / 2;
    const txOutGcWG = createBox({
      size: [ribW, siRibH, outGcWgZspan],
      position: [txOutputGcBranchX, ribY, outGcWgZcenter],
      color: 0x0f766e, roughness: 0.42, metalness: 0.12
    });
    lSiDevice.add(tagPart(txOutGcWG, "ribWaveguide", false, 4));

    // GC teeth — periodic along Z, each tooth spans X
    const txOutputGcGroup = new THREE.Group();
    for (let i = -gcN; i <= gcN; i++) {
      const txOutputGcTooth = createBox({
        size: [gcToothZW, siRibH, gcToothW],
        position: [txOutputGcBranchX, ribY, outGcZ + i * gcPeriod],
        color: 0x7c3aed,
        roughness: 0.35,
        metalness: 0.25
      });
      txOutputGcGroup.add(tagPart(txOutputGcTooth, "gratingCoupler", false, 5));
    }
    lSiDevice.add(tagPart(txOutputGcGroup, "gratingCoupler"));

    // TX heaters above phase arms (thermal tuning / bias)
    // Offset slightly outward in Z to remain visible under GND electrodes
    const txHeater1 = createBox({
      size: [armLen - 0.5, heaterH, heaterW],
      position: [dopingX, cladTopY + heaterH / 2, armZ1 - 0.03],
      color: 0xeab308,
      metalness: 0.5,
      roughness: 0.3
    });
    lHeater.add(tagPart(txHeater1, "heater", false, 5, "mzm"));

    const txHeater2 = createBox({
      size: [armLen - 0.5, heaterH, heaterW],
      position: [dopingX, cladTopY + heaterH / 2, armZ2 + 0.03],
      color: 0xeab308,
      metalness: 0.5,
      roughness: 0.3
    });
    lHeater.add(tagPart(txHeater2, "heater", false, 5, "mzm"));

    // Heater W vias up to M1 level
    const heaterZ1 = armZ1 - 0.03;
    const heaterZ2 = armZ2 + 0.03;
    const viaToM1H = heaterH + m1H;
    const heaterVia1 = createBox({
      size: [0.06, viaToM1H, 0.06],
      position: [dopingX, cladTopY + viaToM1H / 2, heaterZ1],
      color: 0x78716c,
      metalness: 0.75,
      roughness: 0.25
    });
    lHeater.add(tagPart(heaterVia1, "heater", false, 5, "mzm"));
    const heaterVia2 = createBox({
      size: [0.06, viaToM1H, 0.06],
      position: [dopingX, cladTopY + viaToM1H / 2, heaterZ2],
      color: 0x78716c,
      metalness: 0.75,
      roughness: 0.25
    });
    lHeater.add(tagPart(heaterVia2, "heater", false, 5, "mzm"));

    // M1 traces from heater vias to bond pad vias
    const heaterM1Y = cladTopY + heaterH + m1H / 2;
    const heaterPadX = 1.3 * xScale;
    const heaterTraceLen = heaterPadX - 0.5 * xScale;
    const heaterTraceCx = (0.5 * xScale + heaterPadX) / 2;
    const heaterM1Trace1 = createBox({
      size: [heaterTraceLen, m1H, 0.08],
      position: [heaterTraceCx, heaterM1Y, heaterZ1],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lM1.add(tagPart(heaterM1Trace1, "m1Interconnect", false, 4, "mzm"));
    const heaterM1Trace2 = createBox({
      size: [heaterTraceLen, m1H, 0.08],
      position: [heaterTraceCx, heaterM1Y, heaterZ2],
      color: 0xf97316,
      metalness: 0.65,
      roughness: 0.22
    });
    lM1.add(tagPart(heaterM1Trace2, "m1Interconnect", false, 4, "mzm"));

    // Top vias: M1 → bond pad (deferred — needs padBaseY)
    const heaterTopViaH = padBaseY - (cladTopY + heaterH + m1H);
    lM1.add(tagPart(createBox({
      size: [0.06, heaterTopViaH, 0.06],
      position: [heaterPadX, cladTopY + heaterH + m1H + heaterTopViaH / 2, heaterZ1],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    }), "m1Interconnect", false, 4, "mzm"));
    lM1.add(tagPart(createBox({
      size: [0.06, heaterTopViaH, 0.06],
      position: [heaterPadX, cladTopY + heaterH + m1H + heaterTopViaH / 2, heaterZ2],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    }), "m1Interconnect", false, 4, "mzm"));

    // Heater bond pads
    lTop.add(tagPart(createBox({
      size: [0.18, padH, 0.18],
      position: [heaterPadX, padBaseY + padH / 2, heaterZ1],
      color: 0x475569, metalness: 0.55, roughness: 0.28
    }), "bondPad", false, 0, "mzm"));
    lTop.add(tagPart(createBox({
      size: [0.18, padH, 0.18],
      position: [heaterPadX, padBaseY + padH / 2, heaterZ2],
      color: 0x475569, metalness: 0.55, roughness: 0.28
    }), "bondPad", false, 0, "mzm"));

    // TX2 heaters above phase arms
    const tx2HeaterZ1 = tx2ArmZ1 - 0.03;
    const tx2HeaterZ2 = tx2ArmZ2 + 0.03;
    const tx2Heater1 = createBox({
      size: [armLen - 0.5, heaterH, heaterW],
      position: [dopingX, cladTopY + heaterH / 2, tx2HeaterZ1],
      color: 0xeab308,
      metalness: 0.5,
      roughness: 0.3
    });
    lHeater.add(tagPart(tx2Heater1, "heater", false, 5, "mzm"));
    const tx2Heater2 = createBox({
      size: [armLen - 0.5, heaterH, heaterW],
      position: [dopingX, cladTopY + heaterH / 2, tx2HeaterZ2],
      color: 0xeab308,
      metalness: 0.5,
      roughness: 0.3
    });
    lHeater.add(tagPart(tx2Heater2, "heater", false, 5, "mzm"));

    // TX2 heater W vias
    const tx2HeaterVia1 = createBox({
      size: [0.06, viaToM1H, 0.06],
      position: [dopingX, cladTopY + viaToM1H / 2, tx2HeaterZ1],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    });
    lHeater.add(tagPart(tx2HeaterVia1, "heater", false, 5, "mzm"));
    const tx2HeaterVia2 = createBox({
      size: [0.06, viaToM1H, 0.06],
      position: [dopingX, cladTopY + viaToM1H / 2, tx2HeaterZ2],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    });
    lHeater.add(tagPart(tx2HeaterVia2, "heater", false, 5, "mzm"));

    // TX2 heater M1 traces
    const tx2HeaterTrace1 = createBox({
      size: [heaterTraceLen, m1H, 0.08],
      position: [heaterTraceCx, heaterM1Y, tx2HeaterZ1],
      color: 0xf97316, metalness: 0.65, roughness: 0.22
    });
    lM1.add(tagPart(tx2HeaterTrace1, "m1Interconnect", false, 4, "mzm"));
    const tx2HeaterTrace2 = createBox({
      size: [heaterTraceLen, m1H, 0.08],
      position: [heaterTraceCx, heaterM1Y, tx2HeaterZ2],
      color: 0xf97316, metalness: 0.65, roughness: 0.22
    });
    lM1.add(tagPart(tx2HeaterTrace2, "m1Interconnect", false, 4, "mzm"));

    // TX2 heater top vias
    lM1.add(tagPart(createBox({
      size: [0.06, heaterTopViaH, 0.06],
      position: [heaterPadX, cladTopY + heaterH + m1H + heaterTopViaH / 2, tx2HeaterZ1],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    }), "m1Interconnect", false, 4, "mzm"));
    lM1.add(tagPart(createBox({
      size: [0.06, heaterTopViaH, 0.06],
      position: [heaterPadX, cladTopY + heaterH + m1H + heaterTopViaH / 2, tx2HeaterZ2],
      color: 0x78716c, metalness: 0.75, roughness: 0.25
    }), "m1Interconnect", false, 4, "mzm"));

    // TX2 heater bond pads
    lTop.add(tagPart(createBox({
      size: [0.18, padH, 0.18],
      position: [heaterPadX, padBaseY + padH / 2, tx2HeaterZ1],
      color: 0x475569, metalness: 0.55, roughness: 0.28
    }), "bondPad", false, 0, "mzm"));
    lTop.add(tagPart(createBox({
      size: [0.18, padH, 0.18],
      position: [heaterPadX, padBaseY + padH / 2, tx2HeaterZ2],
      color: 0x475569, metalness: 0.55, roughness: 0.28
    }), "bondPad", false, 0, "mzm"));

    // === p-n junction doping for MZM phase arms ===
    // Each arm has n++ on one side, p++ on the other, forming a lateral p-n junction
    const dopingW = 0.08;
    const dopingH = siSlabH;
    const dopingY = siBase + siSlabH / 2;
    const slabTopY = siSlabTop;

    // Arm1 (doping strips on both sides of the rib)
    // Arm edges at Z=armZ±armWidth/2, doping strips just outside
    const arm1nZ = armZ1 - armWidth / 2 - dopingW / 2; // n++ strip, lower side
    const arm1pZ = armZ1 + armWidth / 2 + dopingW / 2; // p++ strip, upper side
    const arm2nZ = armZ2 - armWidth / 2 - dopingW / 2; // n++ strip, lower side
    const arm2pZ = armZ2 + armWidth / 2 + dopingW / 2; // p++ strip, upper side

    const addDoping = (z, colorHex) => {
      const strip = createBox({
        size: [armLen, dopingH, dopingW],
        position: [dopingX, dopingY, z],
        color: colorHex,
        roughness: 0.45,
        metalness: 0.05
      });
      lSiDevice.add(tagPart(strip, "doping", false, 6, "mzm"));
    };
    addDoping(arm1nZ, 0x1d4ed8); // n++
    addDoping(arm1pZ, 0xdc2626); // p++
    addDoping(arm2nZ, 0x1d4ed8); // n++
    addDoping(arm2pZ, 0xdc2626); // p++

    // Contact vias from doped slab up through cladding to M1 level
    const viaBaseY = slabTopY;
    const viaTopY = cladTopY + heaterH + m1H;
    const contactViaH = viaTopY - viaBaseY;
    const contactViaY = viaBaseY + contactViaH / 2;
    const viaXs = [-0.1, 0.5, 1.1].map(v => v * xScale); // three contacts along each strip

    const addContactVias = (z, group) => {
      for (const vx of viaXs) {
        const via = createBox({
          size: [0.04, contactViaH, 0.04],
          position: [vx, contactViaY, z],
          color: 0x78716c,
          metalness: 0.75,
          roughness: 0.25
        });
        lM1.add(tagPart(via, "m1Interconnect", false, 4, "mzm"));
      }
    };
    addContactVias(arm1nZ); // n++ contacts for arm 1
    addContactVias(arm1pZ); // p++ contacts for arm 1
    addContactVias(arm2nZ); // n++ contacts for arm 2
    addContactVias(arm2pZ); // p++ contacts for arm 2

    // Small M1 contact pads atop the via groups (landing pads for electrode connection)
    const addM1ContactPads = (z) => {
      for (const vx of viaXs) {
        const pad = createBox({
          size: [0.08, m1H, 0.08],
          position: [vx, viaTopY + m1H / 2, z],
          color: 0xf97316,
          metalness: 0.65,
          roughness: 0.22
        });
        lM1.add(tagPart(pad, "m1Interconnect", false, 4, "mzm"));
      }
    };
    addM1ContactPads(arm1nZ);
    addM1ContactPads(arm1pZ);
    addM1ContactPads(arm2nZ);
    addM1ContactPads(arm2pZ);

    // M1 Z-bridges: short traces at each contact-via position
    // arm1 n++ (Z=-0.07) → rfGnd1 (Z=0.20)
    // arm2 p++ (Z=0.87) → rfGnd2 (Z=0.60)
    const rfPadY = viaTopY + m1H / 2;

    const addGndBridge = (zFrom, zTo) => {
      const zCenter = (zFrom + zTo) / 2;
      const zLen = Math.abs(zTo - zFrom);
      for (const vx of viaXs) {
        const trace = createBox({
          size: [0.08, m1H, zLen],
          position: [vx, rfPadY, zCenter],
          color: 0xf97316,
          metalness: 0.65,
          roughness: 0.22
        });
        lRf.add(tagPart(trace, "rfElectrode", false, 4, "mzm"));
      }
    };
    addGndBridge(armZ1 - armWidth / 2 - dopingW / 2, 0.20); // arm1 n++ → GND1
    addGndBridge(armZ2 + armWidth / 2 + dopingW / 2, 0.60);  // arm2 p++ → GND2

    // Signal-side M1 traces directly under RF signal electrode
    const addSigTrace = (z) => {
      for (const vx of viaXs) {
        const trace = createBox({
          size: [0.08, m1H, 0.08],
          position: [vx, rfPadY, z],
          color: 0xf97316,
          metalness: 0.65,
          roughness: 0.22
        });
        lRf.add(tagPart(trace, "rfElectrode", false, 4, "mzm"));
      }
    };
    addSigTrace(armZ1 + armWidth / 2 + dopingW / 2); // arm1 p++
    addSigTrace(armZ2 - armWidth / 2 - dopingW / 2); // arm2 n++
    // Signal-side bridges — connect doping vias to RF signal electrode (Z=0.4)
    addGndBridge(armZ1 + armWidth / 2 + dopingW / 2, 0.4); // arm1 p++ → signal
    addGndBridge(armZ2 - armWidth / 2 - dopingW / 2, 0.4); // arm2 n++ → signal

    // === TX2 p-n junction doping for MZM phase arms ===
    const tx2Arm1nZ = tx2ArmZ1 - armWidth / 2 - dopingW / 2;
    const tx2Arm1pZ = tx2ArmZ1 + armWidth / 2 + dopingW / 2;
    const tx2Arm2nZ = tx2ArmZ2 - armWidth / 2 - dopingW / 2;
    const tx2Arm2pZ = tx2ArmZ2 + armWidth / 2 + dopingW / 2;
    addDoping(tx2Arm1nZ, 0x1d4ed8);
    addDoping(tx2Arm1pZ, 0xdc2626);
    addDoping(tx2Arm2nZ, 0x1d4ed8);
    addDoping(tx2Arm2pZ, 0xdc2626);
    addContactVias(tx2Arm1nZ);
    addContactVias(tx2Arm1pZ);
    addContactVias(tx2Arm2nZ);
    addContactVias(tx2Arm2pZ);
    addM1ContactPads(tx2Arm1nZ);
    addM1ContactPads(tx2Arm1pZ);
    addM1ContactPads(tx2Arm2nZ);
    addM1ContactPads(tx2Arm2pZ);

    // TX2 GSG RF electrodes
    const tx2RfSignalZ = tx2Z;
    const tx2RfGnd1Z = tx2Z - 0.20;
    const tx2RfGnd2Z = tx2Z + 0.20;
    const tx2RfSignal = createBox({
      size: [armLen + 0.1, rfH, rfElectrodeW],
      position: [dopingX, rfBaseY + rfH / 2, tx2RfSignalZ],
      color: 0xef4444,
      metalness: 0.7,
      roughness: 0.18
    });
    lRf.add(tagPart(tx2RfSignal, "rfElectrode", false, 4, "mzm"));
    const tx2RfGnd1 = createBox({
      size: [armLen + 0.1, rfH, rfElectrodeW],
      position: [dopingX, rfBaseY + rfH / 2, tx2RfGnd1Z],
      color: 0x94a3b8,
      metalness: 0.75,
      roughness: 0.22
    });
    const tx2RfGnd2 = createBox({
      size: [armLen + 0.1, rfH, rfElectrodeW],
      position: [dopingX, rfBaseY + rfH / 2, tx2RfGnd2Z],
      color: 0x94a3b8,
      metalness: 0.75,
      roughness: 0.22
    });
    lRf.add(tagPart(tx2RfGnd1, "rfElectrode", false, 0, "mzm"), tagPart(tx2RfGnd2, "rfElectrode", false, 0, "mzm"));

    // TX2 M1 Z-bridges (doping contacts → RF electrodes)
    addGndBridge(tx2Arm1nZ, tx2RfGnd1Z);
    addGndBridge(tx2Arm2pZ, tx2RfGnd2Z);
    addSigTrace(tx2Arm1pZ);
    addSigTrace(tx2Arm2nZ);
    addGndBridge(tx2Arm1pZ, tx2Z); // tx2 arm1 p++ → signal
    addGndBridge(tx2Arm2nZ, tx2Z); // tx2 arm2 n++ → signal

    const createOpticalPathCurve = (points) => {
      const curve = new THREE.CurvePath();
      for (let i = 1; i < points.length; i++) {
        curve.add(new THREE.LineCurve3(points[i - 1], points[i]));
      }
      return curve;
    };

    // Optical path (RX: fiber → GC → waveguide → rings → Ge detector)
    const pathGroup = new THREE.Group();
    const pathY = ribY;
    const gcTopY = siBase + siRibH;
    const pathPoints = [
      new THREE.Vector3(fiberCenterX, fiberBottomY + 0.2, rxZ),
      new THREE.Vector3(fiberCenterX, fiberBottomY, rxZ),
      new THREE.Vector3(fiberCenterX, gcTopY, rxZ),
      new THREE.Vector3(ribStartX, gcTopY, rxZ),
      new THREE.Vector3(rxRingBusStartX, gcTopY, rxZ),
      new THREE.Vector3(rxRingBusEndX, gcTopY, rxZ),
      new THREE.Vector3(geX, gcTopY, rxZ),
      new THREE.Vector3(geX, geBaseY + geH, rxZ),
    ];
    const pathCurve = createOpticalPathCurve(pathPoints);
    const pathGeometry = new THREE.TubeGeometry(pathCurve, 64, 0.025, 8, false);
    const pathMesh = new THREE.Mesh(pathGeometry, transparent(0x0891b2, 0.55));
    pathGroup.add(tagPart(pathMesh, "opticalPath"));
    const pathGlowSpheres = [];
    for (let i = 0; i < 10; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.038, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      pathGlowSpheres.push({ mesh: glow, offset: i / 10 });
      pathGroup.add(glow);
    }
    chip.add(tagPart(pathGroup, "opticalPath"));

    // RX edge coupler optical path (fiber from left → edge coupler → separate track → Z-branch → join main RX path)
    const rxEcPathGroup = new THREE.Group();
    const rxEcPathPoints = [
      new THREE.Vector3(chipLeftX - 0.25, fiberBottomY, rxEcZ),
      new THREE.Vector3(chipLeftX + 0.02, gcTopY, rxEcZ),
      new THREE.Vector3(rxEcJunctionX, gcTopY, rxEcZ),
      new THREE.Vector3(rxEcJunctionX, gcTopY, rxZ),
      new THREE.Vector3(-0.5, gcTopY, rxZ),
    ];
    const rxEcPathCurve = createOpticalPathCurve(rxEcPathPoints);
    const rxEcPathGeom = new THREE.TubeGeometry(rxEcPathCurve, 40, 0.022, 8, false);
    rxEcPathGroup.add(tagPart(new THREE.Mesh(rxEcPathGeom, transparent(0x0891b2, 0.45)), "opticalPath"));
    const rxEcGlowSpheres = [];
    for (let i = 0; i < 6; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      rxEcGlowSpheres.push({ mesh: glow, offset: i / 6 });
      rxEcPathGroup.add(glow);
    }
    chip.add(tagPart(rxEcPathGroup, "opticalPath"));

    // Microring drop optical paths (ring → drop waveguide → Ge PD)
    const dropPathCurves = [];
    const dropPathGlowSpheres = [];
    for (let i = 0; i < 3; i++) {
      const rr = ringR[i], rx = ringXs[i];
      const rz = rxZ + 0.16 + ringGap + rr + 0.035;
      const dropZ = rz + rr + 0.032 + dropLen / 2 + 0.03;
      const dropStartZ = dropZ - dropLen / 2;
      const dropEndZ = dropZ + dropLen / 2;
      const dropOpticalGeZ = dropZ + dropLen / 2 - 0.04;
      const pts = [
        new THREE.Vector3(rx, gcTopY, rz + rr),
        new THREE.Vector3(rx, gcTopY, dropStartZ),
        new THREE.Vector3(rx, gcTopY, dropEndZ),
        new THREE.Vector3(rx, gcTopY, dropOpticalGeZ),
        new THREE.Vector3(rx, geBaseY + dropGeH, dropOpticalGeZ),
      ];
      const curve = createOpticalPathCurve(pts);
      dropPathCurves.push(curve);
      const geom = new THREE.TubeGeometry(curve, 16, 0.015, 6, false);
      const group = new THREE.Group();
      group.add(tagPart(new THREE.Mesh(geom, transparent(0x67e8f9, 0.4)), "opticalPath"));
      const spheres = [];
      for (let j = 0; j < 5; j++) {
        const glow = new THREE.Mesh(
          new THREE.SphereGeometry(0.026, 10, 6),
          new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
        );
        spheres.push({ mesh: glow, offset: j / 5 });
        group.add(glow);
      }
      dropPathGlowSpheres.push(spheres);
      chip.add(tagPart(group, "opticalPath"));
    }

    // Monitor PD optical path (coupling region exit → S-bend → monitor PD)
    const mpdPathGroup = new THREE.Group();
    const mpdPathY = siBase + siRibH;
    const mpdPts = dcCoupledPathPts.slice(1).map((point) => new THREE.Vector3(point.x, mpdPathY, point.z));
    mpdPts.push(new THREE.Vector3(mpdX, mpdBaseY + mpdH, mpdZ));
    const mpdCurve = createOpticalPathCurve(mpdPts);
    const mpdGeom = new THREE.TubeGeometry(mpdCurve, 20, 0.015, 6, false);
    mpdPathGroup.add(tagPart(new THREE.Mesh(mpdGeom, transparent(0x67e8f9, 0.4)), "opticalPath"));
    const mpdGlowSpheres = [];
    for (let i = 0; i < 4; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.028, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      mpdGlowSpheres.push({ mesh: glow, offset: i / 4 });
      mpdPathGroup.add(glow);
    }
    chip.add(tagPart(mpdPathGroup, "opticalPath"));

    // TX2 Monitor PD optical path (coupling region exit → S-bend → monitor PD)
    const tx2MpdPathGroup = new THREE.Group();
    const tx2MpdPathPts = tx2DcCoupledPathPts.slice(1).map((point) => new THREE.Vector3(point.x, mpdPathY, point.z));
    tx2MpdPathPts.push(new THREE.Vector3(tx2MpdX, mpdBaseY + mpdH, tx2MpdZ));
    const tx2MpdOptCurve = createOpticalPathCurve(tx2MpdPathPts);
    const tx2MpdOptGeom = new THREE.TubeGeometry(tx2MpdOptCurve, 20, 0.015, 6, false);
    tx2MpdPathGroup.add(tagPart(new THREE.Mesh(tx2MpdOptGeom, transparent(0x67e8f9, 0.4)), "opticalPath"));
    const tx2MpdOptGlow = [];
    for (let i = 0; i < 4; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.028, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      tx2MpdOptGlow.push({ mesh: glow, offset: i / 4 });
      tx2MpdPathGroup.add(glow);
    }
    chip.add(tagPart(tx2MpdPathGroup, "opticalPath"));

    // Electrical path (Ge → W via → M1 → bond pad → external)
    const elecGroup = new THREE.Group();
    const m1CenterY = cladTopY + heaterH + m1H / 2;
    const padCenterY = padBaseY + padH / 2;
    const elecPoints = [
      new THREE.Vector3(geX, geBaseY + geH, rxZ),          // Ge top (start)
      new THREE.Vector3(geX, cladTopY + heaterH, rxZ),       // W via top
      new THREE.Vector3(geX, m1CenterY, rxZ),                // M1 stub
      new THREE.Vector3(geX, padCenterY, rxZ),               // Al bond pad
      new THREE.Vector3(geX, padCenterY + 0.5, rxZ),         // external circuit
    ];
    const elecCurve = new THREE.CatmullRomCurve3(elecPoints);
    const elecGeometry = new THREE.TubeGeometry(elecCurve, 48, 0.022, 8, false);
    const elecMesh = new THREE.Mesh(elecGeometry, transparent(0xf59e0b, 0.5));
    elecGroup.add(tagPart(elecMesh, "electricalPath"));

    const elecGlowSpheres = [];
    for (let i = 0; i < 5; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0xfcd34d, transparent: true, opacity: 0.5 })
      );
      elecGlowSpheres.push({ mesh: glow, offset: i / 5 });
      elecGroup.add(glow);
    }
    chip.add(tagPart(elecGroup, "electricalPath"));

    // Monitor PD electrical path (Ge → W via → M1 → bond pad → external)
    const mpdElecGroup = new THREE.Group();
    const mpdElecPoints = [
      new THREE.Vector3(mpdX, mpdBaseY + mpdH, mpdZ),        // PD top
      new THREE.Vector3(mpdX, cladTopY + heaterH, mpdZ),      // W via top
      new THREE.Vector3(mpdX, m1CenterY, mpdZ),               // M1 stub
      new THREE.Vector3(mpdX, padCenterY, mpdZ),              // Al bond pad
      new THREE.Vector3(mpdX, padCenterY + 0.5, mpdZ),        // external circuit
    ];
    const mpdElecCurve = new THREE.CatmullRomCurve3(mpdElecPoints);
    const mpdElecGeom = new THREE.TubeGeometry(mpdElecCurve, 32, 0.018, 8, false);
    mpdElecGroup.add(tagPart(new THREE.Mesh(mpdElecGeom, transparent(0xf59e0b, 0.5)), "electricalPath"));
    const mpdElecGlowSpheres = [];
    for (let i = 0; i < 5; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.026, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0xfcd34d, transparent: true, opacity: 0.5 })
      );
      mpdElecGlowSpheres.push({ mesh: glow, offset: i / 5 });
      mpdElecGroup.add(glow);
    }
    chip.add(tagPart(mpdElecGroup, "electricalPath"));

    // Drop PD electrical paths (Ge → W via → M1 → bond pad → external)
    const dropElecCurves = [];
    const dropElecGlowSpheres = [];
    for (const d of dropGeData) {
      const dGroup = new THREE.Group();
      const dGeTopY = geBaseY + dropGeH;
      const dPoints = [
        new THREE.Vector3(d.rx, dGeTopY, d.geZ),
        new THREE.Vector3(d.rx, cladTopY + heaterH, d.geZ),
        new THREE.Vector3(d.rx, m1CenterY, d.geZ),
        new THREE.Vector3(d.rx, padCenterY, d.geZ),
        new THREE.Vector3(d.rx, padCenterY + 0.5, d.geZ),
      ];
      const dCurve = new THREE.CatmullRomCurve3(dPoints);
      dropElecCurves.push(dCurve);
      const dGeom = new THREE.TubeGeometry(dCurve, 32, 0.018, 8, false);
      dGroup.add(tagPart(new THREE.Mesh(dGeom, transparent(0xf59e0b, 0.5)), "electricalPath", false, 0, "microring"));
      const dSpheres = [];
      for (let i = 0; i < 5; i++) {
        const glow = new THREE.Mesh(
          new THREE.SphereGeometry(0.028, 10, 6),
          new THREE.MeshBasicMaterial({ color: 0xfcd34d, transparent: true, opacity: 0.5 })
        );
        dSpheres.push({ mesh: glow, offset: i / 5 });
        dGroup.add(glow);
      }
      dropElecGlowSpheres.push(dSpheres);
      chip.add(tagPart(dGroup, "electricalPath", false, 0, "microring"));
    }

    // TX RF electrical path (bond pad → W via → RF signal electrode → over MZM)
    const txeGroup = new THREE.Group();
    const rfCenterY = rfBaseY + rfH / 2;
    const txePoints = [
      new THREE.Vector3(rfPadPx, padCenterY + 0.5, 0.4),
      new THREE.Vector3(rfPadPx, padCenterY, 0.4),
      new THREE.Vector3(rfPadPx, rfCenterY, 0.4),
      new THREE.Vector3(dopingX, rfCenterY, 0.4),
    ];
    const txeCurve = new THREE.CatmullRomCurve3(txePoints);
    const txeGeometry = new THREE.TubeGeometry(txeCurve, 48, 0.02, 8, false);
    const txeMesh = new THREE.Mesh(txeGeometry, transparent(0xf59e0b, 0.5));
    txeGroup.add(tagPart(txeMesh, "electricalPath", false, 0, "mzm"));

    const txeGlowSpheres = [];
    for (let i = 0; i < 6; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.03, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0xfcd34d, transparent: true, opacity: 0.5 })
      );
      txeGlowSpheres.push({ mesh: glow, offset: i / 6 });
      txeGroup.add(glow);
    }
    chip.add(tagPart(txeGroup, "electricalPath", false, 0, "mzm"));

    // Heater DC electrical paths (bond pad → M1 trace → W via → TiN heater)
    const heaterElecCurves = [];
    const heaterElecGlowSpheres = [];
    const heaterZs = [heaterZ1, heaterZ2];
    for (const hz of heaterZs) {
      const hGroup = new THREE.Group();
      const hPoints = [
        new THREE.Vector3(heaterPadX, padCenterY + 0.5, hz),
        new THREE.Vector3(heaterPadX, padCenterY, hz),
        new THREE.Vector3(heaterPadX, m1CenterY, hz),
        new THREE.Vector3(dopingX, m1CenterY, hz),
        new THREE.Vector3(dopingX, cladTopY + heaterH, hz),
      ];
      const hCurve = new THREE.CatmullRomCurve3(hPoints);
      heaterElecCurves.push(hCurve);
      const hGeom = new THREE.TubeGeometry(hCurve, 32, 0.016, 8, false);
      hGroup.add(tagPart(new THREE.Mesh(hGeom, transparent(0xf59e0b, 0.45)), "electricalPath", false, 0, "mzm"));
      const hSpheres = [];
      for (let i = 0; i < 5; i++) {
        const glow = new THREE.Mesh(
          new THREE.SphereGeometry(0.026, 10, 6),
          new THREE.MeshBasicMaterial({ color: 0xfcd34d, transparent: true, opacity: 0.5 })
        );
        hSpheres.push({ mesh: glow, offset: i / 5 });
        hGroup.add(glow);
      }
      heaterElecGlowSpheres.push(hSpheres);
      chip.add(tagPart(hGroup, "electricalPath", false, 0, "mzm"));
    }

    // TX optical path (CW laser → input coupler → waveguide → MMI splitter → phase arms → MMI combiner → output waveguide → output coupler)
    const txPathGroup = new THREE.Group();
    const txPathY = ribY;
    const txPathTopY = siBase + siRibH;

    // GC input path — stops before entering MZM splitter
    const txGcInPathPoints = [
      new THREE.Vector3(gcCenterX, fiberBottomY + 0.2, -0.4),
      new THREE.Vector3(gcCenterX, fiberBottomY, -0.4),
      new THREE.Vector3(gcCenterX, txPathTopY, -0.4),
      new THREE.Vector3(gcCenterX, txPathTopY, 0),
      new THREE.Vector3(gcCenterX, txPathTopY, 0.4),
      new THREE.Vector3(dcX, txPathTopY, 0.4),
      new THREE.Vector3(mmiSplitterCx - mmiLen / 2 - taperLen, txPathTopY, 0.4),
    ];
    const txGcInCurve = createOpticalPathCurve(txGcInPathPoints);
    const txGcInGeom = new THREE.TubeGeometry(txGcInCurve, 40, 0.022, 8, false);
    const txPathMat = transparent(0x0891b2, 0.45);
    txPathGroup.add(tagPart(new THREE.Mesh(txGcInGeom, txPathMat.clone()), "opticalPath"));
    const txOutputFaceX = chipRightX - 0.02;
    const zBendPathPoints = (startZ, endZ) => [0.25, 0.5, 0.75, 1].map((t) => {
      const point = zBendPoint({ startX: combiOutX, startZ, endX: mziInputFaceX, endZ, y: txPathTopY }, t);
      return new THREE.Vector3(point.x, point.y, point.z);
    });
    const txOutputTailPath = [
      new THREE.Vector3(outWgCx, txPathTopY, outWgZ),
      new THREE.Vector3(txOutputFaceX, txPathTopY, outWgZ),
      new THREE.Vector3(txOutputFaceX, fiberBottomY, outWgZ),
      new THREE.Vector3(txOutputFaceX, fiberBottomY + 0.2, outWgZ),
    ];
    const mzmSplitterOutputPathPoints = (baseZ, armZ) => [
      new THREE.Vector3(mmiSplitterCx - mmiLen / 2 - taperLen, txPathTopY, baseZ),
      new THREE.Vector3(mmiSplitterCx - mmiLen / 2, txPathTopY, baseZ),
      new THREE.Vector3(mmiSplitterCx + mmiLen / 2, txPathTopY, baseZ),
      new THREE.Vector3(taperSplitCx + taperLen / 2, txPathTopY, armZ),
    ];
    const mzmCombinerInputPathPoints = (baseZ, armZ) => [
      new THREE.Vector3(taperCombCx - taperLen / 2, txPathTopY, armZ),
      new THREE.Vector3(mmiCombinerCx - mmiLen / 2, txPathTopY, baseZ),
      new THREE.Vector3(mmiCombinerCx + mmiLen / 2, txPathTopY, baseZ),
      new THREE.Vector3(combiOutX, txPathTopY, baseZ),
    ];
    const mziTopPath = [
      ...zBendPathPoints(0.4, mziPort1Z),
      new THREE.Vector3(mziMmiInCx, txPathTopY, mziPort1Z),
      new THREE.Vector3(mziArmStartX, txPathTopY, mziPort1Z),
      new THREE.Vector3(mziArmEndX, txPathTopY, mziPort1Z),
      new THREE.Vector3(mziMmiOutCx, txPathTopY, outWgZ),
      ...txOutputTailPath,
    ];
    const mziLongArmOpticalPath = Array.from({ length: 17 }, (_, i) => {
      const point = mziArm2Curve.getPoint(i / 16);
      return new THREE.Vector3(point.x, txPathTopY, point.z);
    });
    const mziBottomPath = [
      ...zBendPathPoints(tx2Z, mziPort2Z),
      new THREE.Vector3(mziMmiInCx, txPathTopY, mziPort2Z),
      ...mziLongArmOpticalPath,
      new THREE.Vector3(mziMmiOutCx, txPathTopY, mziPort2Z),
      new THREE.Vector3(mziMmiOutCx, txPathTopY, outWgZ),
      ...txOutputTailPath,
    ];
    const txGcInGlowSpheres = [];
    for (let i = 0; i < 5; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      txGcInGlowSpheres.push({ mesh: glow, offset: i / 5 });
      txPathGroup.add(glow);
    }

    // Two paths through the MZM — one per phase arm (edge coupler input)
    const txEdgePathPoints1 = [
      new THREE.Vector3(ecRightX, fiberBottomY + 0.2, 0.4), // outside left edge coupler
      new THREE.Vector3(ecRightX, fiberBottomY, 0.4),        // fiber end face (in)
      new THREE.Vector3(ecRightX, txPathTopY, 0.4),          // edge coupler surface
      new THREE.Vector3(txWgCx, txPathTopY, 0.4),           // TX waveguide
      new THREE.Vector3(dcX, txPathTopY, 0.4),            // DC bus centre
      ...mzmSplitterOutputPathPoints(0.4, armZ1),
      new THREE.Vector3(dopingX, txPathTopY, armZ1),          // phase arm 1
      ...mzmCombinerInputPathPoints(0.4, armZ1),
      ...mziTopPath,
    ];
    const txEdgePathPoints2 = [
      new THREE.Vector3(ecRightX, fiberBottomY + 0.2, 0.4),
      new THREE.Vector3(ecRightX, fiberBottomY, 0.4),
      new THREE.Vector3(ecRightX, txPathTopY, 0.4),
      new THREE.Vector3(txWgCx, txPathTopY, 0.4),           // TX waveguide
      new THREE.Vector3(dcX, txPathTopY, 0.4),            // DC bus centre
      ...mzmSplitterOutputPathPoints(0.4, armZ2),
      new THREE.Vector3(dopingX, txPathTopY, armZ2),          // phase arm 2
      ...mzmCombinerInputPathPoints(0.4, armZ2),
      ...mziTopPath,
    ];

    const txEdgePathCurve1 = createOpticalPathCurve(txEdgePathPoints1);
    const txEdgePathCurve2 = createOpticalPathCurve(txEdgePathPoints2);
    const txEdgePathGeom1 = new THREE.TubeGeometry(txEdgePathCurve1, 64, 0.022, 8, false);
    const txEdgePathGeom2 = new THREE.TubeGeometry(txEdgePathCurve2, 64, 0.022, 8, false);
    txPathGroup.add(tagPart(new THREE.Mesh(txEdgePathGeom1, txPathMat.clone()), "opticalPath"));
    txPathGroup.add(tagPart(new THREE.Mesh(txEdgePathGeom2, txPathMat.clone()), "opticalPath"));

    const txEdgeGlowSpheres1 = [];
    const txEdgeGlowSpheres2 = [];
    for (let i = 0; i < 8; i++) {
      const glow1 = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      txEdgeGlowSpheres1.push({ mesh: glow1, offset: i / 8 });
      txPathGroup.add(glow1);

      const glow2 = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      txEdgeGlowSpheres2.push({ mesh: glow2, offset: i / 8 });
      txPathGroup.add(glow2);
    }
    // TX output GC optical path (waveguide → Z-branch → GC → upward out of chip)
    const txOutGcPathPoints = [
      new THREE.Vector3(txOutputGcBranchX, txPathTopY, outWgZ),
      new THREE.Vector3(txOutputGcBranchX, txPathTopY, (outWgZ + outGcZ) / 2),
      new THREE.Vector3(txOutputGcBranchX, txPathTopY, outGcZ),
      new THREE.Vector3(txOutputGcBranchX, fiberBottomY, outGcZ),
      new THREE.Vector3(txOutputGcBranchX, fiberBottomY + 0.2, outGcZ),
    ];
    const txOutGcPathCurve = createOpticalPathCurve(txOutGcPathPoints);
    const txOutGcPathGeom = new THREE.TubeGeometry(txOutGcPathCurve, 48, 0.022, 8, false);
    const txOutGcPathMesh = new THREE.Mesh(txOutGcPathGeom, txPathMat.clone());
    txPathGroup.add(tagPart(txOutGcPathMesh, "opticalPath"));

    const txOutGcGlowSpheres = [];
    for (let i = 0; i < 6; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      txOutGcGlowSpheres.push({ mesh: glow, offset: i / 6 });
      txPathGroup.add(glow);
    }

    chip.add(tagPart(txPathGroup, "opticalPath"));

    // === TX2 Optical paths ===
    const tx2PathGroup = new THREE.Group();
    const tx2PathMat = transparent(0x0891b2, 0.45);

    // TX2 GC input path
    const tx2GcInPathPoints = [
      new THREE.Vector3(gcCenterX, fiberBottomY + 0.2, tx2GcZ),
      new THREE.Vector3(gcCenterX, fiberBottomY, tx2GcZ),
      new THREE.Vector3(gcCenterX, txPathTopY, tx2GcZ),
      new THREE.Vector3(gcCenterX, txPathTopY, (tx2GcZ + tx2Z) / 2),
      new THREE.Vector3(gcCenterX, txPathTopY, tx2Z),
      new THREE.Vector3(dcX, txPathTopY, tx2Z),
      new THREE.Vector3(mmiSplitterCx - mmiLen / 2 - taperLen, txPathTopY, tx2Z),
    ];
    const tx2GcInCurve = createOpticalPathCurve(tx2GcInPathPoints);
    const tx2GcInGeom = new THREE.TubeGeometry(tx2GcInCurve, 40, 0.022, 8, false);
    tx2PathGroup.add(tagPart(new THREE.Mesh(tx2GcInGeom, tx2PathMat.clone()), "opticalPath"));
    const tx2GcInGlowSpheres = [];
    for (let i = 0; i < 5; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      tx2GcInGlowSpheres.push({ mesh: glow, offset: i / 5 });
      tx2PathGroup.add(glow);
    }

    // TX2 edge coupler arm1 path (through MZI multiplexer detour arm)
    const tx2EdgePath1 = [
      new THREE.Vector3(ecRightX, fiberBottomY + 0.2, tx2Z),
      new THREE.Vector3(ecRightX, fiberBottomY, tx2Z),
      new THREE.Vector3(ecRightX, txPathTopY, tx2Z),
      new THREE.Vector3(txWgCx, txPathTopY, tx2Z),
      new THREE.Vector3(dcX, txPathTopY, tx2Z),
      ...mzmSplitterOutputPathPoints(tx2Z, tx2ArmZ1),
      new THREE.Vector3(dopingX, txPathTopY, tx2ArmZ1),
      ...mzmCombinerInputPathPoints(tx2Z, tx2ArmZ1),
      ...mziBottomPath,
    ];
    const tx2EdgeCurve1 = createOpticalPathCurve(tx2EdgePath1);
    const tx2EdgeGeom1 = new THREE.TubeGeometry(tx2EdgeCurve1, 64, 0.022, 8, false);
    tx2PathGroup.add(tagPart(new THREE.Mesh(tx2EdgeGeom1, tx2PathMat.clone()), "opticalPath"));
    const tx2EdgeGlow1 = [];
    for (let i = 0; i < 8; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      tx2EdgeGlow1.push({ mesh: glow, offset: i / 8 });
      tx2PathGroup.add(glow);
    }

    // TX2 edge coupler arm2 path (through MZI multiplexer, shorter arm then merge)
    const tx2EdgePath2 = [
      new THREE.Vector3(ecRightX, fiberBottomY + 0.2, tx2Z),
      new THREE.Vector3(ecRightX, fiberBottomY, tx2Z),
      new THREE.Vector3(ecRightX, txPathTopY, tx2Z),
      new THREE.Vector3(txWgCx, txPathTopY, tx2Z),
      new THREE.Vector3(dcX, txPathTopY, tx2Z),
      ...mzmSplitterOutputPathPoints(tx2Z, tx2ArmZ2),
      new THREE.Vector3(dopingX, txPathTopY, tx2ArmZ2),
      ...mzmCombinerInputPathPoints(tx2Z, tx2ArmZ2),
      ...mziBottomPath,
    ];
    const tx2EdgeCurve2 = createOpticalPathCurve(tx2EdgePath2);
    const tx2EdgeGeom2 = new THREE.TubeGeometry(tx2EdgeCurve2, 64, 0.022, 8, false);
    tx2PathGroup.add(tagPart(new THREE.Mesh(tx2EdgeGeom2, tx2PathMat.clone()), "opticalPath"));
    const tx2EdgeGlow2 = [];
    for (let i = 0; i < 8; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      tx2EdgeGlow2.push({ mesh: glow, offset: i / 8 });
      tx2PathGroup.add(glow);
    }

    // TX2 output GC path
    const tx2OutGcPathPoints = [
      new THREE.Vector3(outWgCx, txPathTopY, outWgZ),
      new THREE.Vector3(txOutputGcBranchX, txPathTopY, outWgZ),
      new THREE.Vector3(txOutputGcBranchX, txPathTopY, (outWgZ + outGcZ) / 2),
      new THREE.Vector3(txOutputGcBranchX, txPathTopY, outGcZ),
      new THREE.Vector3(txOutputGcBranchX, fiberBottomY, outGcZ),
      new THREE.Vector3(txOutputGcBranchX, fiberBottomY + 0.2, outGcZ),
    ];
    const tx2OutGcCurve = createOpticalPathCurve(tx2OutGcPathPoints);
    const tx2OutGcGeom = new THREE.TubeGeometry(tx2OutGcCurve, 48, 0.022, 8, false);
    tx2PathGroup.add(tagPart(new THREE.Mesh(tx2OutGcGeom, tx2PathMat.clone()), "opticalPath"));
    const tx2OutGcGlow = [];
    for (let i = 0; i < 6; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0x67e8f9, transparent: true, opacity: 0.5 })
      );
      tx2OutGcGlow.push({ mesh: glow, offset: i / 6 });
      tx2PathGroup.add(glow);
    }

    chip.add(tagPart(tx2PathGroup, "opticalPath"));

    // === TX2 Electrical paths ===
    // TX2 Monitor PD electrical path
    const tx2MpdElecGroup = new THREE.Group();
    const tx2MpdElecPoints = [
      new THREE.Vector3(tx2MpdX, mpdBaseY + mpdH, tx2MpdZ),
      new THREE.Vector3(tx2MpdX, cladTopY + heaterH, tx2MpdZ),
      new THREE.Vector3(tx2MpdX, m1CenterY, tx2MpdZ),
      new THREE.Vector3(tx2MpdX, padCenterY, tx2MpdZ),
      new THREE.Vector3(tx2MpdX, padCenterY + 0.5, tx2MpdZ),
    ];
    const tx2MpdElecCurve = new THREE.CatmullRomCurve3(tx2MpdElecPoints);
    const tx2MpdElecGeom = new THREE.TubeGeometry(tx2MpdElecCurve, 32, 0.018, 8, false);
    tx2MpdElecGroup.add(tagPart(new THREE.Mesh(tx2MpdElecGeom, transparent(0xf59e0b, 0.5)), "electricalPath"));
    const tx2MpdElecGlow = [];
    for (let i = 0; i < 5; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.026, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0xfcd34d, transparent: true, opacity: 0.5 })
      );
      tx2MpdElecGlow.push({ mesh: glow, offset: i / 5 });
      tx2MpdElecGroup.add(glow);
    }
    chip.add(tagPart(tx2MpdElecGroup, "electricalPath"));

    // TX2 RF electrical path (bond pad → W via → RF signal electrode → over TX2 MZM)
    const tx2TxeGroup = new THREE.Group();
    const tx2TxePoints = [
      new THREE.Vector3(rfPadPx, padCenterY + 0.5, tx2Z),
      new THREE.Vector3(rfPadPx, padCenterY, tx2Z),
      new THREE.Vector3(rfPadPx, rfCenterY, tx2Z),
      new THREE.Vector3(dopingX, rfCenterY, tx2Z),
    ];
    const tx2TxeCurve = new THREE.CatmullRomCurve3(tx2TxePoints);
    const tx2TxeGeom = new THREE.TubeGeometry(tx2TxeCurve, 48, 0.02, 8, false);
    tx2TxeGroup.add(tagPart(new THREE.Mesh(tx2TxeGeom, transparent(0xf59e0b, 0.5)), "electricalPath", false, 0, "mzm"));
    const tx2TxeGlow = [];
    for (let i = 0; i < 6; i++) {
      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(0.03, 10, 6),
        new THREE.MeshBasicMaterial({ color: 0xfcd34d, transparent: true, opacity: 0.5 })
      );
      tx2TxeGlow.push({ mesh: glow, offset: i / 6 });
      tx2TxeGroup.add(glow);
    }
    chip.add(tagPart(tx2TxeGroup, "electricalPath", false, 0, "mzm"));

    // TX2 Heater DC electrical paths
    const tx2HeaterElecCurves = [];
    const tx2HeaterElecGlowSpheres = [];
    const tx2HeaterZs = [tx2HeaterZ1, tx2HeaterZ2];
    for (const hz of tx2HeaterZs) {
      const hGroup = new THREE.Group();
      const hPoints = [
        new THREE.Vector3(heaterPadX, padCenterY + 0.5, hz),
        new THREE.Vector3(heaterPadX, padCenterY, hz),
        new THREE.Vector3(heaterPadX, m1CenterY, hz),
        new THREE.Vector3(dopingX, m1CenterY, hz),
        new THREE.Vector3(dopingX, cladTopY + heaterH, hz),
      ];
      const hCurve = new THREE.CatmullRomCurve3(hPoints);
      tx2HeaterElecCurves.push(hCurve);
      const hGeom = new THREE.TubeGeometry(hCurve, 32, 0.016, 8, false);
      hGroup.add(tagPart(new THREE.Mesh(hGeom, transparent(0xf59e0b, 0.45)), "electricalPath", false, 0, "mzm"));
      const hSpheres = [];
      for (let i = 0; i < 5; i++) {
        const glow = new THREE.Mesh(
          new THREE.SphereGeometry(0.026, 10, 6),
          new THREE.MeshBasicMaterial({ color: 0xfcd34d, transparent: true, opacity: 0.5 })
        );
        hSpheres.push({ mesh: glow, offset: i / 5 });
        hGroup.add(glow);
      }
      tx2HeaterElecGlowSpheres.push(hSpheres);
      chip.add(tagPart(hGroup, "electricalPath", false, 0, "mzm"));
    }

    // === Labels (face-attached planes) ===
    const faceZ = new THREE.Vector3(0, 0, 1);   // +Z side face
    const faceTop = new THREE.Vector3(0, 1, 0); // top face
    const eps = 0.025; // slight offset above surface
    const sideZ = chipWidth / 2 + eps;
    const wgTopY = siBase + siRibH + eps;
    const stripTopY = stripY + stripH / 2 + eps;
    const mmiTopY = mmiY + mmiH / 2 + eps;

    // Vertical layer stack — +Z side face
    lSubstrate.add(createFaceLabel("Si 衬底", new THREE.Vector3(0, substrateH / 2, sideZ), faceZ, { scale: 0.12 }));
    lBox.add(createFaceLabel("BOX 埋氧层", new THREE.Vector3(0, substrateH + boxH / 2, sideZ), faceZ, { scale: 0.08 }));
    // Si device layer removed — waveguides now sit directly on BOX
    lCladding.add(createFaceLabel("SiO₂ 上包层", new THREE.Vector3(0, siBase + cladBaseH / 2, sideZ), faceZ, { scale: 0.11 }));

    // Waveguides — top face
    lSiDevice.add(createFaceLabel("TX 脊形波导", new THREE.Vector3(txWgCx, wgTopY, 0.4), faceTop, { scale: 0.10 }));
    lSiDevice.add(createFaceLabel("RX 脊形波导", new THREE.Vector3(rxRibAfterRingCenter, wgTopY, rxZ), faceTop, { scale: 0.10 }));

    // MMI & MZM — top face
    lSiDevice.add(createFaceLabel("MMI 分束器", new THREE.Vector3(mmiSplitterCx, mmiTopY, 0.4), faceTop, { scale: 0.10 }));
    lSiDevice.add(createFaceLabel("MMI 合束器", new THREE.Vector3(mmiCombinerCx, mmiTopY, 0.4), faceTop, { scale: 0.10 }));
    lSiDevice.add(createFaceLabel("MZM 相位臂", new THREE.Vector3(dopingX, wgTopY, armZ1), faceTop, { scale: 0.08 }));
    lSiDevice.add(createFaceLabel("MZM 相位臂", new THREE.Vector3(dopingX, wgTopY, armZ2), faceTop, { scale: 0.08 }));
    // PN doping labels — depth test off
    const facePZ = new THREE.Vector3(0, 0, 1);
    const faceNZ = new THREE.Vector3(0, 0, -1);
    // p++ on arm2 p++ front face (+Z, closest to camera)
    const pZ = armZ2 + armWidth / 2 + dopingW + eps;
    // n++ on arm1 n++ back face (-Z, furthest from camera, facing away)
    const nZ = armZ1 - armWidth / 2 - dopingW - eps;
    lSiDevice.add(createFaceLabel("p++", new THREE.Vector3(dopingX, dopingY, pZ), facePZ, { color: "#dc2626", scale: 0.12 }));
    lSiDevice.add(createFaceLabel("n++", new THREE.Vector3(dopingX, dopingY, nZ), faceNZ, { color: "#1d4ed8", scale: 0.12 }));
    lSiDevice.add(createFaceLabel("定向耦合器", new THREE.Vector3(dcX, stripTopY, 0.4), faceTop, { scale: 0.08 }));
    // Monitor PD (at DC coupled port output)
    lGeDetector.add(createFaceLabel("监测 PD", new THREE.Vector3(mpdX, mpdBaseY + mpdH + eps, mpdZ), faceTop, { scale: 0.07 }));

    // Microring resonators
    for (let i = 0; i < 3; i++) {
      const rr = ringR[i];
      const rx = ringXs[i];
      const rz = rxZ + 0.16 + ringGap + rr + 0.035;
      lSiDevice.add(createFaceLabel("λ" + (i + 1) + " 微环谐振器", new THREE.Vector3(rx, stripTopY, rz + rr + 0.06), faceTop, { scale: 0.07 }));
      // Ge PD label on each drop
      const dropZ = rz + rr + 0.032 + dropLen / 2 + 0.03;
      const geZ = dropZ + dropLen / 2 - 0.04;
      lGeDetector.add(createFaceLabel("Ge PD", new THREE.Vector3(rx, geBaseY + dropGeH + eps, geZ), faceTop, { scale: 0.06 }));
    }

    // Ge detector — top face
    const geTopY = geBaseY + geH + eps;
    lGeDetector.add(createFaceLabel("Ge 光电探测器", new THREE.Vector3(geX, geTopY, rxZ), faceTop, { scale: 0.11 }));

    // Grating couplers — top face
    lSiDevice.add(createFaceLabel("RX 光栅耦合器", new THREE.Vector3(gcCenterX, wgTopY, rxZ), faceTop, { scale: 0.10 }));
    lSiDevice.add(createFaceLabel("TX 光栅耦合器", new THREE.Vector3(gcCenterX, wgTopY, -0.4), faceTop, { scale: 0.10 }));
    lSiDevice.add(createFaceLabel("TX 光栅耦合器", new THREE.Vector3(txOutputGcBranchX, wgTopY, outGcZ), faceTop, { scale: 0.10 }));

    // Edge couplers — on ±X end faces
    const facePX = new THREE.Vector3(1, 0, 0);
    const faceNX = new THREE.Vector3(-1, 0, 0);
    const ecY = ribY + 0.04;
    const ecRX = chipRightX + 0.02 + eps;
    const ecLX = chipLeftX - 0.02 - eps;
    lSiDevice.add(createFaceLabel("RX 边缘耦合器", new THREE.Vector3(ecLX, ecY, rxEcZ), faceNX, { scale: 0.08 }));
    lSiDevice.add(createFaceLabel("TX 输入边缘耦合器", new THREE.Vector3(ecLX, ecY, 0.4), faceNX, { scale: 0.08 }));
