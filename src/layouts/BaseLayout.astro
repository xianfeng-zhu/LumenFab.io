---
import { sitePath } from "../lib/paths";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "LumenFab.io 解释光互连、光模块与 CPO 的组件、材料、工艺和测试。"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | LumenFab.io</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const theme =
          stored ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={sitePath("/")}>LumenFab.io</a>
      <button
        class="theme-toggle"
        type="button"
        aria-label="切换深色/浅色模式"
        data-theme-toggle
      >
        <svg class="theme-toggle__sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="theme-toggle__moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </header>
    <main>
      <slot />
    </main>

    <div class="floating-toc" data-floating-toc hidden>
      <button
        class="floating-toc__button"
        type="button"
        aria-label="章节目录"
        aria-expanded="false"
        aria-controls="floating-toc-panel"
      >
        <span class="floating-toc__bar"></span>
        <span class="floating-toc__bar"></span>
        <span class="floating-toc__bar"></span>
      </button>
      <nav class="floating-toc__panel" id="floating-toc-panel" aria-label="章节目录">
        <p class="floating-toc__title">章节</p>
        <ol class="floating-toc__list"></ol>
      </nav>
    </div>

    <script>
      const toggle = document.querySelector("[data-theme-toggle]");
      toggle?.addEventListener("click", () => {
        const html = document.documentElement;
        const next = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
        html.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
      });
    </script>
    <script>
      import mermaid from "mermaid";
      mermaid.initialize({
        startOnLoad: false,
        theme: "neutral",
        securityLevel: "loose"
      });

      const preElements = document.querySelectorAll("pre");
      for (const pre of preElements) {
        const code = pre.querySelector("code");
        const isMermaid =
          pre.classList.contains("language-mermaid") ||
          (code && code.classList.contains("language-mermaid")) ||
          pre.getAttribute("data-language") === "mermaid" ||
          pre.getAttribute("data-lang") === "mermaid";

        if (isMermaid) {
          const content = code ? code.textContent : pre.textContent;
          if (content) {
            const container = document.createElement("div");
            container.className = "mermaid";
            container.textContent = content.trim();
            pre.parentNode?.replaceChild(container, pre);
          }
        }
      }

      mermaid.run();

      const toc = document.querySelector("[data-floating-toc]");
      const tocButton = toc?.querySelector(".floating-toc__button");
      const tocList = toc?.querySelector(".floating-toc__list");
      const headings = Array.from(
        document.querySelectorAll(".concept-page h2, .concept-page h3")
      ).filter((heading) => heading.textContent?.trim());

      const slugCounts = new Map();
      const slugify = (text) => {
        const base = text
          .trim()
          .toLowerCase()
          .replace(/[^\p{L}\p{N}]+/gu, "-")
          .replace(/^-+|-+$/g, "");
        const slug = base || "section";
        const count = slugCounts.get(slug) || 0;
        slugCounts.set(slug, count + 1);
        return count ? `${slug}-${count + 1}` : slug;
      };

      if (toc && tocButton && tocList && headings.length > 2) {
        let activeId = null;

        const closeToc = () => {
          toc.removeAttribute("data-open");
          tocButton.setAttribute("aria-expanded", "false");
        };

        const openToc = () => {
          toc.setAttribute("data-open", "true");
          tocButton.setAttribute("aria-expanded", "true");

          if (activeId) {
            const activeItem = tocList.querySelector(`[data-toc-id="${CSS.escape(activeId)}"]`);
            if (activeItem) {
              activeItem.scrollIntoView({ block: "nearest", behavior: "smooth" });
            }
          }
        };

        for (const heading of headings) {
          if (!heading.id) {
            heading.id = slugify(heading.textContent || "");
          }

          const item = document.createElement("li");
          item.className = `floating-toc__item floating-toc__item--${heading.tagName.toLowerCase()}`;
          item.setAttribute("data-toc-id", heading.id);

          const link = document.createElement("a");
          link.href = `#${heading.id}`;
          link.textContent = heading.textContent?.trim() || "";
          link.addEventListener("click", closeToc);

          item.append(link);
          tocList.append(item);
        }

        /* 2. 当前阅读位置跟踪 —— 用 IntersectionObserver 判断哪个标题在视野中 */
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                const id = entry.target.id;
                if (id !== activeId) {
                  if (activeId) {
                    tocList.querySelector(`[data-toc-id="${CSS.escape(activeId)}"]`)?.classList.remove("active");
                  }
                  activeId = id;
                  tocList.querySelector(`[data-toc-id="${CSS.escape(id)}"]`)?.classList.add("active");
                }
              }
            }
          },
          { rootMargin: "-20% 0px -70% 0px" },
        );

        for (const heading of headings) {
          observer.observe(heading);
        }

        toc.hidden = false;
        tocButton.addEventListener("click", (event) => {
          event.stopPropagation();
          const isOpen = toc.getAttribute("data-open") === "true";
          if (isOpen) {
            closeToc();
          } else {
            openToc();
          }
        });

        let leaveTimer = null;

        tocButton.addEventListener("mouseenter", () => {
          clearTimeout(leaveTimer);
          if (toc.getAttribute("data-open") !== "true") {
            openToc();
          }
        });

        toc.addEventListener("mouseleave", () => {
          leaveTimer = setTimeout(() => {
            if (!toc.matches(":hover")) {
              closeToc();
            }
          }, 250);
        });

        toc.addEventListener("mouseenter", () => {
          clearTimeout(leaveTimer);
        });

        document.addEventListener("click", (event) => {
          if (toc.getAttribute("data-open") === "true" && !toc.contains(event.target)) {
            closeToc();
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            closeToc();
          }
        });
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --max: 1120px;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Noto Sans SC", sans-serif;
  }

  [data-theme="light"] {
    color-scheme: light;
    --bg: #f8faf7;
    --surface: #ffffff;
    --surface-2: #eef5f1;
    --text: #16201b;
    --muted: #65746d;
    --border: #d7e1db;
    --accent: #1d7a6b;
    --accent-strong: #0f4f49;
  }

  [data-theme="dark"] {
    color-scheme: dark;
    --bg: #0f1714;
    --surface: #1a2621;
    --surface-2: #1f2e28;
    --text: #d9e8e1;
    --muted: #7e9b8f;
    --border: #283831;
    --accent: #3db89e;
    --accent-strong: #5dd4be;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
  }

  a {
    color: var(--accent-strong);
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: var(--max);
    margin: 0 auto;
    padding: 1rem 1.25rem;
  }

  .brand {
    color: var(--text);
    font-weight: 800;
    text-decoration: none;
  }

  .theme-toggle {
    display: grid;
    width: 2.25rem;
    height: 2.25rem;
    place-items: center;
    padding: 0;
    background: none;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
    cursor: pointer;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  .theme-toggle:hover {
    color: var(--text);
    border-color: var(--accent);
    background: var(--surface-2);
  }

  [data-theme="light"] .theme-toggle__moon { display: none; }
  [data-theme="dark"] .theme-toggle__sun { display: none; }

  main {
    max-width: var(--max);
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  h1,
  h2,
  h3 {
    line-height: 1.25;
  }

  h1 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 4rem);
    letter-spacing: 0;
  }

  h2 {
    margin-top: 2.5rem;
  }

  h2,
  h3 {
    scroll-margin-top: 1.5rem;
  }

  p {
    max-width: 74ch;
  }

  figure {
    margin: 2rem 0;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  figcaption {
    max-width: 74ch;
    margin-top: 0.65rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  code {
    padding: 0.1rem 0.25rem;
    border-radius: 4px;
    background: var(--surface-2);
  }

  pre.astro-code {
    margin: 1.25rem 0 1.75rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface-2) !important;
    color: var(--text) !important;
    overflow-x: auto;
    line-height: 1.65;
  }

  pre.astro-code code {
    display: block;
    padding: 0;
    background: transparent;
  }

  pre.astro-code span {
    color: inherit !important;
    background: transparent !important;
  }

  table {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    margin: 1.25rem 0 1.75rem;
  }

  th,
  td {
    padding: 0.75rem;
    border: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
  }

  th {
    background: var(--surface-2);
  }

  .page-kicker {
    margin: 0 0 0.65rem;
    color: var(--accent-strong);
    font-weight: 700;
  }

  .lede {
    max-width: 860px;
    color: var(--muted);
    font-size: 1.15rem;
  }

  .band {
    margin: 2rem 0;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }

  .hero-panel {
    max-width: 960px;
    margin-bottom: 2.75rem;
  }

  .section-heading {
    margin-bottom: 1rem;
  }

  .section-heading h2 {
    margin-top: 0;
  }

  .module-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1rem;
  }

  .module-card {
    display: block;
    padding: 1.1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    color: inherit;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  a.module-card:hover,
  a.module-card:focus-visible {
    border-color: var(--accent);
    box-shadow: 0 10px 30px rgb(15 79 73 / 10%);
    transform: translateY(-1px);
  }

  a.module-card:focus-visible {
    outline: 3px solid rgb(29 122 107 / 25%);
    outline-offset: 3px;
  }

  .module-card h3 {
    margin-top: 0;
  }

  .module-card p {
    color: var(--muted);
    font-size: 0.96rem;
  }

  .module-card ul,
  .topic-columns ul {
    padding-left: 1.1rem;
  }

  .topic-columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .mermaid {
    display: flex;
    justify-content: center;
    margin: 1.75rem 0;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow-x: auto;
  }

  .stage-list {
    display: grid;
    gap: 0.8rem;
    margin: 1.75rem 0;
    padding: 0;
    list-style: none;
    counter-reset: stage;
  }

  .stage-list li {
    position: relative;
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.1rem 1rem 3.4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    counter-increment: stage;
  }

  .stage-list li::before {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: grid;
    width: 1.75rem;
    height: 1.75rem;
    place-items: center;
    color: #ffffff;
    font-size: 0.9rem;
    font-weight: 800;
    background: var(--accent);
    border-radius: 999px;
    content: counter(stage);
  }

  .stage-list strong {
    color: var(--text);
    font-size: 1.02rem;
    line-height: 1.45;
  }

  .stage-list span {
    color: var(--muted);
    line-height: 1.75;
  }

  .floating-toc {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 20;
    display: flex;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .floating-toc[hidden] {
    display: none;
  }

  .floating-toc__button {
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    gap: 0.2rem;
    padding: 0.75rem;
    background: var(--accent-strong);
    border: 1px solid rgb(255 255 255 / 45%);
    border-radius: 999px;
    box-shadow: 0 12px 30px rgb(15 79 73 / 22%);
    cursor: pointer;
  }

  .floating-toc__button:focus-visible {
    outline: 3px solid rgb(29 122 107 / 25%);
    outline-offset: 4px;
  }

  .floating-toc__bar {
    display: block;
    width: 1.15rem;
    height: 2px;
    background: #ffffff;
    border-radius: 999px;
  }

  .floating-toc__panel {
    position: absolute;
    right: 0;
    bottom: 3.55rem;
    width: min(22rem, calc(100vw - 2.5rem));
    max-height: min(70vh, 34rem);
    padding: 0.85rem;
    overflow-y: auto;
    background: rgb(255 255 255 / 96%);
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: 0 18px 50px rgb(15 79 73 / 16%);
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.4rem);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .floating-toc[data-open="true"] .floating-toc__panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .floating-toc__title {
    margin: 0 0 0.55rem;
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .floating-toc__list {
    display: grid;
    gap: 0.1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .floating-toc__item a {
    position: relative;
    display: block;
    padding: 0.45rem 0.5rem;
    color: var(--text);
    border-radius: 6px;
    font-size: 0.92rem;
    line-height: 1.45;
    text-decoration: none;
  }

  .floating-toc__item--h3 a {
    padding-left: 1.25rem;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .floating-toc__item.active a {
    color: var(--accent-strong);
    background: var(--surface-2);
    font-weight: 600;
  }

  .floating-toc__item.active a::before {
    position: absolute;
    left: 0;
    top: 50%;
    display: block;
    width: 3px;
    height: 1.1em;
    background: var(--accent-strong);
    border-radius: 3px;
    transform: translateY(-50%);
    content: "";
  }

  .floating-toc__item a:hover,
  .floating-toc__item a:focus-visible {
    color: var(--accent-strong);
    background: var(--surface-2);
    outline: none;
  }

  @media (max-width: 720px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    main {
      padding-top: 1rem;
    }

    .stage-list {
      gap: 0.9rem;
    }

    .stage-list li {
      padding: 1rem 1rem 1rem 3.15rem;
    }

    .stage-list span {
      font-size: 0.98rem;
    }

    .floating-toc {
      right: 1rem;
      bottom: 1rem;
    }

    .floating-toc__panel {
      bottom: 3.5rem;
      width: min(20rem, calc(100vw - 2rem));
      max-height: 62vh;
    }
  }
</style>
