---
import { sitePath } from "../lib/paths";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "LumenFab.io 解释光互连、光模块与 CPO 的组件、材料、工艺和测试。"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | LumenFab.io</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={sitePath("/")}>LumenFab.io</a>
    </header>
    <main>
      <slot />
    </main>

    <div class="floating-toc" data-floating-toc hidden>
      <button
        class="floating-toc__button"
        type="button"
        aria-label="章节目录"
        aria-expanded="false"
        aria-controls="floating-toc-panel"
      >
        <span class="floating-toc__bar"></span>
        <span class="floating-toc__bar"></span>
        <span class="floating-toc__bar"></span>
      </button>
      <nav class="floating-toc__panel" id="floating-toc-panel" aria-label="章节目录">
        <p class="floating-toc__title">章节</p>
        <ol class="floating-toc__list"></ol>
      </nav>
    </div>

    <script>
      import mermaid from "mermaid";
      mermaid.initialize({
        startOnLoad: false,
        theme: "neutral",
        securityLevel: "loose"
      });

      const preElements = document.querySelectorAll("pre");
      for (const pre of preElements) {
        const code = pre.querySelector("code");
        const isMermaid =
          pre.classList.contains("language-mermaid") ||
          (code && code.classList.contains("language-mermaid")) ||
          pre.getAttribute("data-language") === "mermaid" ||
          pre.getAttribute("data-lang") === "mermaid";

        if (isMermaid) {
          const content = code ? code.textContent : pre.textContent;
          if (content) {
            const container = document.createElement("div");
            container.className = "mermaid";
            container.textContent = content.trim();
            pre.parentNode?.replaceChild(container, pre);
          }
        }
      }

      mermaid.run();

      const toc = document.querySelector("[data-floating-toc]");
      const tocButton = toc?.querySelector(".floating-toc__button");
      const tocList = toc?.querySelector(".floating-toc__list");
      const headings = Array.from(
        document.querySelectorAll(".concept-page h2, .concept-page h3")
      ).filter((heading) => heading.textContent?.trim());

      const slugCounts = new Map();
      const slugify = (text) => {
        const base = text
          .trim()
          .toLowerCase()
          .replace(/[^\p{L}\p{N}]+/gu, "-")
          .replace(/^-+|-+$/g, "");
        const slug = base || "section";
        const count = slugCounts.get(slug) || 0;
        slugCounts.set(slug, count + 1);
        return count ? `${slug}-${count + 1}` : slug;
      };

      if (toc && tocButton && tocList && headings.length > 2) {
        for (const heading of headings) {
          if (!heading.id) {
            heading.id = slugify(heading.textContent || "");
          }

          const item = document.createElement("li");
          item.className = `floating-toc__item floating-toc__item--${heading.tagName.toLowerCase()}`;

          const link = document.createElement("a");
          link.href = `#${heading.id}`;
          link.textContent = heading.textContent?.trim() || "";
          link.addEventListener("click", () => {
            toc.removeAttribute("data-open");
            tocButton.setAttribute("aria-expanded", "false");
          });

          item.append(link);
          tocList.append(item);
        }

        toc.hidden = false;
        tocButton.addEventListener("click", () => {
          const isOpen = toc.getAttribute("data-open") === "true";
          if (isOpen) {
            toc.removeAttribute("data-open");
            tocButton.setAttribute("aria-expanded", "false");
          } else {
            toc.setAttribute("data-open", "true");
            tocButton.setAttribute("aria-expanded", "true");
          }
        });
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f8faf7;
    --surface: #ffffff;
    --surface-2: #eef5f1;
    --text: #16201b;
    --muted: #65746d;
    --border: #d7e1db;
    --accent: #1d7a6b;
    --accent-strong: #0f4f49;
    --max: 1120px;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Noto Sans SC", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
  }

  a {
    color: var(--accent-strong);
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: var(--max);
    margin: 0 auto;
    padding: 1rem 1.25rem;
  }

  .brand {
    color: var(--text);
    font-weight: 800;
    text-decoration: none;
  }

  main {
    max-width: var(--max);
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  h1,
  h2,
  h3 {
    line-height: 1.25;
  }

  h1 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 4rem);
    letter-spacing: 0;
  }

  h2 {
    margin-top: 2.5rem;
  }

  h2,
  h3 {
    scroll-margin-top: 1.5rem;
  }

  p {
    max-width: 74ch;
  }

  figure {
    margin: 2rem 0;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  figcaption {
    max-width: 74ch;
    margin-top: 0.65rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  code {
    padding: 0.1rem 0.25rem;
    border-radius: 4px;
    background: var(--surface-2);
  }

  pre.astro-code {
    margin: 1.25rem 0 1.75rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface-2) !important;
    color: var(--text) !important;
    overflow-x: auto;
    line-height: 1.65;
  }

  pre.astro-code code {
    display: block;
    padding: 0;
    background: transparent;
  }

  pre.astro-code span {
    color: inherit !important;
    background: transparent !important;
  }

  table {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    margin: 1.25rem 0 1.75rem;
  }

  th,
  td {
    padding: 0.75rem;
    border: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
  }

  th {
    background: var(--surface-2);
  }

  .page-kicker {
    margin: 0 0 0.65rem;
    color: var(--accent-strong);
    font-weight: 700;
  }

  .lede {
    max-width: 860px;
    color: var(--muted);
    font-size: 1.15rem;
  }

  .band {
    margin: 2rem 0;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }

  .hero-panel {
    max-width: 960px;
    margin-bottom: 2.75rem;
  }

  .section-heading {
    margin-bottom: 1rem;
  }

  .section-heading h2 {
    margin-top: 0;
  }

  .module-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1rem;
  }

  .module-card {
    display: block;
    padding: 1.1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    color: inherit;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  a.module-card:hover,
  a.module-card:focus-visible {
    border-color: var(--accent);
    box-shadow: 0 10px 30px rgb(15 79 73 / 10%);
    transform: translateY(-1px);
  }

  a.module-card:focus-visible {
    outline: 3px solid rgb(29 122 107 / 25%);
    outline-offset: 3px;
  }

  .module-card h3 {
    margin-top: 0;
  }

  .module-card p {
    color: var(--muted);
    font-size: 0.96rem;
  }

  .module-card ul,
  .topic-columns ul {
    padding-left: 1.1rem;
  }

  .topic-columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .mermaid {
    display: flex;
    justify-content: center;
    margin: 1.75rem 0;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow-x: auto;
  }

  .stage-list {
    display: grid;
    gap: 0.8rem;
    margin: 1.75rem 0;
    padding: 0;
    list-style: none;
    counter-reset: stage;
  }

  .stage-list li {
    position: relative;
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.1rem 1rem 3.4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    counter-increment: stage;
  }

  .stage-list li::before {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: grid;
    width: 1.75rem;
    height: 1.75rem;
    place-items: center;
    color: #ffffff;
    font-size: 0.9rem;
    font-weight: 800;
    background: var(--accent);
    border-radius: 999px;
    content: counter(stage);
  }

  .stage-list strong {
    color: var(--text);
    font-size: 1.02rem;
    line-height: 1.45;
  }

  .stage-list span {
    color: var(--muted);
    line-height: 1.75;
  }

  .floating-toc {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 20;
    display: flex;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .floating-toc[hidden] {
    display: none;
  }

  .floating-toc::before {
    position: absolute;
    right: 0;
    bottom: 2.85rem;
    display: block;
    width: min(22rem, calc(100vw - 2.5rem));
    height: 1.05rem;
    content: "";
  }

  .floating-toc__button {
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    gap: 0.2rem;
    padding: 0.75rem;
    background: var(--accent-strong);
    border: 1px solid rgb(255 255 255 / 45%);
    border-radius: 999px;
    box-shadow: 0 12px 30px rgb(15 79 73 / 22%);
    cursor: pointer;
  }

  .floating-toc__button:focus-visible {
    outline: 3px solid rgb(29 122 107 / 25%);
    outline-offset: 4px;
  }

  .floating-toc__bar {
    display: block;
    width: 1.15rem;
    height: 2px;
    background: #ffffff;
    border-radius: 999px;
  }

  .floating-toc__panel {
    position: absolute;
    right: 0;
    bottom: 3.55rem;
    width: min(22rem, calc(100vw - 2.5rem));
    max-height: min(70vh, 34rem);
    padding: 0.85rem;
    overflow-y: auto;
    background: rgb(255 255 255 / 96%);
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: 0 18px 50px rgb(15 79 73 / 16%);
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.4rem);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .floating-toc:hover .floating-toc__panel,
  .floating-toc:focus-within .floating-toc__panel,
  .floating-toc[data-open="true"] .floating-toc__panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .floating-toc__title {
    margin: 0 0 0.55rem;
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .floating-toc__list {
    display: grid;
    gap: 0.1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .floating-toc__item a {
    display: block;
    padding: 0.45rem 0.5rem;
    color: var(--text);
    border-radius: 6px;
    font-size: 0.92rem;
    line-height: 1.45;
    text-decoration: none;
  }

  .floating-toc__item--h3 a {
    padding-left: 1.25rem;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .floating-toc__item a:hover,
  .floating-toc__item a:focus-visible {
    color: var(--accent-strong);
    background: var(--surface-2);
    outline: none;
  }

  @media (max-width: 720px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    main {
      padding-top: 1rem;
    }

    .stage-list {
      gap: 0.9rem;
    }

    .stage-list li {
      padding: 1rem 1rem 1rem 3.15rem;
    }

    .stage-list span {
      font-size: 0.98rem;
    }

    .floating-toc {
      right: 1rem;
      bottom: 1rem;
    }

    .floating-toc__panel {
      bottom: 3.5rem;
      width: min(20rem, calc(100vw - 2rem));
      max-height: 62vh;
    }
  }
</style>
