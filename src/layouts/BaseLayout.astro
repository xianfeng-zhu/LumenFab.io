---
import { sitePath } from "../lib/paths";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "LumenFab.io 解释光互连、光模块与 CPO 的组件、材料、工艺和测试。"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | LumenFab.io</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={sitePath("/")}>LumenFab.io</a>
    </header>
    <main>
      <slot />
    </main>

    <script>
      import mermaid from "mermaid";
      mermaid.initialize({
        startOnLoad: false,
        theme: "neutral",
        securityLevel: "loose"
      });

      const preElements = document.querySelectorAll("pre");
      for (const pre of preElements) {
        const code = pre.querySelector("code");
        const isMermaid =
          pre.classList.contains("language-mermaid") ||
          (code && code.classList.contains("language-mermaid")) ||
          pre.getAttribute("data-language") === "mermaid" ||
          pre.getAttribute("data-lang") === "mermaid";

        if (isMermaid) {
          const content = code ? code.textContent : pre.textContent;
          if (content) {
            const container = document.createElement("div");
            container.className = "mermaid";
            container.textContent = content.trim();
            pre.parentNode?.replaceChild(container, pre);
          }
        }
      }

      mermaid.run();
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f8faf7;
    --surface: #ffffff;
    --surface-2: #eef5f1;
    --text: #16201b;
    --muted: #65746d;
    --border: #d7e1db;
    --accent: #1d7a6b;
    --accent-strong: #0f4f49;
    --max: 1120px;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Noto Sans SC", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
  }

  a {
    color: var(--accent-strong);
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: var(--max);
    margin: 0 auto;
    padding: 1rem 1.25rem;
  }

  .brand {
    color: var(--text);
    font-weight: 800;
    text-decoration: none;
  }

  main {
    max-width: var(--max);
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  h1,
  h2,
  h3 {
    line-height: 1.25;
  }

  h1 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 4rem);
    letter-spacing: 0;
  }

  h2 {
    margin-top: 2.5rem;
  }

  p {
    max-width: 74ch;
  }

  figure {
    margin: 2rem 0;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  figcaption {
    max-width: 74ch;
    margin-top: 0.65rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  code {
    padding: 0.1rem 0.25rem;
    border-radius: 4px;
    background: var(--surface-2);
  }

  pre.astro-code {
    margin: 1.25rem 0 1.75rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface-2) !important;
    color: var(--text) !important;
    overflow-x: auto;
    line-height: 1.65;
  }

  pre.astro-code code {
    display: block;
    padding: 0;
    background: transparent;
  }

  pre.astro-code span {
    color: inherit !important;
    background: transparent !important;
  }

  table {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    margin: 1.25rem 0 1.75rem;
  }

  th,
  td {
    padding: 0.75rem;
    border: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
  }

  th {
    background: var(--surface-2);
  }

  .page-kicker {
    margin: 0 0 0.65rem;
    color: var(--accent-strong);
    font-weight: 700;
  }

  .lede {
    max-width: 860px;
    color: var(--muted);
    font-size: 1.15rem;
  }

  .band {
    margin: 2rem 0;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }

  .hero-panel {
    max-width: 960px;
    margin-bottom: 2.75rem;
  }

  .section-heading {
    margin-bottom: 1rem;
  }

  .section-heading h2 {
    margin-top: 0;
  }

  .module-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1rem;
  }

  .module-card {
    display: block;
    padding: 1.1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    color: inherit;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  a.module-card:hover,
  a.module-card:focus-visible {
    border-color: var(--accent);
    box-shadow: 0 10px 30px rgb(15 79 73 / 10%);
    transform: translateY(-1px);
  }

  a.module-card:focus-visible {
    outline: 3px solid rgb(29 122 107 / 25%);
    outline-offset: 3px;
  }

  .module-card h3 {
    margin-top: 0;
  }

  .module-card p {
    color: var(--muted);
    font-size: 0.96rem;
  }

  .module-card ul,
  .topic-columns ul {
    padding-left: 1.1rem;
  }

  .topic-columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .mermaid {
    display: flex;
    justify-content: center;
    margin: 1.75rem 0;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow-x: auto;
  }

  .stage-list {
    display: grid;
    gap: 0.8rem;
    margin: 1.75rem 0;
    padding: 0;
    list-style: none;
    counter-reset: stage;
  }

  .stage-list li {
    position: relative;
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.1rem 1rem 3.4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    counter-increment: stage;
  }

  .stage-list li::before {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: grid;
    width: 1.75rem;
    height: 1.75rem;
    place-items: center;
    color: #ffffff;
    font-size: 0.9rem;
    font-weight: 800;
    background: var(--accent);
    border-radius: 999px;
    content: counter(stage);
  }

  .stage-list strong {
    color: var(--text);
    font-size: 1.02rem;
    line-height: 1.45;
  }

  .stage-list span {
    color: var(--muted);
    line-height: 1.75;
  }

  @media (max-width: 720px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    main {
      padding-top: 1rem;
    }

    .stage-list {
      gap: 0.9rem;
    }

    .stage-list li {
      padding: 1rem 1rem 1rem 3.15rem;
    }

    .stage-list span {
      font-size: 0.98rem;
    }
  }
</style>
